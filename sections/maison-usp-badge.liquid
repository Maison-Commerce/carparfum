{% comment %}
  Section: Maison USP Badge
  Horizontal USP badge bar with icons and text.
  Desktop: static 4-column row.
  Mobile: continuous infinite marquee (items duplicated for seamless loop).
  Desktop: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-22495&m=dev
  Mobile: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-28214&m=dev
{% endcomment %}

{%- assign section_uid = 'maison-usp-badge-' | append: section.id -%}

<section
  id="{{ section_uid }}"
  class="maison_commerce_maison_usp_badge"
  style="background-color: {{ section.settings.section_bg_color }};"
>
  <div class="maison_commerce_maison_usp_badge__container">
    {% if section.blocks.size > 0 %}
      <div class="maison_commerce_maison_usp_badge__viewport">
        <div class="maison_commerce_maison_usp_badge__items">
          {% for block in section.blocks %}
            {% if block.type == 'usp_item' %}
              <div
                class="maison_commerce_maison_usp_badge__item"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.icon != blank %}
                  <img
                    class="maison_commerce_maison_usp_badge__icon"
                    src="{{ block.settings.icon | image_url: width: 96 }}"
                    alt="{{ block.settings.icon.alt | default: block.settings.text }}"
                    loading="lazy"
                    width="{{ block.settings.icon.width }}"
                    height="{{ block.settings.icon.height }}"
                  >
                {% endif %}
                {% if block.settings.text != blank %}
                  <span
                    class="maison_commerce_maison_usp_badge__text"
                    style="color: {{ section.settings.text_color }};"
                  >
                    {{ block.settings.text }}
                  </span>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}

          {%- comment -%} Duplicate set for seamless mobile marquee (hidden on desktop) {%- endcomment -%}
          {% for block in section.blocks %}
            {% if block.type == 'usp_item' %}
              <div
                class="maison_commerce_maison_usp_badge__item maison_commerce_maison_usp_badge__item--clone"
                aria-hidden="true"
              >
                {% if block.settings.icon != blank %}
                  <img
                    class="maison_commerce_maison_usp_badge__icon"
                    src="{{ block.settings.icon | image_url: width: 96 }}"
                    alt=""
                    loading="lazy"
                    width="{{ block.settings.icon.width }}"
                    height="{{ block.settings.icon.height }}"
                  >
                {% endif %}
                {% if block.settings.text != blank %}
                  <span
                    class="maison_commerce_maison_usp_badge__text"
                    style="color: {{ section.settings.text_color }};"
                  >
                    {{ block.settings.text }}
                  </span>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .maison_commerce_maison_usp_badge {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_left_desktop }}px;
    padding-right: {{ section.settings.padding_right_desktop }}px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_usp_badge {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: 0;
      padding-right: 0;
    }
  }

  .maison_commerce_maison_usp_badge__container {
    max-width: 1360px;
    margin: 0 auto;
  }

  .maison_commerce_maison_usp_badge__viewport {
    width: 100%;
  }

  /* Desktop: static horizontal row, clones hidden */
  .maison_commerce_maison_usp_badge__items {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .maison_commerce_maison_usp_badge__item--clone {
    display: none;
  }

  /* USP Item */
  .maison_commerce_maison_usp_badge__item {
    flex: 1;
    min-width: fit-content;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  /* Icon */
  .maison_commerce_maison_usp_badge__icon {
    display: block;
    height: auto;
    width: auto;
    max-height: 24px;
    flex-shrink: 0;
  }

  /* Text */
  .maison_commerce_maison_usp_badge__text {
    font-size: {{ section.settings.font_size_desktop }}px;
    font-weight: 400;
    line-height: 1.5;
    text-transform: uppercase;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Mobile: infinite marquee */
  @media (max-width: 768px) {
    #{{ section_uid }} .maison_commerce_maison_usp_badge__viewport {
      overflow: hidden;
      mask-image: linear-gradient(
        to right,
        transparent 0,
        #000 24px,
        #000 calc(100% - 24px),
        transparent 100%
      );
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0,
        #000 24px,
        #000 calc(100% - 24px),
        transparent 100%
      );
    }

    #{{ section_uid }} .maison_commerce_maison_usp_badge__items {
      display: flex;
      flex-wrap: nowrap;
      width: max-content;
      gap: {{ section.settings.marquee_gap_mobile | default: 32 }}px;
      animation: maison-usp-badge-scroll-{{ section.id }} {{ section.settings.scroll_duration_mobile | default: 25 }}s linear infinite;
      will-change: transform;
    }

    #{{ section_uid }} .maison_commerce_maison_usp_badge__items:hover {
      animation-play-state: {% if section.settings.pause_on_hover_mobile == false %}running{% else %}paused{% endif %};
    }

    #{{ section_uid }} .maison_commerce_maison_usp_badge__item {
      flex: 0 0 auto;
      min-width: auto;
      justify-content: flex-start;
    }

    #{{ section_uid }} .maison_commerce_maison_usp_badge__item--clone {
      display: flex;
    }

    #{{ section_uid }} .maison_commerce_maison_usp_badge__text {
      font-size: {{ section.settings.font_size_mobile }}px;
      white-space: nowrap;
      display: inline;
      overflow: visible;
    }
  }

  @keyframes maison-usp-badge-scroll-{{ section.id }} {
    from { transform: translate3d(0, 0, 0); }
    to { transform: translate3d(-50%, 0, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_uid }} .maison_commerce_maison_usp_badge__items {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "Maison USP Badge",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background",
      "default": "#FCFCFC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Desktop)",
      "default": 12
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 8,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Mobile)",
      "default": 10
    },
    {
      "type": "header",
      "content": "Mobile marquee"
    },
    {
      "type": "range",
      "id": "scroll_duration_mobile",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "s",
      "label": "Scroll duration (Mobile)",
      "default": 25
    },
    {
      "type": "range",
      "id": "marquee_gap_mobile",
      "min": 12,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Gap between items (Mobile)",
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover_mobile",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Padding Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_left_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Right (Desktop)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Padding Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "usp_item",
      "name": "USP Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "USP Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Maison USP Badge",
      "blocks": [
        {
          "type": "usp_item",
          "settings": {
            "text": "4.4/5 OP TRUSTPILOT"
          }
        },
        {
          "type": "usp_item",
          "settings": {
            "text": "9.000+ TEVREDEN KLANTEN"
          }
        },
        {
          "type": "usp_item",
          "settings": {
            "text": "20% PUUR PARFUM"
          }
        },
        {
          "type": "usp_item",
          "settings": {
            "text": "NIET GOED? GELD TERUG"
          }
        }
      ]
    }
  ]
}
{% endschema %}
