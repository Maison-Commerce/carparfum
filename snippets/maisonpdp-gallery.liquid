{%- comment -%}
  Product image gallery for maison-pdp-hero section.
  Renders a main image area with thumbnail strip.
  Usage: {% render 'maisonpdp-gallery', product: product, section: section %}
{%- endcomment -%}

<div class="maisonpdp-gallery__main" x-ref="galleryMain">
  {%- if section.settings.badge_overlay_image -%}
    <div class="maisonpdp-gallery__badge">
      {{
        section.settings.badge_overlay_image
        | image_url: width: 256
        | image_tag:
          loading: 'eager',
          class: 'maisonpdp-gallery__badge-img',
          alt: 'Badge'
      }}
    </div>
  {%- endif -%}

  <div class="maisonpdp-gallery__images" x-ref="galleryScroll" @scroll.debounce.100="onGalleryScroll()">
    {%- for image in product.images -%}
      {%- if forloop.first -%}
        {%- assign img_loading = 'eager' -%}
      {%- else -%}
        {%- assign img_loading = 'lazy' -%}
      {%- endif -%}
      <div class="maisonpdp-gallery__slide" data-index="{{ forloop.index0 }}">
        {{
          image
          | image_url: width: 1200
          | image_tag:
            loading: img_loading,
            class: 'maisonpdp-gallery__image',
            alt: image.alt | default: product.title,
            widths: '400,600,800,1000,1200',
            style: 'width: 100%; height: 100%; object-fit: cover;',
            sizes: '(max-width: 999px) 100vw, 50vw'
        }}
      </div>
    {%- endfor -%}
  </div>

  {%- if product.images.size > 1 -%}
    <button
      class="maisonpdp-gallery__arrow maisonpdp-gallery__arrow--prev"
      @click="prevImage()"
      x-show="activeImageIndex > 0"
      x-cloak
      x-transition.opacity.duration.300ms
      type="button"
      aria-label="Previous image"
    >
      {%- render 'maisonpdp-icons', icon: 'arrow-left', color: '#001C4F', size: 20 -%}
    </button>
    <button
      class="maisonpdp-gallery__arrow maisonpdp-gallery__arrow--next"
      @click="nextImage()"
      x-show="activeImageIndex < {{ product.images.size | minus: 1 }}"
      x-cloak
      x-transition.opacity.duration.300ms
      type="button"
      aria-label="Next image"
    >
      {%- render 'maisonpdp-icons', icon: 'arrow-right', color: '#001C4F', size: 20 -%}
    </button>
  {%- endif -%}
</div>

{%- if product.images.size > 1 -%}
  <div class="maisonpdp-gallery__thumbs">
    {%- for image in product.images -%}
      <button
        class="maisonpdp-gallery__thumb"
        :class="{ 'maisonpdp-gallery__thumb--active': activeImageIndex === {{ forloop.index0 }} }"
        @click="setActiveImage({{ forloop.index0 }})"
        type="button"
        aria-label="View image {{ forloop.index }}"
      >
        {{
          image
          | image_url: width: 200
          | image_tag:
            loading: 'lazy',
            class: 'maisonpdp-gallery__thumb-img',
            alt: image.alt | default: product.title
        }}
      </button>
    {%- endfor -%}
  </div>
{%- endif -%}
