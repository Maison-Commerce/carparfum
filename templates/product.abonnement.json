{"sections":{"image_hero_R3rkkq":{"type":"image-hero","blocks":{"accent_j8BVFR":{"type":"accent","disabled":true,"settings":{"accent":"Accent"}},"heading_xmQQ3y":{"type":"heading","disabled":true,"settings":{"title":"The CarBar  Abonnement","heading_tag":"h2","heading_font_class":"fs-heading-display-2"}},"text_WX383T":{"type":"text","disabled":true,"settings":{"text":"<p>Use these sections to promote a particular feature with editorial photography.<\/p>","text_font_class":"fs-body-100"}}},"block_order":["accent_j8BVFR","heading_xmQQ3y","text_WX383T"],"settings":{"image_aspect":"custom","desktop_height":55,"mobile_height":50,"image":"shopify:\/\/shop_images\/The_Car_Parfum_foto_s_31_oktober_2024_-_Fini_Production_-1_1ef510c5-6de9-48ac-844f-b53ca80a5343.jpg","focal_point":"image_presentation","mobile_focal_point":"image_presentation","media_link":"","text_position":"center_center","text_position_mobile":"center_center","text_color":"#ffffff","button_background_color":"#ffffff","button_text_color":"#000000","color_overlay":"#000000","color_overlay_gradient":"","overlay_opacity":0,"enable_animation":true,"section_padding":"section--vertical-padding-none"}},"rich_text_WBMpj6":{"type":"rich-text","blocks":{"heading_LbQqVJ":{"type":"heading","settings":{"title":"The CarBar - Abonnement","heading_tag":"h2","heading_font_class":"fs-heading-2-base"}},"text_ifUEmF":{"type":"text","settings":{"text":"<p><br\/>Ontdek het gemak van onze CarBar Abonnementsservice.<\/p><p>Ons The CarBar abonnement biedt je de exclusieve mogelijkheid om iedere 12 weken, <span style=\"text-decoration:underline\"><strong>drie stuks<\/strong><\/span> van jouw favoriete geur te ontvangen voor jouw CarBar. Dit betekent dat je auto altijd fris en uitnodigend zal ruiken.<\/p><p>Met ons abonnement geniet je niet alleen van de constante stroom van verfrissende geuren, maar ook van een speciale prijs. Vergeleken met het los kopen van onze geuren, betaal je namelijk helemaal <span style=\"text-decoration:underline\"><strong>geen verzendkosten<\/strong><\/span>. Dit betekent dat je niet alleen tijd en moeite bespaart, maar ook geld.<br\/><br\/>Als abonnee krijg je toegang tot ons Self Service Centre, waar je <span style=\"text-decoration:underline\"><strong>volledige controle<\/strong><\/span> hebt over je abonnement. Je kunt hier de geurselectie wijzigen, extra producten toevoegen of je abonnement tijdelijk stopzetten of annuleren. Zo blijf je altijd flexibel en kun je je abonnement aanpassen aan jouw wensen.<\/p>","text_font_class":"fs-body-100"}}},"block_order":["heading_LbQqVJ","text_ifUEmF"],"settings":{"alignment":"left_left","enable_animation":true,"divider_style":"none","section_padding":"section--vertical-padding-top-bottom","content_width":"custom","custom_content_width":700}},"main":{"type":"main-product--default","blocks":{"product_header":{"type":"product_header","settings":{"show_divider":false,"show_vendor":false,"show_sku":false,"show_discount":true,"discount_format":"save_percent","show_product_rating":false,"show_sale_badge":true,"show_custom_badges":true}},"text_nEDfRJ":{"type":"text","disabled":true,"settings":{"text_font_class":"fs-body-100","text":"<p>Per 12 weken<\/p>","column_placement":"right"}},"product_callouts_mini":{"type":"product_callouts_mini","disabled":true,"settings":{"icon_1":"none","text_1":"","icon_2":"none","text_2":"Bespaar op verzendkosten","icon_3":"chat","text_3":"","icon_4":"none","text_4":"","icon_5":"none","text_5":"","icon_6":"none","text_6":""}},"variant_picker":{"type":"variant_picker","settings":{"variant_popup_option":"Size","variant_popup_icon":"measuring-tape","variant_popup_text":"Size guide","variant_popup_page":"","swatch_size":"medium","chip_layout":"3col"}},"firmhouse_subscription_options_artiTn":{"type":"shopify:\/\/apps\/firmhouse\/blocks\/subscription_options\/c05a962b-cac2-4640-98c5-5e2e025abc3a","settings":{"title":"Levering:","display_type":"pills","subscribe_and_save_text":"Subscribe & Save","one_time_purcha