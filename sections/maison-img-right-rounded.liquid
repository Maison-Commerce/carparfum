      "id": "body_font_size_desktop",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Body Font Size (Desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "body_font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Body Font Size (Mobile)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 65
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
