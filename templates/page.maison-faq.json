        "faq_item_efqwm7": {
          "type": "faq_item",
          "settings": {
            "question": "Kan ik The Car Parfum verkopen in mijn winkel?",
            "answer": "<p>Ja. We werken al met meer dan 1500 verkooppunten door heel Nederland. Neem gerust contact met ons op.<br/><br/>Telefoon: 085-0139154<br/>E-mail: <a href=\"mailto:info@thecarparfum.com\" target=\"_blank\" title=\"mailto:info@thecarparfum.com\">info@thecarparfum.com</a></p>"
