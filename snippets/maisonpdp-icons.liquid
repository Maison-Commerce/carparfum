{%- comment -%}
  Renders an inline SVG icon.
  Usage: {% render 'maisonpdp-icons', icon: 'checkmark' %}
  Optional: color (default: 'currentColor'), size (default: 20)
{%- endcomment -%}

{%- liquid
  assign icon_color = color | default: 'currentColor'
  assign icon_size = size | default: 20
-%}

{%- case icon -%}

  {%- when 'checkmark' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M5 10L8.5 13.5L15 7" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {%- when 'check-circle' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="10" cy="10" r="8.5" stroke="{{ icon_color }}" stroke-width="1.2"/>
      <path d="M6.5 10L8.75 12.25L13.5 7.5" stroke="{{ icon_color }}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {%- when 'gift' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="2" y="8" width="16" height="3" rx="0.5" stroke="{{ icon_color }}" stroke-width="1.2"/>
      <path d="M3 11V17C3 17.2761 3.22386 17.5 3.5 17.5H16.5C16.7761 17.5 17 17.2761 17 17V11" stroke="{{ icon_color }}" stroke-width="1.2"/>
      <path d="M10 8V17.5" stroke="{{ icon_color }}" stroke-width="1.2"/>
      <path d="M10 8C10 8 10 5 7.5 3.5C6 2.5 4 3.5 4.5 5C5 6.5 10 8 10 8Z" stroke="{{ icon_color }}" stroke-width="1.2"/>
      <path d="M10 8C10 8 10 5 12.5 3.5C14 2.5 16 3.5 15.5 5C15 6.5 10 8 10 8Z" stroke="{{ icon_color }}" stroke-width="1.2"/>
    </svg>

  {%- when 'truck' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 3.5H12V14.5H1V3.5Z" stroke="{{ icon_color }}" stroke-width="1.2"/>
      <path d="M12 7H16L18.5 10V14.5H12V7Z" stroke="{{ icon_color }}" stroke-width="1.2"/>
      <circle cx="5" cy="14.5" r="2" stroke="{{ icon_color }}" stroke-width="1.2"/>
      <circle cx="15" cy="14.5" r="2" stroke="{{ icon_color }}" stroke-width="1.2"/>
    </svg>

  {%- when 'return-arrow' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2 8L7 3M2 8L7 13M2 8H13C15.7614 8 18 10.2386 18 13V13C18 15.7614 15.7614 18 13 18H10" stroke="{{ icon_color }}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {%- when 'heart' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 17.5S2 13 2 7.5C2 4.5 4.5 2 7 2C8.5 2 9.5 2.8 10 3.5C10.5 2.8 11.5 2 13 2C15.5 2 18 4.5 18 7.5C18 13 10 17.5 10 17.5Z" stroke="{{ icon_color }}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {%- when 'star' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 1.5L12.5 7L18.5 7.5L14 11.5L15.5 17.5L10 14.5L4.5 17.5L6 11.5L1.5 7.5L7.5 7L10 1.5Z" fill="{{ icon_color }}"/>
    </svg>

  {%- when 'star-half' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 1.5L12.5 7L18.5 7.5L14 11.5L15.5 17.5L10 14.5L4.5 17.5L6 11.5L1.5 7.5L7.5 7L10 1.5Z" fill="{{ icon_color }}" fill-opacity="0.25"/>
      <path d="M10 1.5L7.5 7L1.5 7.5L6 11.5L4.5 17.5L10 14.5V1.5Z" fill="{{ icon_color }}"/>
    </svg>

  {%- when 'trustpilot' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 1L12.9 7.3L20 7.8L14.7 12.4L16.5 19L10 15.4L3.5 19L5.3 12.4L0 7.8L7.1 7.3L10 1Z" fill="#00B67A"/>
    </svg>

  {%- when 'chevron-down' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M5 7.5L10 12.5L15 7.5" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {%- when 'plus' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 2V18M2 10H18" stroke="{{ icon_color }}" stroke-width="1.25" stroke-linecap="round"/>
    </svg>

  {%- when 'close' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M15 5L5 15M5 5L15 15" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/>
    </svg>

  {%- when 'play' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="10" cy="10" r="9" stroke="{{ icon_color }}" stroke-width="1.2"/>
      <path d="M8 6L14 10L8 14V6Z" fill="{{ icon_color }}"/>
    </svg>

  {%- when 'arrow-left' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 4L6 10L12 16" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {%- when 'arrow-right' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 4L14 10L8 16" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {%- when 'radio-empty' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="10" cy="10" r="8.5" stroke="{{ icon_color }}" stroke-width="1.2"/>
    </svg>

  {%- when 'radio-filled' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="10" cy="10" r="8.5" stroke="{{ icon_color }}" stroke-width="1.2"/>
      <circle cx="10" cy="10" r="5" fill="{{ icon_color }}"/>
    </svg>

  {%- when 'cotton-flower' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="10" cy="7" r="2.5" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <circle cx="7" cy="10" r="2.5" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <circle cx="13" cy="10" r="2.5" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <circle cx="8" cy="13" r="2.5" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <circle cx="12" cy="13" r="2.5" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <circle cx="10" cy="10.5" r="1.5" fill="{{ icon_color }}"/>
    </svg>

  {%- when 'rose' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 3C8 3 5 5.5 5 9C5 12.5 7.5 16 10 17C12.5 16 15 12.5 15 9C15 5.5 12 3 10 3Z" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <path d="M10 5C8.5 6 7 8 7.5 10.5" stroke="{{ icon_color }}" stroke-width="1.1" stroke-linecap="round"/>
      <path d="M10 5C11.5 6 13 8 12.5 10.5" stroke="{{ icon_color }}" stroke-width="1.1" stroke-linecap="round"/>
      <path d="M10 7V12" stroke="{{ icon_color }}" stroke-width="1.1" stroke-linecap="round"/>
    </svg>

  {%- when 'citrus' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="10" cy="10.5" r="6.5" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <circle cx="10" cy="10.5" r="4.5" stroke="{{ icon_color }}" stroke-width="0.8"/>
      <line x1="10" y1="6" x2="10" y2="10.5" stroke="{{ icon_color }}" stroke-width="0.8"/>
      <line x1="6.8" y1="8" x2="10" y2="10.5" stroke="{{ icon_color }}" stroke-width="0.8"/>
      <line x1="13.2" y1="8" x2="10" y2="10.5" stroke="{{ icon_color }}" stroke-width="0.8"/>
      <line x1="7.5" y1="13" x2="10" y2="10.5" stroke="{{ icon_color }}" stroke-width="0.8"/>
      <line x1="12.5" y1="13" x2="10" y2="10.5" stroke="{{ icon_color }}" stroke-width="0.8"/>
      <path d="M9 4C9 3 10 2 11 2.5" stroke="{{ icon_color }}" stroke-width="0.8" stroke-linecap="round"/>
    </svg>

  {%- when 'lavender' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 18V7" stroke="{{ icon_color }}" stroke-width="1.1" stroke-linecap="round"/>
      <ellipse cx="10" cy="5" rx="1.8" ry="2.5" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <ellipse cx="7.5" cy="7.5" rx="1.5" ry="2" transform="rotate(-20 7.5 7.5)" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <ellipse cx="12.5" cy="7.5" rx="1.5" ry="2" transform="rotate(20 12.5 7.5)" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <ellipse cx="8" cy="10.5" rx="1.3" ry="1.8" transform="rotate(-25 8 10.5)" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <ellipse cx="12" cy="10.5" rx="1.3" ry="1.8" transform="rotate(25 12 10.5)" stroke="{{ icon_color }}" stroke-width="1.1"/>
    </svg>

  {%- when 'ice-cream' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M7 10L10 18L13 10" stroke="{{ icon_color }}" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M5.5 8.5C5.5 6 7.5 2 10 2C12.5 2 14.5 6 14.5 8.5C14.5 9.5 13.5 10 12.5 10H7.5C6.5 10 5.5 9.5 5.5 8.5Z" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <path d="M7 6.5H13" stroke="{{ icon_color }}" stroke-width="0.8" stroke-linecap="round"/>
    </svg>

  {%- when 'lotus' -%}
    <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 4C10 4 8 7 8 10C8 13 10 15 10 15C10 15 12 13 12 10C12 7 10 4 10 4Z" stroke="{{ icon_color }}" stroke-width="1.1"/>
      <path d="M6 7C6 7 5 10 6 13C7 15 10 15 10 15" stroke="{{ icon_color }}" stroke-width="1.1" stroke-linecap="round"/>
      <path d="M14 7C14 7 15 10 14 13C13 15 10 15 10 15" stroke="{{ icon_color }}" stroke-width="1.1" stroke-linecap="round"/>
      <path d="M3 10C3 10 4 12 6 14C8 15.5 10 15 10 15" stroke="{{ icon_color }}" stroke-width="1.1" stroke-linecap="round"/>
      <path d="M17 10C17 10 16 12 14 14C12 15.5 10 15 10 15" stroke="{{ icon_color }}" stroke-width="1.1" stroke-linecap="round"/>
    </svg>

{%- endcase -%}
