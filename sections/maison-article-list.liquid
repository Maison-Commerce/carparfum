      "label": "List Title Font Size (Mobile)",
      "default": 14
    },
    {
      "type": "color",
      "id": "list_title_color",
      "label": "List Title Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "list_meta_color",
      "label": "List Meta Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Padding Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 140,
