{%- comment -%} Section: Maison FAQ Banner {%- endcomment -%}

{%- assign body_r = section.settings.body_color | default: '#121212' | color_extract: 'red' -%}
{%- assign body_g = section.settings.body_color | default: '#121212' | color_extract: 'green' -%}
{%- assign body_b = section.settings.body_color | default: '#121212' | color_extract: 'blue' -%}

{%- style -%}
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_banner {
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-right: {{ section.settings.padding_right_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --padding-left: {{ section.settings.padding_left_desktop }}px;
    --heading-font-size: {{ section.settings.heading_font_size_desktop }}px;
    --body-font-size: {{ section.settings.body_font_size_desktop }}px;
    --heading-body-gap: 20px;
  }
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_maison_faq_banner {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-right: {{ section.settings.padding_right_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --padding-left: {{ section.settings.padding_left_mobile }}px;
      --heading-font-size: {{ section.settings.heading_font_size_mobile }}px;
      --body-font-size: {{ section.settings.body_font_size_mobile }}px;
      --heading-body-gap: 8px;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Section Wrapper ====== */
  .maison_commerce_maison_faq_banner {
    padding: var(--padding-top) var(--padding-right) var(--padding-bottom) var(--padding-left);
    background-color: {{ section.settings.section_bg_color | default: '#FFFFFF' }};
  }

  /* ====== Container ====== */
  .maison_commerce_maison_faq_banner__container {
    max-width: 1360px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--heading-body-gap);
    text-align: center;
  }

  /* ====== Heading ====== */
  .maison_commerce_maison_faq_banner__heading {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 800;
    font-size: var(--heading-font-size);
    line-height: 1.3;
    color: {{ section.settings.heading_color | default: '#121212' }};
    margin: 0;
    max-width: 600px;
  }

  /* ====== Subtitle ====== */
  .maison_commerce_maison_faq_banner__subtitle {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: var(--body-font-size);
    line-height: 1.5;
    color: rgba({{ body_r }}, {{ body_g }}, {{ body_b }}, 0.75);
    margin: 0;
    max-width: 480px;
  }

  /* ====== Mobile Responsive ====== */
  @media (max-width: 1050px) {
    .maison_commerce_maison_faq_banner__heading {
      line-height: 1.4;
      max-width: 100%;
    }

    .maison_commerce_maison_faq_banner__subtitle {
      max-width: 100%;
    }
  }
</style>

<section class="maison_commerce_maison_faq_banner">
  <div class="maison_commerce_maison_faq_banner__container">

    {%- if section.settings.heading != blank -%}
      <h2 class="maison_commerce_maison_faq_banner__heading">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="maison_commerce_maison_faq_banner__subtitle">
        {{ section.settings.subtitle }}
      </p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Maison FAQ Banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hoe Kunnen We Helpen?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Vind snel antwoord op je vraag of neem contact met ons op."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Subtitle Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading Font Size (Desktop)",
