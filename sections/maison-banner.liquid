    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Premium autoparfum, ontwikkeld in Nederland.<br>Omdat elke rit een beleving verdient.</p>"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#E6E6E6"
    },
    {
      "type": "range",
      "id": "body_font_size_desktop",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Subtitle Font Size (Desktop)",
      "default": 18
    },
    {
      "type": "range",
      "id": "body_font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subtitle Font Size (Mobile)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP DE COLLECTIE"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#001C4F"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FAFAFB"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image (Mobile)"
    },
    {
      "type": "range",
      "id": "product_image_height_mobile",
      "min": 200,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Product Image Height (Mobile)",
      "default": 320
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "Desktop Section Height",
      "options": [
        { "value": "auto", "label": "Auto (fit content)" },
        { "value": "500px", "label": "Small (500px)" },
        { "value": "700px", "label": "Medium (700px)" },
        { "value": "100vh", "label": "Full Screen" }
      ],
      "default": "100vh"
    },
    {
      "type": "header",
      "content": "Padding (Desktop)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
