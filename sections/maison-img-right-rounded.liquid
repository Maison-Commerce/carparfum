{%- comment -%} Section: Maison Image Right Rounded {%- endcomment -%}

{%- assign body_r = section.settings.body_color | default: '#121212' | color_extract: 'red' -%}
{%- assign body_g = section.settings.body_color | default: '#121212' | color_extract: 'green' -%}
{%- assign body_b = section.settings.body_color | default: '#121212' | color_extract: 'blue' -%}

{%- style -%}
  #shopify-section-{{ section.id }} .maison_commerce_maison_img_right_rounded {
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-right: {{ section.settings.padding_right_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --padding-left: {{ section.settings.padding_left_desktop }}px;
    --heading-font-size: {{ section.settings.heading_font_size_desktop }}px;
    --body-font-size: {{ section.settings.body_font_size_desktop }}px;
    --column-gap: 20px;
    --content-padding-y: 48px;
    --content-padding-x: 40px;
    --content-body-gap: 0px;
    --body-section-gap: 20px;
    --button-padding-y: 16px;
    --button-padding-x: 32px;
    --button-font-size: 14px;
    --button-gap: 12px;
    --arrow-size: 16px;
  }
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_maison_img_right_rounded {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-right: {{ section.settings.padding_right_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --padding-left: {{ section.settings.padding_left_mobile }}px;
      --heading-font-size: {{ section.settings.heading_font_size_mobile }}px;
      --body-font-size: {{ section.settings.body_font_size_mobile }}px;
      --column-gap: 20px;
      --content-padding-y: 32px;
      --content-padding-x: 16px;
      --content-body-gap: 32px;
      --body-section-gap: 20px;
      --button-padding-y: 12px;
      --button-padding-x: 24px;
      --button-font-size: 12px;
      --button-gap: 8px;
      --arrow-size: 16px;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Section Wrapper ====== */
  .maison_commerce_maison_img_right_rounded {
    padding: var(--padding-top) var(--padding-right) var(--padding-bottom) var(--padding-left);
    background-color: {{ section.settings.section_bg_color | default: '#fcfcfc' }};
  }

  /* ====== Main Wrapper (Two Columns) ====== */
  .maison_commerce_maison_img_right_rounded__wrapper {
    display: flex;
    gap: var(--column-gap);
    align-items: stretch;
    max-width: 1360px;
    margin: 0 auto;
  }

  /* ====== Content Column ====== */
  .maison_commerce_maison_img_right_rounded__content-col {
    width: 50%;
    padding: var(--content-padding-y) var(--content-padding-x);
  }

  /* ====== Content Inner ====== */
  .maison_commerce_maison_img_right_rounded__content {
    max-width: 600px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  /* ====== Heading ====== */
  .maison_commerce_maison_img_right_rounded__heading {
    font-weight: 800;
    font-size: var(--heading-font-size);
    line-height: 1.2;
    color: {{ section.settings.heading_color | default: '#121212' }};
    margin: 0;
  }

  /* ====== Body Group ====== */
  .maison_commerce_maison_img_right_rounded__body-group {
    display: flex;
    flex-direction: column;
    gap: var(--body-section-gap);
    font-family: '{% comment %} font-family: 'PP Fragment', sans-serif; {% endcomment %}ment', sans-serif;
    font-weight: 400;
    font-size: var(--body-font-size);
    line-height: 1.5;
    color: rgba({{ body_r }}, {{ body_g }}, {{ body_b }}, 0.75);
  }

  .maison_commerce_maison_img_right_rounded__body-group p {
    margin: 0;
  }

  .maison_commerce_maison_img_right_rounded__body-group strong,
  .maison_commerce_maison_img_right_rounded__body-group b {
    font-weight: 800;
    color: {{ section.settings.body_color | default: '#121212' }};
  }

  /* ====== Button ====== */
  .maison_commerce_maison_img_right_rounded__button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--button-gap);
    padding: var(--button-padding-y) var(--button-padding-x);
    border: 1px solid {{ section.settings.button_border_color | default: '#E6E6E6' }};
    background: transparent;
    font-family: '{% comment %} font-family: 'PP Fragment', sans-serif; {% endcomment %}ment', sans-serif;
    font-weight: 400;
    font-size: var(--button-font-size);
    line-height: 1.5;
    color: {{ section.settings.button_text_color | default: '#121212' }};
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    max-width: 400px;
  }

  .maison_commerce_maison_img_right_rounded__button-arrow {
    width: var(--arrow-size);
    height: var(--arrow-size);
    flex-shrink: 0;
  }

  .maison_commerce_maison_img_right_rounded__button-arrow svg {
    width: 100%;
    height: 100%;
  }

  /* ====== Image Column ====== */
  .maison_commerce_maison_img_right_rounded__image-col {
    width: 50%;
    position: relative;
    overflow: hidden;
  }

  .maison_commerce_maison_img_right_rounded__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ====== Mobile Responsive ====== */
  @media (max-width: 1050px) {
    .maison_commerce_maison_img_right_rounded__wrapper {
      flex-direction: column;
      max-width: 100%;
    }

    .maison_commerce_maison_img_right_rounded__content-col {
      width: 100%;
    }

    .maison_commerce_maison_img_right_rounded__content {
      max-width: 100%;
      height: auto;
      justify-content: flex-start;
      gap: var(--content-body-gap);
    }

    .maison_commerce_maison_img_right_rounded__heading {
      line-height: 1.4;
    }

    .maison_commerce_maison_img_right_rounded__button {
      max-width: 100%;
      width: 100%;
    }

    .maison_commerce_maison_img_right_rounded__image-col {
      width: 100%;
      aspect-ratio: 1;
    }
  }
</style>

<section class="maison_commerce_maison_img_right_rounded">
  <div class="maison_commerce_maison_img_right_rounded__wrapper">

    {%- comment -%} ====== Content Column (Left on Desktop) ====== {%- endcomment -%}
    <div class="maison_commerce_maison_img_right_rounded__content-col">
      <div class="maison_commerce_maison_img_right_rounded__content">

        {%- if section.settings.heading != blank -%}
          <h2 class="maison_commerce_maison_img_right_rounded__heading">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="maison_commerce_maison_img_right_rounded__body-group">
            {{ section.settings.body }}
          </div>
        {%- endif -%}

        {%- if section.settings.button_text != blank and section.settings.button_url != blank -%}
          <a href="{{ section.settings.button_url }}" class="maison_commerce_maison_img_right_rounded__button">
            {{ section.settings.button_text }}
            <span class="maison_commerce_maison_img_right_rounded__button-arrow" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none">
                <path d="M1.33 8h13.34M9.33 2.67L14.67 8l-5.34 5.33" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        {%- endif -%}

      </div>
    </div>

    {%- comment -%} ====== Image Column (Right on Desktop) ====== {%- endcomment -%}
    <div class="maison_commerce_maison_img_right_rounded__image-col">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            class: 'maison_commerce_maison_img_right_rounded__image',
            alt: section.settings.heading
        }}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Maison Img Right Rounded",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Giving Back"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Text",
      "default": "<p>We geloven in meer dan alleen producten verkopen. Daarom zijn we trots partner van <strong>Drive for Life</strong> — een organisatie die zich inzet voor de ontwikkeling van jongeren.</p><p>Een deel van elke aankoop gaat naar programma's die de volgende generatie helpen om hun dromen waar te maken.</p><p><strong>Op dat moment wist hij het zeker: dit moet anders.</strong></p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "LEES MEER OVER DRIVE FOR LIFE"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#fcfcfc"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body Text Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_border_color",
