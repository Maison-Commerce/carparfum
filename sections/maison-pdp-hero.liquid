{%- comment -%} Section: Maison PDP Hero {%- endcomment -%}

<script>
  const product = {{ product | json }};
</script>

{%- style -%}
  #shopify-section-{{ section.id }} .maisonpdp-section {
    --section-bg: {{ section.settings.bg_color | default: '#F9F9F8' }};
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }
  @media (max-width: 999px) {
    #shopify-section-{{ section.id }} .maisonpdp-section {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Reset & Base ====== */
  .maisonpdp-section {
    background: var(--section-bg);
    padding: var(--padding-top) 0 var(--padding-bottom);
    font-weight: 400;
    color: #121212;
    line-height: 1.5;
    box-sizing: border-box;
  }

  .maisonpdp-section > * {
    font-family: 'PP Fragment', sans-serif !important;
    font-style: normal;
  }

  .maisonpdp-section *,
  .maisonpdp-section *::before,
  .maisonpdp-section *::after {
    box-sizing: border-box;
  }

  .maisonpdp-section [x-cloak] {
    display: none !important;
  }

  /* ====== Root layout ====== */
  .maisonpdp-root {
    max-width: 1360px;
    margin: 0 auto;
    display: flex;
    gap: 40px;
    padding: 0 40px;
    align-items: flex-start;
  }

  /* ====== Gallery (left) ====== */
  .maisonpdp-gallery {
    flex: 1;
    position: sticky;
    top: 0;
    min-width: 0;
    padding-bottom: 40px;
  }

  .maisonpdp-gallery__main {
    position: relative;
    overflow: hidden;
    background: #fff;
  }

  .maisonpdp-gallery__images {
    display: flex;
    scroll-snap-type: x mandatory;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .maisonpdp-gallery__images::-webkit-scrollbar {
    display: none;
  }

  .maisonpdp-gallery__slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .maisonpdp-gallery__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .maisonpdp-gallery__badge {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 2;
    pointer-events: none;
  }

  .maisonpdp-gallery__badge-img {
    width: 128px;
    height: 128px;
    display: block;
  }

  .maisonpdp-gallery__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .maisonpdp-gallery__arrow:hover {
    background: #fff;
  }

  .maisonpdp-gallery__arrow--prev {
    left: 12px;
  }

  .maisonpdp-gallery__arrow--next {
    right: 12px;
  }

  .maisonpdp-gallery__thumbs {
    display: flex;
    gap: 8px;
    margin-top: 20px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .maisonpdp-gallery__thumbs::-webkit-scrollbar {
    display: none;
  }

  .maisonpdp-gallery__thumb {
    flex: 0 0 80px;
    width: 80px;
    height: 80px;
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    background: #fff;
    padding: 0;
    transition: border-color 0.15s;
  }

  .maisonpdp-gallery__thumb--active {
    border-color: #001c4f;
  }

  .maisonpdp-gallery__thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ====== Sidebar (right) ====== */
  .maisonpdp-sidebar {
    width: 528px;
    flex-shrink: 0;
  }

  .maisonpdp-sidebar form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ====== Badges ====== */
  .maisonpdp-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .maisonpdp-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 12px;
    height: 24px;
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }

  .maisonpdp-badge > span:not([class]),
  .maisonpdp-price__save > span:not([class]),
  .maisonpdp-price__daily > span:not([class]),
  .maisonpdp-purchase__card-label-badge > span:not([class]),
  .maisonpdp-purchase__popular-tag > span:not([class]),
  .maisonpdp-variant-chip > span:not([class]) {
    transform: translateY(1px);
  }

  .maisonpdp-badge__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .maisonpdp-badge__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* ====== Title ====== */
  .maisonpdp-title {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 800;
    font-size: 24px;
    line-height: 1.4;
    color: #121212;
    margin: 0;
  }

  /* ====== Reviews ====== */
  .maisonpdp-reviews {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 20px;
  }

  .maisonpdp-reviews__stars {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .maisonpdp-reviews__stars svg {
    width: 16px;
    height: 16px;
  }

  .maisonpdp-reviews__text {
    font-size: 12px;
    color: #121212;
  }

  .maisonpdp-reviews__text a {
    color: inherit;
    text-decoration: underline;
  }

  .maisonpdp-reviews__platform {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #121212;
  }

  .maisonpdp-reviews__platform svg {
    width: 14px;
    height: 14px;
  }

  /* ====== Subtitle ====== */
  .maisonpdp-subtitle {
    font-size: 14px;
    line-height: 1.5;
    color: rgba(18, 18, 18, 0.75);
    margin: 0;
  }

  /* ====== Price ====== */
  .maisonpdp-price {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .maisonpdp-price__row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .maisonpdp-price__compare {
    font-size: 14px;
    color: #121212;
    opacity: 0.5;
    text-decoration: line-through;
  }

  .maisonpdp-price__current-group {
    display: flex;
    gap: 4px;
    align-items: flex-end;
    line-height: 1.5;
    color: #121212;
  }

  .maisonpdp-price__current {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 800;
    font-size: 18px;
    color: #121212;
  }

  .maisonpdp-price__per-unit {
    font-size: 14px;
    color: #121212;
    opacity: 0.5;
  }

  .maisonpdp-price__daily {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 4px 12px;
    background: #ebeae9;
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
  }

  .maisonpdp-price__save {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    color: #fff;
  }

  /* ====== USPs ====== */
  .maisonpdp-usps {
    display: flex;
    flex-wrap: wrap;
  }

  .maisonpdp-usp {
    flex: 1 0 50%;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    line-height: 1.5;
    color: #121212;
    padding: 8px 0;
  }

  .maisonpdp-usp__icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .maisonpdp-usp__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .maisonpdp-usp__icon svg {
    width: 16px;
    height: 16px;
  }

  h1 em,
  h2 em,
  h3 em,
  h4 em,
  h5 em,
  h6 em,
  p em,
  [class*=heading-italic] {
    font-family: 'PP Editorial New', serif !important;
    color: #001c4f !important;
  }

  /* ====== Scent pills ====== */
  .maisonpdp-scent-pills {
  }

  .maisonpdp-scent-pills__label {
    font-size: 12px;
    font-weight: 800;
    color: #121212;
    opacity: 0.5;
    margin-bottom: 12px;
  }

  .maisonpdp-scent-pills__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .maisonpdp-scent-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 8px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 14px;
    color: #121212;
    background: #fff;
    min-width: 110px;
    width: 170px;
  }

  .maisonpdp-scent-pill__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .maisonpdp-scent-pill__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* ====== Divider ====== */
  .maisonpdp-divider {
    height: 1px;
    background: rgba(0, 0, 0, 0.08);
    width: 100%;
  }

  /* ====== Purchase options ====== */
  .maisonpdp-purchase {
  }

  .maisonpdp-purchase__cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .maisonpdp-purchase__card {
    position: relative;
    border: 1px solid rgba(0, 0, 0, 0.08);
    padding: 4px 20px;
    min-height: 72px;
    cursor: pointer;
    transition: border-color 0.15s;
    background: #fff;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .maisonpdp-purchase__card--active {
    border: 2px solid #001c4f;
    background: #f5f4f3;
  }

  .maisonpdp-purchase__card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .maisonpdp-purchase__card-left {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .maisonpdp-purchase__radio {
    flex-shrink: 0;
  }

  .maisonpdp-purchase__radio svg {
    width: 18px;
    height: 18px;
  }

  .maisonpdp-purchase__card-label {
    font-size: 14px;
    font-weight: 800;
    color: #121212;
  }

  .maisonpdp-purchase__card-label-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 4px 20px;
    background: #354f3f;
    color: #fff;
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    margin-left: 8px;
    vertical-align: middle;
  }

  @media (max-width: 999px) {
    .maisonpdp-purchase__card-label-badge {
      margin-left: 0;
    }
  }

  .maisonpdp-purchase__card-subtitle {
    font-size: 12px;
    color: rgba(18, 18, 18, 0.75);
    margin-top: 4px;
  }

  .maisonpdp-purchase__card-prices {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    line-height: 1.5;
    color: #121212;
    white-space: nowrap;
  }

  .maisonpdp-purchase__card-price {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 800;
    font-size: 14px;
    color: #121212;
    white-space: nowrap;
    text-align: right;
  }

  .maisonpdp-purchase__card-compare {
    font-size: 12px;
    color: #121212;
    opacity: 0.5;
    text-decoration: line-through;
  }

  .maisonpdp-purchase__popular-tag {
    position: absolute;
    top: -13px;
    right: 18px;
    background: #001c4f;
    color: #fafafb;
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
    line-height: 1.5;
    height: 22px;
    display: flex;
    align-items: center;
  }

  .maisonpdp-purchase__benefits {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .maisonpdp-purchase__benefit {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: rgba(18, 18, 18, 0.75);
  }

  .maisonpdp-purchase__benefit svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .maisonpdp-purchase__sub-row {
    display: flex;
    gap: 12px;
  }

  .maisonpdp-purchase__sub-benefits {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .maisonpdp-purchase__frequency {
    flex-shrink: 0;
    width: 164px;
  }

  .maisonpdp-purchase__frequency select {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    font-family: 'PP Fragment', sans-serif;
    font-size: 12px;
    color: rgba(18, 18, 18, 0.75);
    background: #fff;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%23121212' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    padding-right: 36px;
  }

  /* ====== CTA ====== */
  .maisonpdp-cta {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  .maisonpdp-cta__shipping {
    font-size: 12px;
    text-align: center;
    color: #121212;
    line-height: 1.5;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  @media (max-width: 999px) {
    .maisonpdp-cta__shipping {
      font-size: 10px !important;
    }
  }

  .maisonpdp-cta__shipping svg,
  .maisonpdp-cta__shipping img {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .maisonpdp-cta__shipping u {
    text-decoration: underline;
    font-weight: 400;
  }

  .maisonpdp-cta__button {
    width: 100%;
    height: 56px;
    padding: 16px 20px;
    border: none;
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: 14px;
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: opacity 0.15s;
  }

  .maisonpdp-cta__button:hover {
    opacity: 0.9;
  }

  .maisonpdp-cta__button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .maisonpdp-cta__button-icon {
    width: 16px;
    height: 16px;
  }

  .maisonpdp-cta__button-text-mobile {
    display: none;
  }

  .maisonpdp-cta__payment-icons {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 6px;
  }

  .maisonpdp-cta__payment-icon {
    display: inline-flex;
    overflow: hidden;
  }

  .maisonpdp-cta__payment-icon svg {
    width: 23px;
    height: 16px;
  }

  /* ====== Trust features ====== */
  .maisonpdp-trust-features {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .maisonpdp-trust-feature {
    flex: 1 0 calc(50% - 4px);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 12px;
    text-transform: uppercase;
  }

  .maisonpdp-trust-feature__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .maisonpdp-trust-feature__icon img,
  .maisonpdp-trust-feature__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .maisonpdp-trust-feature__text {
    font-weight: 400;
  }

  .maisonpdp-trust-feature__link {
    font-size: 12px;
    text-decoration: underline;
  }

  /* ====== Donation banner ====== */
  .maisonpdp-donation {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px;
    font-size: 12px;
    text-transform: uppercase;
  }

  .maisonpdp-donation__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .maisonpdp-donation__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .maisonpdp-donation a {
    text-decoration: underline;
    font-weight: 400;
    color: #001c4f;
  }

  .maisonpdp-donation__break {
    display: none !important;
  }

  /* ====== Video ====== */
  .maisonpdp-video {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
  }

  .maisonpdp-video__title {
    font-size: 18px;
    font-weight: 800;
    line-height: 1.4;
    margin: 0;
    color: #121212;
    text-align: center;
  }

  .maisonpdp-video__player {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
  }

  .maisonpdp-video__player video {
    width: 100%;
    display: block;
    cursor: pointer;
  }

  .maisonpdp-video__player video::-webkit-media-controls {
    display: none !important;
  }

  .maisonpdp-video__player.is-playing video::-webkit-media-controls {
    display: flex !important;
  }

  .maisonpdp-video__play-icon {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 8px;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .maisonpdp-video__player.is-playing .maisonpdp-video__play-icon {
    opacity: 0;
  }

  /* ====== Accordions ====== */
  .maisonpdp-accordions {
    display: flex;
    flex-direction: column;
  }

  .maisonpdp-accordion {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .maisonpdp-accordion:last-child {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .maisonpdp-accordion__trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 20px 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: 12px;
    text-transform: uppercase;
    color: #121212;
  }

  .maisonpdp-accordion__trigger:hover {
    opacity: 0.75;
  }

  .maisonpdp-accordion__trigger-icon {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .maisonpdp-accordion__trigger-icon svg {
    width: 12px !important;
    height: 12px !important;
  }

  .maisonpdp-accordion__content {
    overflow: hidden;
  }

  .maisonpdp-accordion__content-inner {
    padding-bottom: 16px;
    font-size: 14px;
    line-height: 1.6;
    color: rgba(18, 18, 18, 0.75);
  }

  .maisonpdp-accordion__content-inner p {
    margin: 0;
  }

  .maisonpdp-accordion__content-inner p + p {
    margin-top: 8px;
  }

  /* ====== Cross-sell ====== */
  .maisonpdp-cross-sell {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
  }

  .maisonpdp-cross-sell__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .maisonpdp-cross-sell__title {
    font-size: 16px;
    font-weight: 800;
    color: #121212;
    margin: 0;
  }

  .maisonpdp-cross-sell__nav {
    display: flex;
    gap: 8px;
  }

  .maisonpdp-cross-sell__nav-btn {
    width: 28px;
    height: 28px;
    border: 1px solid #e6e6e6;
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s;
    padding: 8px;
  }

  .maisonpdp-cross-sell__nav-btn:hover {
    border-color: #121212;
  }

  .maisonpdp-cross-sell__nav-btn svg {
    width: 12px;
    height: 12px;
  }

  .maisonpdp-cross-sell__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    width: 100%;
  }

  .maisonpdp-cross-sell__track::-webkit-scrollbar {
    display: none;
  }

  .maisonpdp-cross-sell__card {
    flex: 0 0 auto;
    width: 100%;
    max-width: 390px;
    scroll-snap-align: start;
    border: 1px solid #e6e6e6;
    border-right: none;
    background: #fff;
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 16px;
  }

  .maisonpdp-cross-sell__card:last-child {
    border-right: 1px solid #e6e6e6;
  }

  .maisonpdp-cross-sell__card-img {
    width: 64px;
    height: 64px;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
  }

  .maisonpdp-cross-sell__card-body {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .maisonpdp-cross-sell__card-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .maisonpdp-cross-sell__card-title {
    font-size: 14px;
    font-weight: 800;
    color: #121212;
    margin: 0;
  }

  .maisonpdp-cross-sell__card-price {
    font-size: 14px;
    font-weight: 800;
    color: #121212;
  }

  .maisonpdp-cross-sell__card-btn {
    padding: 8px 16px;
    height: 36px;
    border: 1px solid #e6e6e6;
    background: transparent;
    color: #121212;
    font-family: 'PP Fragment', sans-serif;
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }

  .maisonpdp-cross-sell__card-btn:hover {
    background: #121212;
    color: #fff;
  }

  .maisonpdp-cross-sell__dots {
    display: none;
  }

  /* ====== Accordion transition ====== */
  .maisonpdp-acc-transition {
    transition: max-height 0.3s ease, opacity 0.25s ease;
    overflow: hidden;
  }

  .maisonpdp-acc-hidden {
    max-height: 0 !important;
    opacity: 0;
  }

  .maisonpdp-acc-visible {
    max-height: 800px;
    opacity: 1;
  }

  /* ====== Mobile ====== */
  @media (max-width: 999px) {
    .maisonpdp-root {
      flex-direction: column;
      gap: 0;
      padding: 0 20px;
    }

    .maisonpdp-gallery {
      position: static;
      width: 100%;
      padding-bottom: 0;
    }

    .maisonpdp-gallery__badge {
      top: 8px;
      left: 8px;
    }

    .maisonpdp-gallery__badge-img {
      width: 80px;
      height: 80px;
    }

    .maisonpdp-gallery__arrow {
      width: 36px;
      height: 36px;
    }

    .maisonpdp-gallery__thumbs {
      margin-top: 12px;
    }

    .maisonpdp-gallery__thumb {
      flex: 0 0 64px;
      width: 64px;
      height: 64px;
    }

    .maisonpdp-sidebar {
      margin-top: 20px;
      width: 100%;
    }

    .maisonpdp-sidebar form {
      gap: 12px;
    }

    .maisonpdp-title {
      font-size: 20px;
    }

    .maisonpdp-reviews__text {
      font-size: 12px;
    }

    .maisonpdp-subtitle {
      font-size: 12px;
    }

    .maisonpdp-price__current {
      font-size: 16px;
    }

    .maisonpdp-price__compare {
      font-size: 12px;
    }

    .maisonpdp-price__per-unit {
      font-size: 12px;
    }

    .maisonpdp-usp {
      flex: 1 0 calc(50% - 4px);
      font-size: 12px;
      padding: 4px 0;
    }

    .maisonpdp-scent-pill {
      width: calc(50% - 4px);
      font-size: 12px;
    }

    .maisonpdp-trust-feature {
      flex: 1 0 100%;
    }

    .maisonpdp-badges {
      gap: 8px;
    }

    .maisonpdp-badge {
      padding: 4px 8px;
    }

    .maisonpdp-cta__button {
      height: 44px;
      font-size: 12px;
    }

    .maisonpdp-purchase__cards {
      gap: 12px;
    }

    .maisonpdp-video__title {
      font-size: 16px;
    }

    .maisonpdp-cta__button-text-desktop {
      display: none;
    }

    .maisonpdp-cta__button-text-mobile {
      display: inline;
    }

    .maisonpdp-cross-sell {
      gap: 12px;
    }

    .maisonpdp-cross-sell__title {
      font-size: 14px;
    }

    .maisonpdp-cross-sell__card {
      width: 320px;
      max-width: 320px;
      padding: 12px;
    }

    .maisonpdp-cross-sell__card-img {
      width: 48px;
      height: 48px;
    }

    .maisonpdp-cross-sell__card-body {
      gap: 12px;
    }

    .maisonpdp-cross-sell__card-title,
    .maisonpdp-cross-sell__card-price {
      font-size: 12px;
    }

    .maisonpdp-cross-sell__card-btn {
      height: 30px;
      padding: 8px 12px;
    }

    .maisonpdp-cross-sell__dots {
      display: flex;
      gap: 4px;
      align-items: center;
    }

    .maisonpdp-cross-sell__dot {
      width: 4px;
      height: 4px;
      background: #121212;
      opacity: 0.1;
      transition: width 0.2s, opacity 0.2s;
    }

    .maisonpdp-cross-sell__dot--active {
      width: 16px;
      opacity: 1;
    }

    /* Purchase cards — mobile Figma overrides */
    .maisonpdp-purchase__card {
      padding: 0 12px;
      height: 64px;
      min-height: auto;
      overflow: clip;
    }

    .maisonpdp-purchase__card--active {
      padding: 12px;
      height: auto;
      overflow: visible;
    }

    .maisonpdp-purchase__card-header {
      gap: 12px;
    }

    .maisonpdp-purchase__card-left {
      gap: 12px;
    }

    .maisonpdp-purchase__card-label-badge {
      height: 20px;
      padding: 0 20px;
      font-size: 10px;
    }

    .maisonpdp-purchase__sub-row {
      flex-direction: column;
    }

    .maisonpdp-purchase__sub-benefits {
      flex: none;
    }

    .maisonpdp-purchase__frequency {
      flex-shrink: initial;
      width: 100%;
    }

    /* Price — mobile Figma overrides */
    .maisonpdp-price {
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
    }

    .maisonpdp-price__daily {
      width: 100%;
    }

    .maisonpdp-price__row {
      align-items: center !important;
    }

    .maisonpdp-price__save {
      align-self: center !important;
    }

    .maisonpdp-donation__break {
      display: block !important;
    }

    .maisonpdp-trust-feature__icon {
      width: 16px !important;
      height: 16px !important;
    }
  }

  /* ====== Variant Picker ====== */
  .maisonpdp-variant-picker {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .maisonpdp-variant-picker__option {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .maisonpdp-variant-picker__label {
    font-size: 12px;
    font-weight: 800;
    color: #001c4f;
    opacity: 0.5;
  }

  .maisonpdp-variant-picker__label span {
    opacity: 1;
    font-weight: 400;
    text-transform: none;
  }

  .maisonpdp-variant-picker__values {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* Chip style */
  .maisonpdp-variant-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 14px;
    color: #121212;
    background: #fff;
    cursor: pointer;
    transition: border-color 0.15s;
    min-width: 60px;
    text-align: center;
  }

  .maisonpdp-variant-chip:hover {
    border-color: rgba(0, 28, 79, 0.3);
  }

  .maisonpdp-variant-chip--selected {
    border: 2px solid #001c4f;
    padding: 7px 15px;
  }

  .maisonpdp-variant-chip--equal {
    flex: 1;
    min-width: 80px;
  }

  /* Swatch style */
  .maisonpdp-variant-swatch {
    position: relative;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .maisonpdp-variant-swatch[data-shape='round'] {
    border-radius: 50%;
  }

  .maisonpdp-variant-swatch[data-shape='square'] {
    border-radius: 0;
  }

  .maisonpdp-variant-swatch[data-shape='rectangle'] {
    width: 50px;
    height: 36px;
    border-radius: 0;
  }

  .maisonpdp-variant-swatch:hover {
    border-color: rgba(0, 28, 79, 0.3);
  }

  .maisonpdp-variant-swatch--selected {
    border: 2px solid #001c4f;
  }

  .maisonpdp-variant-swatch img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Dropdown style */
  .maisonpdp-variant-select {
    padding: 10px 14px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 14px;
    color: #121212;
    background: #fff;
    width: 100%;
    max-width: 300px;
    cursor: pointer;
    appearance: auto;
  }

  .maisonpdp-variant-select:focus {
    outline: none;
    border-color: #001c4f;
  }

  /* ====== Spinner ====== */
  @keyframes maisonpdp-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .maisonpdp-cta__spinner {
    display: inline-block;
    width: 20px;
    height: 20px;
    border: 2px solid transparent;
    border-top-color: currentColor;
    border-right-color: currentColor;
    border-radius: 50%;
    animation: maisonpdp-spin 0.6s linear infinite;
  }

  .maisonpdp-cta__spinner--small {
    width: 14px;
    height: 14px;
  }

  .maisonpdp-cross-sell__card-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<section
  class="maisonpdp-section"
  x-data="maisonpdpHero()"
  data-section-id="{{ section.id }}"
>
  {%- comment -%} ====== Product JSON for Alpine.js ====== {%- endcomment -%}
  <script type="application/json" data-maisonpdp-product>
    {
      "id": {{ product.id }},
      "title": {{ product.title | json }},
      "options": {{ product.options | json }},
      "variants": [
        {%- for variant in product.variants -%}
          {
            "id": {{ variant.id }},
            "title": {{ variant.title | json }},
            "price": {{ variant.price }},
            "compare_at_price": {{ variant.compare_at_price | default: 'null' }},
            "available": {{ variant.available }},
            "option1": {{ variant.option1 | json }},
            "option2": {{ variant.option2 | json }},
            "option3": {{ variant.option3 | json }},
            "featured_image_position": {{ variant.featured_image.position | default: 'null' }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ],
      "selling_plan_groups": [
        {%- for group in product.selling_plan_groups -%}
          {
            "id": {{ group.id | json }},
            "name": {{ group.name | json }},
            "selling_plans": [
              {%- for plan in group.selling_plans -%}
                {
                  "id": {{ plan.id }},
                  "name": {{ plan.name | json }},
                  "price_adjustments": [
                    {%- for adj in plan.price_adjustments -%}
                      {
                        "order_count": {{ adj.order_count | default: 'null' }},
                        "position": {{ adj.position }},
                        "value_type": {{ adj.value_type | json }},
                        "value": {{ adj.value }}
                      }{%- unless forloop.last -%},{%- endunless -%}
                    {%- endfor -%}
                  ]
                }{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ],
            "app_id": {{ group.app_id | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>

  <div class="maisonpdp-root">
    {%- comment -%} ====== LEFT: Sticky Gallery ====== {%- endcomment -%}
    <div class="maisonpdp-gallery">
      {%- render 'maisonpdp-gallery', product: product, section: section -%}
    </div>

    {%- comment -%} ====== RIGHT: Scrollable Sidebar ====== {%- endcomment -%}
    <div class="maisonpdp-sidebar">
      <form method="post" action="{{ routes.cart_add_url }}" x-ref="form" @submit.prevent="addToCart()">
        <input type="hidden" name="id" :value="currentVariantId">
        <input type="hidden" name="selling_plan" :value="selectedSellingPlan" x-show="selectedSellingPlan">

        {%- for block in section.blocks -%}
          {%- liquid
            assign prev_type = null
            if forloop.index0 > 0
              assign prev_index = forloop.index0 | minus: 1
              assign prev_type = section.blocks[prev_index].type
            endif
            assign next_type = null
            assign next_index = forloop.index0 | plus: 1
            if next_index < section.blocks.size
              assign next_type = section.blocks[next_index].type
            endif
          -%}

          {%- case block.type -%}
              {%- comment -%} ====== BADGE ====== {%- endcomment -%}
            {%- when 'badge' -%}
              {%- if prev_type != 'badge' -%}<div class="maisonpdp-badges">{%- endif -%}
              <div
                class="maisonpdp-badge"
                style="background:{{ block.settings.badge_bg_color | default: '#E4E7EC' }};color:{{ block.settings.badge_text_color | default: '#001C4F' }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.badge_icon -%}
                  <span class="maisonpdp-badge__icon">
                    {{ block.settings.badge_icon | image_url: width: 32 | image_tag: alt: '' }}
                  </span>
                {%- elsif block.settings.badge_icon_type != blank and block.settings.badge_icon_type != 'none' -%}
                  <span class="maisonpdp-badge__icon">
                    {%- render 'maisonpdp-icons',
                      icon: block.settings.badge_icon_type,
                      color: 'currentColor',
                      size: 16
                    -%}
                  </span>
                {%- endif -%}
                <span>{{ block.settings.badge_text }}</span>
              </div>
              {%- if next_type != 'badge' -%}</div>{%- endif -%}

              {%- comment -%} ====== TITLE ====== {%- endcomment -%}
            {%- when 'title' -%}
              <h1 class="maisonpdp-title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

              {%- comment -%} ====== REVIEWS ====== {%- endcomment -%}
            {%- when 'reviews' -%}
              <div class="maisonpdp-reviews" {{ block.shopify_attributes }}>
                {%- assign rating_num = block.settings.rating | split: '/' | first | plus: 0 -%}
                {%- assign full_stars = rating_num | floor -%}
                {%- assign remainder = rating_num | minus: full_stars -%}
                {%- assign half_star_index = -1 -%}
                {%- if remainder >= 0.3 -%}
                  {%- assign half_star_index = full_stars | plus: 1 -%}
                {%- endif -%}
                <div class="maisonpdp-reviews__stars">
                  {%- for i in (1..5) -%}
                    {%- if i <= full_stars -%}
                      {%- render 'maisonpdp-icons', icon: 'star', color: '#F5A623', size: 16 -%}
                    {%- elsif i == half_star_index -%}
                      {%- render 'maisonpdp-icons', icon: 'star-half', color: '#F5A623', size: 16 -%}
                    {%- else -%}
                      {%- render 'maisonpdp-icons', icon: 'star', color: '#E4E7EC', size: 16 -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                <span class="maisonpdp-reviews__text">
                  {{ block.settings.rating }}
                  {%- if block.settings.review_count != blank -%}
                    (<a href="{{ block.settings.reviews_url | default: '#' }}">
                      {{- block.settings.review_count }} reviews</a
                    >)
                  {%- endif -%}
                </span>
                {%- if block.settings.review_platform != blank -%}
                  <span class="maisonpdp-reviews__platform">
                    {%- if block.settings.review_platform == 'Trustpilot' -%}
                      {%- render 'maisonpdp-icons', icon: 'trustpilot', size: 16 -%}
                    {%- endif -%}
                    {%- if block.settings.reviews_url != blank -%}
                      <a href="{{ block.settings.reviews_url }}">{{ block.settings.review_platform }}</a>
                    {%- else -%}
                      {{ block.settings.review_platform }}
                    {%- endif -%}
                  </span>
                {%- endif -%}
              </div>

              {%- comment -%} ====== SUBTITLE ====== {%- endcomment -%}
            {%- when 'subtitle' -%}
              <p class="maisonpdp-subtitle" {{ block.shopify_attributes }}>
                {%- if block.settings.text != blank -%}
                  {{ block.settings.text }}
                {%- else -%}
                  {{ product.description | strip_html | truncate: 200 }}
                {%- endif -%}
              </p>

              {%- comment -%} ====== PRICE ====== {%- endcomment -%}
            {%- when 'price' -%}
              <div class="maisonpdp-price" {{ block.shopify_attributes }}>
                <div class="maisonpdp-price__row">
                  {%- if block.settings.show_compare_price -%}
                    <span
                      class="maisonpdp-price__compare"
                      x-show="compareAtPrice && compareAtPrice > currentPrice"
                      x-text="formatMoney(compareAtPrice)"
                      x-cloak
                    >
                      {%- if product.selected_or_first_available_variant.compare_at_price
                          > product.selected_or_first_available_variant.price
                      -%}
                        {{ product.selected_or_first_available_variant.compare_at_price | money }}
                      {%- endif -%}
                    </span>
                  {%- endif -%}
                  <div class="maisonpdp-price__current-group">
                    <span class="maisonpdp-price__current" x-text="formatMoney(currentPrice)">
                      {{ product.selected_or_first_available_variant.price | money }}
                    </span>
                    {%- if block.settings.show_per_unit and block.settings.per_unit_text != blank -%}
                      <span class="maisonpdp-price__per-unit">{{ block.settings.per_unit_text }}</span>
                    {%- endif -%}
                  </div>
                  {%- if block.settings.daily_cost_text != blank -%}
                    <span class="maisonpdp-price__daily">
                      <span>{{ block.settings.daily_cost_text }}</span>
                    </span>
                  {%- endif -%}
                  {%- if block.settings.save_badge_text != blank -%}
                    <span
                      class="maisonpdp-price__save"
                      style="background:{{ block.settings.save_badge_bg | default: '#354F3F' }}"
                    >
                      <span>{{ block.settings.save_badge_text }}</span>
                    </span>
                  {%- endif -%}
                </div>
              </div>

              {%- comment -%} ====== VARIANT PICKER ====== {%- endcomment -%}
            {%- when 'variant_picker' -%}
              {%- unless product.has_only_default_variant -%}
                {%- render 'maisonpdp-variant-picker', product: product, block: block -%}
              {%- endunless -%}

              {%- comment -%} ====== USP ====== {%- endcomment -%}
            {%- when 'usp' -%}
              {%- if prev_type != 'usp' -%}<div class="maisonpdp-usps">{%- endif -%}
              <div class="maisonpdp-usp" {{ block.shopify_attributes }}>
                <span class="maisonpdp-usp__icon">
                  {%- if block.settings.icon == 'custom' and block.settings.custom_icon != blank -%}
                    {{ block.settings.custom_icon | image_url: width: 36 | image_tag: alt: '' }}
                  {%- else -%}
                    {%- render 'maisonpdp-icons', icon: 'checkmark', color: '#354F3F', size: 18 -%}
                  {%- endif -%}
                </span>
                <span>{{ block.settings.text }}</span>
              </div>
              {%- if next_type != 'usp' -%}</div>{%- endif -%}

              {%- comment -%} ====== SCENT PILL ====== {%- endcomment -%}
            {%- when 'scent_pill' -%}
              {%- if prev_type != 'scent_pill' -%}
                <div class="maisonpdp-scent-pills">
                  {%- if section.settings.scent_pills_label != blank -%}
                    <div class="maisonpdp-scent-pills__label">{{ section.settings.scent_pills_label }}</div>
                  {%- endif -%}
                  <div class="maisonpdp-scent-pills__grid">
              {%- endif -%}
              <div class="maisonpdp-scent-pill" {{ block.shopify_attributes }}>
                <span class="maisonpdp-scent-pill__icon">
                  {%- if block.settings.icon -%}
                    {{ block.settings.icon | image_url: width: 40 | image_tag: alt: '' }}
                  {%- elsif block.settings.icon_type != blank and block.settings.icon_type != 'none' -%}
                    {%- render 'maisonpdp-icons', icon: block.settings.icon_type, color: '#001C4F', size: 20 -%}
                  {%- else -%}
                    {%- render 'maisonpdp-icons', icon: 'checkmark', color: '#001C4F', size: 20 -%}
                  {%- endif -%}
                </span>
                {{ block.settings.name }}
              </div>
              {%- if next_type != 'scent_pill' -%}
                </div>
                </div>
              {%- endif -%}

              {%- comment -%} ====== DIVIDER ====== {%- endcomment -%}
            {%- when 'divider' -%}
              <div class="maisonpdp-divider" {{ block.shopify_attributes }}></div>

              {%- comment -%} ====== PURCHASE OPTIONS ====== {%- endcomment -%}
            {%- when 'purchase_options' -%}
              <div class="maisonpdp-purchase" {{ block.shopify_attributes }}>
                <div class="maisonpdp-purchase__cards">
                  {%- comment -%} One-time card {%- endcomment -%}
                  <div
                    class="maisonpdp-purchase__card"
                    :class="{ 'maisonpdp-purchase__card--active': purchaseType === 'one_time' }"
                    @click="selectPurchaseType('one_time')"
                  >
                    <div class="maisonpdp-purchase__card-header">
                      <div class="maisonpdp-purchase__card-left">
                        <span class="maisonpdp-purchase__radio">
                          <template x-if="purchaseType === 'one_time'">
                            {%- render 'maisonpdp-icons', icon: 'radio-filled', color: '#001C4F', size: 18 -%}
                          </template>
                          <template x-if="purchaseType !== 'one_time'">
                            {%- render 'maisonpdp-icons', icon: 'radio-empty', color: '#CCC', size: 18 -%}
                          </template>
                        </span>
                        <span class="maisonpdp-purchase__card-label">
                          {{ block.settings.one_time_label | default: 'Eenmalige aankoop' }}
                          {%- if block.settings.one_time_save_text != blank -%}
                            <span class="maisonpdp-purchase__card-label-badge"
                              ><span>{{ block.settings.one_time_save_text }}</span></span
                            >
                          {%- endif -%}
                        </span>
                      </div>
                      <div class="maisonpdp-purchase__card-prices">
                        <span class="maisonpdp-purchase__card-price" x-text="formatMoney(oneTimePrice)"></span>
                        <span
                          class="maisonpdp-purchase__card-compare"
                          x-show="compareAtPrice && compareAtPrice > oneTimePrice"
                          x-text="formatMoney(compareAtPrice)"
                          x-cloak
                        ></span>
                      </div>
                    </div>
                  </div>

                  {%- comment -%} Subscription card {%- endcomment -%}
                  <template x-if="sellingPlanGroups.length > 0">
                    <div
                      class="maisonpdp-purchase__card"
                      :class="{ 'maisonpdp-purchase__card--active': purchaseType === 'subscription' }"
                      @click="selectPurchaseType('subscription')"
                    >
                      {%- if block.settings.popular_tag_text != blank -%}
                        <div class="maisonpdp-purchase__popular-tag">
                          <span>{{ block.settings.popular_tag_text }}</span>
                        </div>
                      {%- endif -%}

                      <div class="maisonpdp-purchase__card-header">
                        <div class="maisonpdp-purchase__card-left">
                          <span class="maisonpdp-purchase__radio">
                            <template x-if="purchaseType === 'subscription'">
                              {%- render 'maisonpdp-icons', icon: 'radio-filled', color: '#001C4F', size: 18 -%}
                            </template>
                            <template x-if="purchaseType !== 'subscription'">
                              {%- render 'maisonpdp-icons', icon: 'radio-empty', color: '#CCC', size: 18 -%}
                            </template>
                          </span>
                          <div>
                            <div class="maisonpdp-purchase__card-label">
                              {{ block.settings.subscription_label | default: 'Sub & Save' }}
                              {%- if block.settings.subscription_save_text != blank -%}
                                <span class="maisonpdp-purchase__card-label-badge"
                                  ><span>{{ block.settings.subscription_save_text }}</span></span
                                >
                              {%- endif -%}
                            </div>
                            {%- if block.settings.subscription_subtitle != blank -%}
                              <div class="maisonpdp-purchase__card-subtitle">
                                {{ block.settings.subscription_subtitle }}
                              </div>
                            {%- endif -%}
                          </div>
                        </div>
                        <div class="maisonpdp-purchase__card-prices">
                          <span class="maisonpdp-purchase__card-price" x-text="formatMoney(subscriptionPrice)"></span>
                          <span
                            class="maisonpdp-purchase__card-compare"
                            x-show="compareAtPrice"
                            x-text="formatMoney(compareAtPrice)"
                            x-cloak
                          ></span>
                        </div>
                      </div>

                      <template x-if="purchaseType === 'subscription'">
                        <div>
                          <div class="maisonpdp-purchase__benefits">
                            <div class="maisonpdp-purchase__sub-row">
                              <div class="maisonpdp-purchase__sub-benefits">
                                {%- if block.settings.benefit_1 != blank -%}
                                  <div class="maisonpdp-purchase__benefit">
                                    {%- render 'maisonpdp-icons',
                                      icon: 'check-circle',
                                      color: 'rgba(18,18,18,0.75)',
                                      size: 16
                                    -%}
                                    <span>{{ block.settings.benefit_1 }}</span>
                                  </div>
                                {%- endif -%}
                                {%- if block.settings.benefit_2 != blank -%}
                                  <div class="maisonpdp-purchase__benefit">
                                    {%- render 'maisonpdp-icons',
                                      icon: 'check-circle',
                                      color: 'rgba(18,18,18,0.75)',
                                      size: 16
                                    -%}
                                    <span>{{ block.settings.benefit_2 }}</span>
                                  </div>
                                {%- endif -%}
                                {%- if block.settings.benefit_3 != blank -%}
                                  <div class="maisonpdp-purchase__benefit">
                                    {%- render 'maisonpdp-icons',
                                      icon: 'check-circle',
                                      color: 'rgba(18,18,18,0.75)',
                                      size: 16
                                    -%}
                                    <span>{{ block.settings.benefit_3 }}</span>
                                  </div>
                                {%- endif -%}
                              </div>
                              <div class="maisonpdp-purchase__frequency">
                                <select x-model="selectedSellingPlan" @change="onSellingPlanChange()">
                                  <template x-for="plan in currentSellingPlans" :key="plan.id">
                                    <option :value="plan.id" x-text="plan.name"></option>
                                  </template>
                                </select>
                              </div>
                            </div>
                          </div>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </div>

              {%- comment -%} ====== CTA ====== {%- endcomment -%}
            {%- when 'cta' -%}
              <div
                class="maisonpdp-cta"
                {{ block.shopify_attributes }}
                data-shipping-cutoff="{{ block.settings.shipping_cutoff_hour | default: 0 }}"
              >
                {%- if block.settings.shipping_cutoff_hour != blank -%}
                  <div
                    class="maisonpdp-cta__shipping"
                    x-show="shippingCountdown"
                    x-cloak
                    x-transition.opacity.duration.300ms
                  >
                    {%- render 'maisonpdp-icons', icon: 'truck', color: '#121212', size: 20 -%}
                    <span>
                      BESTEL BINNEN <u x-text="shippingCountdown"></u> — <span x-text="shippingDeliveryLabel"></span>
                    </span>
                  </div>
                {%- endif -%}
                <button
                  type="submit"
                  class="maisonpdp-cta__button"
                  style="background:{{ block.settings.button_bg | default: '#D12800' }};color:{{ block.settings.button_text_color | default: '#F9E1DB' }}"
                  :disabled="!currentVariantAvailable || adding"
                >
                  <span class="maisonpdp-cta__button-text-desktop" x-show="!adding">
                    {{ block.settings.button_text | default: 'VOEG TOE AAN WINKELWAGEN' }}
                  </span>
                  <span class="maisonpdp-cta__button-text-mobile" x-show="!adding">
                    {{ block.settings.button_text_mobile | default: 'In Winkelwagen' }}
                  </span>
                  <span class="maisonpdp-cta__button-icon" x-show="!adding">
                    {%- render 'maisonpdp-icons', icon: 'plus', color: 'currentColor', size: 16 -%}
                  </span>
                  <span class="maisonpdp-cta__spinner" x-show="adding" x-cloak></span>
                </button>
                {%- if block.settings.show_payment_icons -%}
                  <div class="maisonpdp-cta__payment-icons">
                    {%- for type in shop.enabled_payment_types -%}
                      <span class="maisonpdp-cta__payment-icon">{{ type | payment_type_svg_tag }}</span>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>

              {%- comment -%} ====== TRUST FEATURE ====== {%- endcomment -%}
            {%- when 'trust_feature' -%}
              {%- if prev_type != 'trust_feature' -%}<div class="maisonpdp-trust-features">{%- endif -%}
              <div
                class="maisonpdp-trust-feature"
                style="{% if block.settings.bg_color != blank and block.settings.bg_color != 'rgba(0,0,0,0)' %}background:{{ block.settings.bg_color }};{% endif %}color:{{ block.settings.text_color | default: '#121212' }}"
                {{ block.shopify_attributes }}
              >
                <span class="maisonpdp-trust-feature__icon">
                  {%- if block.settings.icon -%}
                    {{ block.settings.icon | image_url: width: 40 | image_tag: alt: '' }}
                  {%- elsif block.settings.icon_type == 'truck' -%}
                    {%- render 'maisonpdp-icons', icon: 'truck', color: '#001C4F', size: 20 -%}
                  {%- elsif block.settings.icon_type == 'return' -%}
                    {%- render 'maisonpdp-icons', icon: 'return-arrow', color: '#001C4F', size: 20 -%}
                  {%- elsif block.settings.icon_type == 'heart' -%}
                    {%- render 'maisonpdp-icons', icon: 'heart', color: '#001C4F', size: 20 -%}
                  {%- else -%}
                    {%- render 'maisonpdp-icons', icon: 'checkmark', color: '#001C4F', size: 20 -%}
                  {%- endif -%}
                </span>
                <span class="maisonpdp-trust-feature__text">{{ block.settings.text }}</span>
                {%- if block.settings.link_text != blank and block.settings.link_url != blank -%}
                  <a
                    href="{{ block.settings.link_url }}"
                    class="maisonpdp-trust-feature__link"
                    style="color:{{ block.settings.link_color | default: '#001C4F' }}"
                  >
                    {{ block.settings.link_text }}
                  </a>
                {%- endif -%}
              </div>
              {%- if next_type != 'trust_feature' -%}</div>{%- endif -%}

              {%- comment -%} ====== DONATION BANNER ====== {%- endcomment -%}
            {%- when 'donation_banner' -%}
              <div
                class="maisonpdp-donation"
                style="background:{{ block.settings.bg_color | default: '#E4E7EC' }}"
                {{ block.shopify_attributes }}
              >
                <span class="maisonpdp-donation__icon">
                  {%- if block.settings.icon -%}
                    {{ block.settings.icon | image_url: width: 48 | image_tag: alt: '' }}
                  {%- else -%}
                    {%- render 'maisonpdp-icons', icon: 'heart', color: '#121212', size: 20 -%}
                  {%- endif -%}
                </span>
                <span>
                  {{ block.settings.text_before | replace: '[br]', '<br class="maisonpdp-donation__break">' }}
                  {%- if block.settings.link_text != blank and block.settings.link_url != blank -%}
                    <a href="{{ block.settings.link_url }}">{{ block.settings.link_text }}</a>
                  {%- endif -%}
                </span>
              </div>

              {%- comment -%} ====== VIDEO ====== {%- endcomment -%}
            {%- when 'video' -%}
              <div class="maisonpdp-video" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h3 class="maisonpdp-video__title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.video != blank -%}
                  <div
                    class="maisonpdp-video__player"
                    x-data="{ started: false }"
                    @click="if (!started) { const v = $el.querySelector('video'); v.controls = true; v.play(); started = true; $el.classList.add('is-playing'); }"
                  >
                    {{
                      block.settings.video
                      | video_tag:
                        image_size: '800x',
                        autoplay: false,
                        loop: false,
                        controls: false,
                        muted: false,
                        preload: 'none'
                    }}
                    <span class="maisonpdp-video__play-icon">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M7 6L17 12L7 18V6Z" fill="white"/>
                      </svg>
                    </span>
                  </div>
                {%- endif -%}
              </div>

              {%- comment -%} ====== ACCORDION ====== {%- endcomment -%}
            {%- when 'accordion' -%}
              {%- if prev_type != 'accordion' -%}<div class="maisonpdp-accordions">{%- endif -%}
              <div class="maisonpdp-accordion" {{ block.shopify_attributes }}>
                <button
                  class="maisonpdp-accordion__trigger"
                  @click="toggleAccordion('{{ block.id }}')"
                  type="button"
                  :aria-expanded="openAccordion === '{{ block.id }}'"
                >
                  <span>{{ block.settings.title }}</span>
                  <span
                    class="maisonpdp-accordion__trigger-icon"
                    :style="openAccordion === '{{ block.id }}' ? 'transform: rotate(45deg)' : ''"
                  >
                    {%- render 'maisonpdp-icons', icon: 'plus', color: '#121212', size: 12 -%}
                  </span>
                </button>
                <div
                  class="maisonpdp-accordion__content"
                  x-show="openAccordion === '{{ block.id }}'"
                  x-transition:enter="maisonpdp-acc-transition"
                  x-transition:enter-start="maisonpdp-acc-hidden"
                  x-transition:enter-end="maisonpdp-acc-visible"
                  x-transition:leave="maisonpdp-acc-transition"
                  x-transition:leave-start="maisonpdp-acc-visible"
                  x-transition:leave-end="maisonpdp-acc-hidden"
                  x-cloak
                >
                  <div class="maisonpdp-accordion__content-inner">
                    {{ block.settings.content }}
                  </div>
                </div>
              </div>
              {%- if next_type != 'accordion' -%}</div>{%- endif -%}

              {%- comment -%} ====== CROSS-SELL PRODUCT ====== {%- endcomment -%}
            {%- when 'cross_sell_product' -%}
              {%- if prev_type != 'cross_sell_product' -%}
                <div class="maisonpdp-cross-sell">
                  {%- if section.settings.cross_sell_title != blank -%}
                    <div class="maisonpdp-cross-sell__header">
                      <h3 class="maisonpdp-cross-sell__title">{{ section.settings.cross_sell_title }}</h3>
                      <div class="maisonpdp-cross-sell__nav">
                        <button
                          class="maisonpdp-cross-sell__nav-btn"
                          @click="scrollCrossSell('left')"
                          type="button"
                          aria-label="Previous"
                        >
                          {%- render 'maisonpdp-icons', icon: 'arrow-left', color: '#001C4F', size: 16 -%}
                        </button>
                        <button
                          class="maisonpdp-cross-sell__nav-btn"
                          @click="scrollCrossSell('right')"
                          type="button"
                          aria-label="Next"
                        >
                          {%- render 'maisonpdp-icons', icon: 'arrow-right', color: '#001C4F', size: 16 -%}
                        </button>
                      </div>
                    </div>
                  {%- endif -%}
                  <div class="maisonpdp-cross-sell__track" x-ref="crossSellTrack">
              {%- endif -%}

              {%- if block.settings.product != blank -%}
                {%- assign cs_product = block.settings.product -%}
                <div class="maisonpdp-cross-sell__card" {{ block.shopify_attributes }}>
                  {%- if cs_product.featured_image -%}
                    {{
                      cs_product.featured_image
                      | image_url: width: 128
                      | image_tag: class: 'maisonpdp-cross-sell__card-img', alt: cs_product.title, loading: 'lazy'
                    }}
                  {%- endif -%}
                  <div class="maisonpdp-cross-sell__card-body">
                    <div class="maisonpdp-cross-sell__card-info">
                      <p class="maisonpdp-cross-sell__card-title">{{ cs_product.title }}</p>
                      <div class="maisonpdp-cross-sell__card-price">{{ cs_product.price | money }}</div>
                    </div>
                    <button
                      type="button"
                      class="maisonpdp-cross-sell__card-btn"
                      @click.stop="addCrossSell({{ cs_product.selected_or_first_available_variant.id }})"
                      :disabled="addingCrossSell === {{ cs_product.selected_or_first_available_variant.id }}"
                    >
                      <span x-show="addingCrossSell !== {{ cs_product.selected_or_first_available_variant.id }}"
                        >+ Toevoegen</span
                      >
                      <span
                        class="maisonpdp-cta__spinner maisonpdp-cta__spinner--small"
                        x-show="addingCrossSell === {{ cs_product.selected_or_first_available_variant.id }}"
                        x-cloak
                      ></span>
                    </button>
                  </div>
                </div>
              {%- endif -%}

              {%- if next_type != 'cross_sell_product' -%}
                </div>
                <div class="maisonpdp-cross-sell__dots" x-ref="crossSellDots"></div>
                </div>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      </form>
    </div>
  </div>
</section>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('maisonpdpHero', () => ({
      /* Gallery */
      activeImageIndex: 0,
      totalImages: {{ product.images.size | default: 0 }},

      /* Product */
      product: null,
      currentVariantId: {{ product.selected_or_first_available_variant.id | default: 'null' }},
      currentVariantAvailable: {{ product.selected_or_first_available_variant.available | default: 'true' }},

      /* Prices */
      oneTimePrice: {{ product.selected_or_first_available_variant.price | default: 0 }},
      currentPrice: {{ product.selected_or_first_available_variant.price | default: 0 }},
      compareAtPrice: {{ product.selected_or_first_available_variant.compare_at_price | default: 'null' }},
      subscriptionPrice: 0,

      /* Purchase options */
      purchaseType: 'one_time',
      selectedSellingPlan: null,
      sellingPlanGroups: [],
      currentSellingPlans: [],

      /* Accordion */
      openAccordion: null,

      /* Variant options */
      selectedOptions: {},
      productOptions: [],

      /* Adding state */
      adding: false,
      addingCrossSell: null,

      /* Cross-sell dots */
      crossSellDotIndex: 0,

      /* Shipping countdown */
      shippingCountdown: '',
      shippingDeliveryLabel: '',

      init() {
        const jsonEl = this.$el.closest('.maisonpdp-section').querySelector('[data-maisonpdp-product]');
        if (jsonEl) {
          this.product = JSON.parse(jsonEl.textContent);
          this.sellingPlanGroups = this.product.selling_plan_groups || [];
        }
        this.initVariantOptions();
        this.initSellingPlans();
        this.$nextTick(() => {
          this.initCrossSellDots();
          this.initShippingCountdown();
          this.dispatchAtcBarSync();
        });
      },

      /* Gallery methods */
      setActiveImage(index) {
        this.activeImageIndex = index;
        const scroll = this.$refs.galleryScroll;
        if (scroll) {
          const slide = scroll.children[index];
          if (slide) {
            scroll.scrollTo({ left: slide.offsetLeft, behavior: 'smooth' });
          }
        }
      },

      prevImage() {
        if (this.activeImageIndex > 0) {
          this.setActiveImage(this.activeImageIndex - 1);
        }
      },

      nextImage() {
        if (this.activeImageIndex < this.totalImages - 1) {
          this.setActiveImage(this.activeImageIndex + 1);
        }
      },

      onGalleryScroll() {
        const scroll = this.$refs.galleryScroll;
        if (!scroll || !scroll.children.length) return;
        const slideWidth = scroll.children[0].offsetWidth;
        if (slideWidth > 0) {
          this.activeImageIndex = Math.round(scroll.scrollLeft / slideWidth);
        }
      },

      /* Variant methods */
      initVariantOptions() {
        if (!this.product) return;
        this.productOptions = this.product.options || [];
        const current = this.product.variants.find(v => v.id === this.currentVariantId);
        if (current) {
          this.selectedOptions = {};
          if (current.option1 != null) this.selectedOptions[1] = current.option1;
          if (current.option2 != null) this.selectedOptions[2] = current.option2;
          if (current.option3 != null) this.selectedOptions[3] = current.option3;
        }
      },

      selectOptionValue(position, value) {
        this.selectedOptions[position] = value;
        const match = this.findMatchingVariant();
        if (match) {
          this.currentVariantId = match.id;
          this.currentVariantAvailable = match.available;
          this.oneTimePrice = match.price;
          this.compareAtPrice = match.compare_at_price;
          this.computeSubscriptionPrice();
          this.currentPrice = this.purchaseType === 'subscription'
            ? this.subscriptionPrice
            : this.oneTimePrice;
          this.updateVariantUrl();
          this.dispatchAtcBarSync();
          if (match.featured_image_position != null) {
            this.setActiveImage(match.featured_image_position - 1);
          }
        } else {
          this.currentVariantAvailable = false;
          this.dispatchAtcBarSync();
        }
      },

      findMatchingVariant() {
        if (!this.product) return null;
        return this.product.variants.find(v => {
          for (let i = 1; i <= 3; i++) {
            if (this.selectedOptions[i] && v['option' + i] !== this.selectedOptions[i]) {
              return false;
            }
          }
          return true;
        });
      },

      updateVariantUrl() {
        if (this.currentVariantId) {
          const url = new URL(window.location);
          url.searchParams.set('variant', this.currentVariantId);
          history.replaceState({}, '', url);
        }
      },

      /* Selling plan methods */
      initSellingPlans() {
        if (this.sellingPlanGroups.length > 0) {
          const group = this.sellingPlanGroups[0];
          this.currentSellingPlans = group.selling_plans;
          if (this.currentSellingPlans.length > 0) {
            this.selectedSellingPlan = this.currentSellingPlans[0].id;
            this.computeSubscriptionPrice();
            /* Default to subscription if selling plans exist */
            this.purchaseType = 'subscription';
            this.currentPrice = this.subscriptionPrice;
          }
        }
      },

      computeSubscriptionPrice() {
        if (!this.selectedSellingPlan) {
          this.subscriptionPrice = this.oneTimePrice;
          return;
        }
        const plan = this.currentSellingPlans.find(p => p.id == this.selectedSellingPlan);
        if (plan && plan.price_adjustments && plan.price_adjustments.length > 0) {
          const adj = plan.price_adjustments[0];
          if (adj.value_type === 'percentage') {
            this.subscriptionPrice = Math.round(this.oneTimePrice * (100 - adj.value) / 100);
          } else if (adj.value_type === 'fixed_amount') {
            this.subscriptionPrice = this.oneTimePrice - adj.value;
          } else if (adj.value_type === 'price') {
            this.subscriptionPrice = adj.value;
          } else {
            this.subscriptionPrice = this.oneTimePrice;
          }
        } else {
          this.subscriptionPrice = this.oneTimePrice;
        }
      },

      selectPurchaseType(type) {
        this.purchaseType = type;
        if (type === 'one_time') {
          this.selectedSellingPlan = null;
          this.currentPrice = this.oneTimePrice;
        } else {
          if (this.currentSellingPlans.length > 0 && !this.selectedSellingPlan) {
            this.selectedSellingPlan = this.currentSellingPlans[0].id;
          }
          this.computeSubscriptionPrice();
          this.currentPrice = this.subscriptionPrice;
        }
        this.dispatchAtcBarSync();
      },

      onSellingPlanChange() {
        this.computeSubscriptionPrice();
        this.currentPrice = this.subscriptionPrice;
        this.dispatchAtcBarSync();
      },

      /* Sync state to ATC bar */
      dispatchAtcBarSync() {
        document.dispatchEvent(new CustomEvent('maison:variant-changed', {
          detail: {
            variantId: this.currentVariantId,
            available: this.currentVariantAvailable,
            price: this.currentPrice,
            compareAtPrice: this.compareAtPrice,
            sellingPlan: this.selectedSellingPlan,
            purchaseType: this.purchaseType
          }
        }));
      },

      /* Price formatting */
      formatMoney(cents) {
        if (cents == null) return '';
        return (cents / 100).toLocaleString('nl-NL', {
          style: 'currency',
          currency: 'EUR'
        });
      },

      /* Cart */
      async addToCart() {
        if (this.adding) return;
        this.adding = true;

        const body = {
          id: this.currentVariantId,
          quantity: 1
        };
        if (this.purchaseType === 'subscription' && this.selectedSellingPlan) {
          body.selling_plan = this.selectedSellingPlan;
        }

        try {
          const res = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
          });

          if (res.ok) {
            document.dispatchEvent(new CustomEvent('cart:updated'));
            /* Also try theme-specific events */
            document.dispatchEvent(new CustomEvent('ajaxProduct:added'));
          }
        } catch (e) {
          console.error('Add to cart failed:', e);
        } finally {
          this.adding = false;
        }
      },

      async addCrossSell(variantId) {
        if (this.addingCrossSell) return;
        this.addingCrossSell = variantId;

        try {
          const res = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: variantId, quantity: 1 })
          });
          if (res.ok) {
            document.dispatchEvent(new CustomEvent('cart:updated'));
            document.dispatchEvent(new CustomEvent('ajaxProduct:added'));
          }
        } catch (e) {
          console.error('Cross-sell add failed:', e);
        } finally {
          this.addingCrossSell = null;
        }
      },

      /* Accordion */
      toggleAccordion(id) {
        this.openAccordion = this.openAccordion === id ? null : id;
      },

      /* Shipping countdown */
      initShippingCountdown() {
        const ctaEl = this.$el.querySelector('[data-shipping-cutoff]');
        if (!ctaEl) return;
        const cutoff = parseFloat(ctaEl.dataset.shippingCutoff);
        if (!cutoff) return;
        this._shippingCutoffHour = Math.floor(cutoff);
        this._shippingCutoffMin = Math.round((cutoff % 1) * 100);
        this.updateShippingCountdown();
        this._shippingInterval = setInterval(() => this.updateShippingCountdown(), 60000);
      },

      updateShippingCountdown() {
        const now = new Date();
        const cutoff = new Date(now);
        cutoff.setHours(this._shippingCutoffHour, this._shippingCutoffMin, 0, 0);

        let deliveryOffset = 1; /* days from now */
        if (now >= cutoff) {
          /* past today's cutoff — count to tomorrow's cutoff */
          cutoff.setDate(cutoff.getDate() + 1);
          deliveryOffset = 2;
        }

        const diff = cutoff - now;
        const hours = Math.floor(diff / 3600000);
        const minutes = Math.floor((diff % 3600000) / 60000);
        this.shippingCountdown = hours + 'U, ' + minutes + 'M';

        const delivery = new Date(now);
        delivery.setDate(delivery.getDate() + deliveryOffset);
        const day = delivery.getDate();
        const months = ['jan', 'feb', 'mrt', 'apr', 'mei', 'jun', 'jul', 'aug', 'sep', 'okt', 'nov', 'dec'];
        this.shippingDeliveryLabel = 'MORGEN BEZORGD (' + day + ' ' + months[delivery.getMonth()] + ')';
        if (deliveryOffset > 1) {
          this.shippingDeliveryLabel = 'OVERMORGEN BEZORGD (' + day + ' ' + months[delivery.getMonth()] + ')';
        }
      },

      /* Cross-sell carousel */
      initCrossSellDots() {
        const track = this.$refs.crossSellTrack;
        const dotsEl = this.$refs.crossSellDots;
        if (!track || !dotsEl) return;
        const cards = track.querySelectorAll('.maisonpdp-cross-sell__card');
        if (cards.length <= 1) return;
        dotsEl.innerHTML = '';
        cards.forEach((_, i) => {
          const dot = document.createElement('span');
          dot.className = 'maisonpdp-cross-sell__dot' + (i === 0 ? ' maisonpdp-cross-sell__dot--active' : '');
          dotsEl.appendChild(dot);
        });
        track.addEventListener('scroll', () => this.updateCrossSellDots(), { passive: true });
      },

      updateCrossSellDots() {
        const track = this.$refs.crossSellTrack;
        const dotsEl = this.$refs.crossSellDots;
        if (!track || !dotsEl) return;
        const cards = track.querySelectorAll('.maisonpdp-cross-sell__card');
        if (!cards.length) return;
        const cardWidth = cards[0].offsetWidth;
        const index = Math.round(track.scrollLeft / cardWidth);
        if (index === this.crossSellDotIndex) return;
        this.crossSellDotIndex = index;
        dotsEl.querySelectorAll('.maisonpdp-cross-sell__dot').forEach((dot, i) => {
          dot.classList.toggle('maisonpdp-cross-sell__dot--active', i === index);
        });
      },

      scrollCrossSell(direction) {
        const track = this.$refs.crossSellTrack;
        if (!track) return;
        const card = track.querySelector('.maisonpdp-cross-sell__card');
        const scrollAmount = card ? card.offsetWidth : 220;
        track.scrollBy({
          left: direction === 'right' ? scrollAmount : -scrollAmount,
          behavior: 'smooth'
        });
      }
    }));
  });

  /* Load Alpine.js if not already present */
  if (!window.Alpine) {
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js';
    script.defer = true;
    document.head.appendChild(script);
  }
</script>

