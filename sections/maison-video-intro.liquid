{%- comment -%}
  Section: Maison Video Intro
  Full-width banner-style video. Two playback modes:
    - autoplay_muted: autoplays muted in loop, no controls (banner style)
    - click_to_play: shows poster + centered play button; on click starts with sound + controls
{%- endcomment -%}

{%- assign section_id = 'maison-video-intro-' | append: section.id -%}
{%- assign mode = section.settings.playback_mode -%}

<section
  id="{{ section_id }}"
  class="maison-video-intro maison-video-intro--{{ mode }}"
>
  {%- if section.settings.video != blank -%}
    <div class="maison-video-intro__wrap">
      {%- if mode == 'autoplay_muted' -%}
        {{
          section.settings.video
          | video_tag:
            autoplay: true,
            muted: true,
            loop: true,
            playsinline: true,
            controls: false,
            preload: 'auto',
            class: 'maison-video-intro__video',
            poster: section.settings.poster_image
        }}
      {%- else -%}
        {{
          section.settings.video
          | video_tag:
            muted: false,
            loop: false,
            playsinline: true,
            controls: false,
            preload: 'metadata',
            class: 'maison-video-intro__video',
            poster: section.settings.poster_image
        }}

        <button
          type="button"
          class="maison-video-intro__play-btn"
          aria-label="Play video"
          data-play-button
        >
          <svg width="96" height="96" viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="48" cy="48" r="48" fill="rgba(0, 16, 44, 0.75)"/>
            <path d="M38 32L66 48L38 64V32Z" fill="#FFFFFF"/>
          </svg>
        </button>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<style>
  #{{ section_id }}.maison-video-intro {
    width: 100%;
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    background: {{ section.settings.section_bg_color }};
  }

  #{{ section_id }} .maison-video-intro__wrap {
    position: relative;
    width: 100%;
    aspect-ratio: {{ section.settings.aspect_ratio_desktop }};
    overflow: hidden;
    background: #000;
  }

  #{{ section_id }} .maison-video-intro__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #{{ section_id }} .maison-video-intro__play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 96px;
    height: 96px;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    z-index: 2;
    transition: filter 0.25s ease, transform 0.25s ease;
  }

  #{{ section_id }} .maison-video-intro__play-btn:hover {
    filter: brightness(1.15);
    transform: translate(-50%, -50%) scale(1.05);
  }

  #{{ section_id }} .maison-video-intro__play-btn[hidden] {
    display: none !important;
  }

  @media (max-width: 768px) {
    #{{ section_id }}.maison-video-intro {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #{{ section_id }} .maison-video-intro__wrap {
      aspect-ratio: {{ section.settings.aspect_ratio_mobile }};
    }

    #{{ section_id }} .maison-video-intro__play-btn {
      width: 64px;
      height: 64px;
    }
  }
</style>

{%- if mode == 'click_to_play' -%}
  <script>
    (function () {
      var section = document.getElementById('{{ section_id }}');
      if (!section) return;
      var video = section.querySelector('.maison-video-intro__video');
      var btn = section.querySelector('[data-play-button]');
      if (!video || !btn) return;

      btn.addEventListener('click', function () {
        video.muted = false;
        video.controls = true;
        video.play();
        btn.hidden = true;
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Maison Video Intro",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "playback_mode",
      "label": "Playback mode",
      "options": [
        { "value": "autoplay_muted", "label": "Autoplay (muted, loop, banner)" },
        { "value": "click_to_play", "label": "Click-to-play (play button overlay)" }
      ],
      "default": "autoplay_muted"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video (Shopify file)"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster image (first frame / preview)"
    },
    {
      "type": "header",
      "content": "Aspect ratio"
    },
    {
      "type": "select",
      "id": "aspect_ratio_desktop",
      "label": "Aspect ratio (Desktop)",
      "options": [
        { "value": "21 / 9", "label": "21:9 (ultra-wide banner)" },
        { "value": "16 / 9", "label": "16:9 (standard)" },
        { "value": "4 / 3", "label": "4:3" },
        { "value": "1 / 1", "label": "1:1 (square)" }
      ],
      "default": "16 / 9"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "Aspect ratio (Mobile)",
      "options": [
        { "value": "16 / 9", "label": "16:9" },
        { "value": "4 / 3", "label": "4:3" },
        { "value": "1 / 1", "label": "1:1 (square)" },
        { "value": "4 / 5", "label": "4:5 (portrait)" },
        { "value": "9 / 16", "label": "9:16 (vertical)" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Maison Video Intro"
    }
  ]
}
{% endschema %}
