{%- comment -%} Section: Maison Quote {%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .maison_commerce_maison_quote {
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-right: {{ section.settings.padding_right_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --padding-left: {{ section.settings.padding_left_desktop }}px;
    --quote-font-size: {{ section.settings.quote_font_size_desktop }}px;
    --container-padding-y: 80px;
    --container-padding-x: 40px;
    --quote-mark-size: 64px;
    --quote-mark-offset: 31px;
    --quote-max-width: 720px;
  }
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_maison_quote {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-right: {{ section.settings.padding_right_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --padding-left: {{ section.settings.padding_left_mobile }}px;
      --quote-font-size: {{ section.settings.quote_font_size_mobile }}px;
      --container-padding-y: 48px;
      --container-padding-x: 24px;
      --quote-mark-size: 40px;
      --quote-mark-offset: 20px;
      --quote-max-width: 100%;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Section Wrapper ====== */
  .maison_commerce_maison_quote {
    padding: var(--padding-top) var(--padding-right) var(--padding-bottom) var(--padding-left);
    background: #FFF;
  }

  /* ====== Container ====== */
  .maison_commerce_maison_quote__container {
    position: relative;
    max-width: 1360px;
    margin: 0 auto;
    background-color: {{ section.settings.container_bg_color | default: '#f5f4f3' }};
    padding: var(--container-padding-y) var(--container-padding-x);
    display: flex;
    justify-content: center;
    overflow: hidden;
  }

  /* ====== Quote Text ====== */
  .maison_commerce_maison_quote__text {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: var(--quote-font-size);
    line-height: 1.5;
    color: {{ section.settings.quote_color | default: '#121212' }};
    text-align: center;
    max-width: var(--quote-max-width);
    margin: 0;
  }

  .maison_commerce_maison_quote__text p {
    margin: 0;
  }

  /* ====== Quote Marks ====== */
  .maison_commerce_maison_quote__mark {
    position: absolute;
    width: var(--quote-mark-size);
    height: var(--quote-mark-size);
    opacity: 0.1;
    color: {{ section.settings.quote_color | default: '#121212' }};
  }

  .maison_commerce_maison_quote__mark svg {
    width: 100%;
    height: 100%;
  }

  .maison_commerce_maison_quote__mark--open {
    top: var(--quote-mark-offset);
    left: var(--quote-mark-offset);
    transform: rotate(180deg);
  }

  .maison_commerce_maison_quote__mark--close {
    bottom: var(--quote-mark-offset);
    right: var(--quote-mark-offset);
  }
</style>

<section class="maison_commerce_maison_quote">
  <div class="maison_commerce_maison_quote__container">

    {%- comment -%} Opening Quote Mark {%- endcomment -%}
    <span class="maison_commerce_maison_quote__mark maison_commerce_maison_quote__mark--open" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
        <path d="M13.33 29.33V17.33h12v12c0 5.89-4.78 10.67-10.66 10.67v-5.34c2.94 0 5.33-2.38 5.33-5.33H13.33z" fill="currentColor"/>
        <path d="M34.67 29.33V17.33h12v12c0 5.89-4.78 10.67-10.67 10.67v-5.34c2.95 0 5.33-2.38 5.33-5.33H34.67z" fill="currentColor"/>
      </svg>
    </span>

    {%- comment -%} Quote Text {%- endcomment -%}
    {%- if section.settings.quote != blank -%}
      <div class="maison_commerce_maison_quote__text">
        {{ section.settings.quote }}
      </div>
    {%- endif -%}

    {%- comment -%} Closing Quote Mark {%- endcomment -%}
    <span class="maison_commerce_maison_quote__mark maison_commerce_maison_quote__mark--close" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
        <path d="M13.33 29.33V17.33h12v12c0 5.89-4.78 10.67-10.66 10.67v-5.34c2.94 0 5.33-2.38 5.33-5.33H13.33z" fill="currentColor"/>
        <path d="M34.67 29.33V17.33h12v12c0 5.89-4.78 10.67-10.67 10.67v-5.34c2.95 0 5.33-2.38 5.33-5.33H34.67z" fill="currentColor"/>
      </svg>
    </span>

  </div>
</section>

