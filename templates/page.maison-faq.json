    "maison_faq_list_kCBCNb": {
      "type": "maison-faq-list",
      "blocks": {
        "faq_item_EGLHwp": {
          "type": "faq_item",
          "disabled": true,
          "settings": {
            "question": "Hoe werkt Subscribe & Save?",
            "answer": "<p>Kies je favoriete geur en hoe vaak je wilt ontvangen — elke 4, 6 of 8 weken. Wij bezorgen automatisch, jij bespaart 10% op elke levering.</p>"
          }
        },
        "faq_item_CKdDdK": {
          "type": "faq_item",
          "settings": {
            "question": "Kan ik mijn abonnement pauzeren?",
            "answer": "<p>Ja, op elk moment. Log in bij het <a href=\"https://account.thecarparfum.com/nl/self-service/login\" target=\"_blank\" title=\"https://account.thecarparfum.com/nl/self-service/login\">self service center</a> of stuur ons een e-mail. Geen verplichtingen, geen kleine lettertjes.</p>"
          }
        },
        "faq_item_8Hcq6h": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe annuleer ik mijn abonnement?",
            "answer": "<p>Stuur ons een e-mail met je naam en e-mailadres. Of log in bij het <a href=\"https://account.thecarparfum.com/nl/self-service/login\" target=\"_blank\" title=\"https://account.thecarparfum.com/nl/self-service/login\">self service center</a>. We annuleren je abonnement direct, zonder vragen.</p>"
          }
        },
        "faq_item_AfxHtT": {
          "type": "faq_item",
          "settings": {
            "question": "Kan ik van geur wisselen?",
            "answer": "<p>Ja zeker. Stuur ons een e-mail welke geur je voortaan wil en we passen je abonnement aan. Of log in bij het <a href=\"https://account.thecarparfum.com/nl/self-service/login\" target=\"_blank\" title=\"https://account.thecarparfum.com/nl/self-service/login\">self service center</a> en wissel zelf makkelijk van geur.</p>"
          }
        },
        "faq_item_hHg93d": {
          "type": "faq_item",
          "settings": {
            "question": "Wanneer wordt mijn volgende levering verstuurd?",
            "answer": "<p>Log in bij het <a href=\"https://account.thecarparfum.com/nl/self-service/login\" target=\"_blank\" title=\"https://account.thecarparfum.com/nl/self-service/login\">self service center</a> en je ziet direct wanneer de volgende levering gepland staat. Wij verzenden de navullingen als brievenbuspakket, je hoeft hiervoor dus niet thuis te blijven.</p>"
          }
        },
        "faq_item_mM4TWB": {
          "type": "faq_item",
          "settings": {
            "question": "Krijg ik korting met een abonnement?",
            "answer": "<p>Ja. Een abonnement is de voordeligste manier om altijd een frisse auto te hebben, zonder gedoe.<br/><br/></p><p>Je ontvangt elke 3 maanden automatisch je navullingen en betaalt geen verzendkosten. Zo ben je altijd voorzien, voor een betere prijs.</p>"
          }
        }
      },
