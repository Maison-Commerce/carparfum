{%- assign heading_line_count = 0 -%}
{%- if section.settings.heading_line1 != blank -%}{%- assign heading_line_count = heading_line_count | plus: 1 -%}{%- endif -%}
{%- if section.settings.heading_line2 != blank -%}{%- assign heading_line_count = heading_line_count | plus: 1 -%}{%- endif -%}
{%- if section.settings.heading_line3 != blank -%}{%- assign heading_line_count = heading_line_count | plus: 1 -%}{%- endif -%}

<section class="maison_commerce_maison_banner">
  {%- if section.settings.background_image != blank -%}
    <div class="maison_commerce_maison_banner__bg-image">
      {{
        section.settings.background_image
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          class: 'maison_commerce_maison_banner__bg-img',
          sizes: '100vw',
          widths: '375, 750, 1080, 1440, 1920'
      }}
    </div>
  {%- endif -%}

  <div class="maison_commerce_maison_banner__content-wrapper">
    <div class="maison_commerce_maison_banner__container">
      <div class="maison_commerce_maison_banner__content">
        <h2 class="maison_commerce_maison_banner__heading{% if section.settings.heading_scroll_enabled %} maison_commerce_maison_banner__heading--animated{% endif %}">
          <span class="maison_commerce_maison_banner__heading-scroll">
            {%- if section.settings.heading_line1 != blank -%}
              <span
                class="ff-heading maison_commerce_maison_banner__heading-line maison_commerce_maison_banner__heading-line--1"
                style="color: {{ section.settings.heading_line2_color }};"
              >
                {{- section.settings.heading_line1 -}}
              </span>
            {%- endif -%}
            {%- if section.settings.heading_line2 != blank -%}
              <span
                class="ff-heading maison_commerce_maison_banner__heading-line maison_commerce_maison_banner__heading-line--2"
                style="color: {{ section.settings.heading_line2_color }};"
              >
                {{- section.settings.heading_line2 -}}
              </span>
            {%- endif -%}
            {%- if section.settings.heading_line3 != blank -%}
              <span
                class="ff-heading maison_commerce_maison_banner__heading-line maison_commerce_maison_banner__heading-line--3"
                style="color: {{ section.settings.heading_line2_color }};"
              >
                {{- section.settings.heading_line3 -}}
              </span>
            {%- endif -%}
            {%- if section.settings.heading_scroll_enabled -%}
              {%- if section.settings.heading_line1 != blank -%}
                <span
                  class="ff-heading maison_commerce_maison_banner__heading-line maison_commerce_maison_banner__heading-line--1"
                  aria-hidden="true"
                  style="color: {{ section.settings.heading_line2_color }};"
                >
                  {{- section.settings.heading_line1 -}}
                </span>
              {%- endif -%}
              {%- if section.settings.heading_line2 != blank -%}
                <span
                  class="ff-heading maison_commerce_maison_banner__heading-line maison_commerce_maison_banner__heading-line--2"
                  aria-hidden="true"
                  style="color: {{ section.settings.heading_line2_color }};"
                >
                  {{- section.settings.heading_line2 -}}
                </span>
              {%- endif -%}
              {%- if section.settings.heading_line3 != blank -%}
                <span
                  class="ff-heading maison_commerce_maison_banner__heading-line maison_commerce_maison_banner__heading-line--3"
                  aria-hidden="true"
                  style="color: {{ section.settings.heading_line2_color }};"
                >
                  {{- section.settings.heading_line3 -}}
                </span>
              {%- endif -%}
            {%- endif -%}
          </span>
        </h2>

        {%- if section.settings.subtitle != blank -%}
          <div class="maison_commerce_maison_banner__subtitle">
            {{ section.settings.subtitle }}
          </div>
        {%- endif -%}

        {%- if section.settings.trustpilot_rating != blank -%}
          {%- assign rating_num = section.settings.trustpilot_rating | plus: 0.0 -%}
          {%- assign full_stars = rating_num | floor -%}
          {%- assign remainder = rating_num | minus: full_stars -%}
          {%- assign half_star_index = -1 -%}
          {%- if remainder >= 0.3 -%}
            {%- assign half_star_index = full_stars | plus: 1 -%}
          {%- endif -%}
          <div class="maison_commerce_maison_banner__trustpilot">
            <div class="maison_commerce_maison_banner__trustpilot-stars">
              {%- for i in (1..5) -%}
                {%- if i <= full_stars -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 16 16" fill="none">
                    <rect width="16" height="16" fill="#00B67A"/>
                    <path d="M8 11.15L10.61 10.45L11.7 14L8 11.15ZM14 6.57H9.41L8 2L6.59 6.57H2L5.71 9.4L4.3 13.96L8.02 11.13L10.3 9.4L14 6.57Z" fill="white"/>
                  </svg>
                {%- elsif i == half_star_index -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 16 16" fill="none">
                    <rect width="16" height="16" fill="#DCDCE6"/>
                    <rect width="8" height="16" fill="#00B67A"/>
                    <path d="M8 11.15L10.61 10.45L11.7 14L8 11.15ZM14 6.57H9.41L8 2L6.59 6.57H2L5.71 9.4L4.3 13.96L8.02 11.13L10.3 9.4L14 6.57Z" fill="white"/>
                  </svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 16 16" fill="none">
                    <rect width="16" height="16" fill="#DCDCE6"/>
                    <path d="M8 11.15L10.61 10.45L11.7 14L8 11.15ZM14 6.57H9.41L8 2L6.59 6.57H2L5.71 9.4L4.3 13.96L8.02 11.13L10.3 9.4L14 6.57Z" fill="white"/>
                  </svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
            <span class="maison_commerce_maison_banner__trustpilot-text">
              {{ rating_num }}/5
              {%- if section.settings.trustpilot_review_count != blank -%}
                ({%- if section.settings.trustpilot_url != blank -%}<a href="{{ section.settings.trustpilot_url }}" target="_blank" rel="noopener" class="maison_commerce_maison_banner__trustpilot-link">{{ section.settings.trustpilot_review_count }} reviews</a>{%- else -%}{{ section.settings.trustpilot_review_count }} reviews{%- endif -%})
              {%- endif -%}
            </span>
            <div class="maison_commerce_maison_banner__trustpilot-brand">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 14 14" fill="none">
                <path d="M7 0L8.75 4.84L14 5.28L10.01 8.72L11.18 14L7 11.34L2.82 14L3.99 8.72L0 5.28L5.25 4.84L7 0Z" fill="#00B67A"/>
              </svg>
              <span>Trustpilot</span>
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.button_text != blank -%}
        <a
          {%- if section.settings.button_url != blank %} href="{{ section.settings.button_url }}"{% endif %}
          class="maison_commerce_maison_banner__button"
        >
          <span class="maison_commerce_maison_banner__button-text">
            {{- section.settings.button_text -}}
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" class="maison_commerce_maison_banner__button-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M1.125 7.99695H14.25" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7.6875 14.5625L14.25 8L7.6875 1.4375" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.product_image != blank -%}
    <div class="maison_commerce_maison_banner__product-wrapper">
      <div class="maison_commerce_maison_banner__product-overlay"></div>
      {{
        section.settings.product_image
        | image_url: width: 750
        | image_tag:
          loading: 'eager',
          class: 'maison_commerce_maison_banner__product-img',
          sizes: '100vw',
          widths: '375, 750'
      }}
    </div>
  {%- endif -%}
</section>

<style>
  /* ========================================
     Section: Maison Banner
     Prefix: .maison_commerce_maison_banner
     ======================================== */

  .maison_commerce_maison_banner {
    position: relative;
    background-color: {{ section.settings.section_bg_color }};
    overflow: hidden;
  }

  /* Background Image (Desktop) */
  .maison_commerce_maison_banner__bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .maison_commerce_maison_banner__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Content Wrapper */
  .maison_commerce_maison_banner__content-wrapper {
    position: relative;
    z-index: 1;
    min-height: {{ section.settings.desktop_height }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_left_desktop }}px;
    padding-right: {{ section.settings.padding_right_desktop }}px;
  }

  /* Container */
  .maison_commerce_maison_banner__container {
    max-width: 1360px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    min-height: inherit;
  }

  /* Content Block */
  .maison_commerce_maison_banner__content {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Heading */
  .maison_commerce_maison_banner__heading {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
  }

  .maison_commerce_maison_banner__heading-line {
    display: block;
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    line-height: 1.2;
  }

  .maison_commerce_maison_banner__heading-line--1,
  .maison_commerce_maison_banner__heading-line--3 {
    opacity: 0.3;
  }

  /* Heading Scroll Animation */
  .maison_commerce_maison_banner__heading-scroll {
    display: contents;
  }

  .maison_commerce_maison_banner__heading--animated {
    overflow: hidden;
    height: calc({{ section.settings.heading_font_size_desktop }}px * 1.2 * {{ heading_line_count }});
  }

  .maison_commerce_maison_banner__heading--animated .maison_commerce_maison_banner__heading-scroll {
    display: flex;
    flex-direction: column;
    will-change: transform;
    transition: transform 350ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  @media (prefers-reduced-motion: reduce) {
    .maison_commerce_maison_banner__heading--animated .maison_commerce_maison_banner__heading-scroll {
      transition: none;
    }
    .maison_commerce_maison_banner__heading--animated {
      height: auto;
      overflow: visible;
    }
  }

  /* Subtitle */
  .maison_commerce_maison_banner__subtitle {
    font-size: {{ section.settings.body_font_size_desktop }}px;
    color: {{ section.settings.subtitle_color }};
    line-height: 1.5;
    font-weight: 400;
    max-width: 480px;
    opacity: 0.8;
  }

  .maison_commerce_maison_banner__subtitle p {
    margin: 0;
  }

  /* Trustpilot Badge */
  .maison_commerce_maison_banner__trustpilot {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    color: {{ section.settings.trustpilot_text_color }};
    font-size: 15px;
    line-height: 1.2;
    margin-top: 20px;
  }

  .maison_commerce_maison_banner__trustpilot-stars {
    display: inline-flex;
    gap: 2px;
    flex-shrink: 0;
  }

  .maison_commerce_maison_banner__trustpilot-text {
    font-weight: 500;
  }

  .maison_commerce_maison_banner__trustpilot-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .maison_commerce_maison_banner__trustpilot-link:hover {
    opacity: 0.85;
  }

  .maison_commerce_maison_banner__trustpilot-brand {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 600;
  }

  /* Button */
  .maison_commerce_maison_banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    max-width: 400px;
    height: 56px;
    padding: 16px 20px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    transition: filter 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    cursor: pointer;
  }

  .maison_commerce_maison_banner__button:hover {
    filter: brightness(1.1);
    box-shadow: 0 6px 20px rgba(0, 16, 44, 0.3);
    transform: translateY(-1px);
  }

  .maison_commerce_maison_banner__button-text {
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.5;
  }

  .maison_commerce_maison_banner__button-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* Product Image (Mobile only by default) */
  .maison_commerce_maison_banner__product-wrapper {
    display: none;
    position: relative;
    height: {{ section.settings.product_image_height_mobile }}px;
    overflow: hidden;
  }

  .maison_commerce_maison_banner__product-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to bottom, {{ section.settings.section_bg_color }} 0%, transparent 50%);
    pointer-events: none;
  }

  .maison_commerce_maison_banner__product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ========================================
     Mobile Responsive (max-width: 768px)
     ======================================== */
  @media (max-width: 768px) {
    .maison_commerce_maison_banner__bg-image {
      display: none;
    }

    .maison_commerce_maison_banner__content-wrapper {
      min-height: auto;
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_left_mobile }}px;
      padding-right: {{ section.settings.padding_right_mobile }}px;
    }

    .maison_commerce_maison_banner__container {
      min-height: auto;
      gap: 48px;
    }

    .maison_commerce_maison_banner__content {
      max-width: 100%;
      align-items: center;
      text-align: center;
      gap: 12px;
    }

    .maison_commerce_maison_banner__heading-line {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }

    .maison_commerce_maison_banner__heading--animated {
      height: calc({{ section.settings.heading_font_size_mobile }}px * 1.2 * {{ heading_line_count }});
    }

    .maison_commerce_maison_banner__subtitle {
      font-size: {{ section.settings.body_font_size_mobile }}px;
      max-width: 100%;
    }

    .maison_commerce_maison_banner__button {
      width: 100%;
      height: 44px;
      padding: 12px 20px;
      max-width: 100%;
    }

    .maison_commerce_maison_banner__button-text {
      font-size: 14px;
    }

    .maison_commerce_maison_banner__trustpilot {
      font-size: 13px;
      gap: 8px;
      margin-top: 16px;
      justify-content: center;
    }

    .maison_commerce_maison_banner__trustpilot-stars svg {
      width: 16px;
      height: 16px;
    }

    .maison_commerce_maison_banner__product-wrapper {
      display: block;
    }
  }
</style>

<script>
  (function () {
    var heading = document.querySelector('.maison_commerce_maison_banner__heading--animated');
    if (!heading) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var scroll = heading.querySelector('.maison_commerce_maison_banner__heading-scroll');
    var lines = heading.querySelectorAll('.maison_commerce_maison_banner__heading-line');
    if (!scroll || !lines.length) return;

    var lineCount = {{ heading_line_count }};
    var step = 0;
    var totalSteps = lineCount;

    function updateOpacity() {
      for (var i = 0; i < lines.length; i++) {
        var lineIndex = i % lineCount;
        var visibleStart = step;
        var visibleEnd = step + lineCount - 1;
        var centerIndex = step + Math.floor(lineCount / 2);
        var distance = Math.abs(lineIndex + (i >= lineCount ? lineCount : 0) - centerIndex);
        if (i >= lineCount) {
          distance = Math.abs((lineIndex + lineCount) - centerIndex);
        }
        var t = Math.max(0, 1 - distance / (lineCount * 0.5));
        lines[i].style.opacity = 0.3 + t * 0.7;
      }
    }

    function scheduleNext() {
      setTimeout(function() {
        step++;
        if (step >= totalSteps) {
          /* Animate to the duplicate set (visually identical to start) */
          scroll.style.transform = 'translateY(-50%)';
          updateOpacity();
          /* After transition ends, snap back instantly */
          setTimeout(function() {
            scroll.style.transition = 'none';
            scroll.style.transform = 'translateY(0)';
            step = 0;
            updateOpacity();
            scroll.offsetHeight;
            scroll.style.transition = '';
            scheduleNext();
          }, 350);
          return;
        }
        scroll.style.transform = 'translateY(' + (-step * (50 / lineCount)) + '%)';
        updateOpacity();
        scheduleNext();
      }, 2000);
    }

    updateOpacity();
    scheduleNext();
  })();
</script>

