    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading Font Size (Mobile)",
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Featured Article"
    },
    {
      "type": "range",
      "id": "featured_title_font_size_desktop",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Featured Title Font Size (Desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "featured_title_font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Featured Title Font Size (Mobile)",
      "default": 18
    },
    {
      "type": "color",
      "id": "featured_title_color",
      "label": "Featured Title Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "featured_meta_color",
      "label": "Featured Meta Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "featured_gradient_color",
      "label": "Featured Gradient Color",
      "default": "#00102C"
    },
    {
      "type": "range",
      "id": "featured_height_mobile",
      "min": 160,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Featured Height (Mobile)",
      "default": 240
