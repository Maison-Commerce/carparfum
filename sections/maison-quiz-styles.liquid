{%- comment -%}
  Injects CSS overrides for the RevenueHunt quiz buttons to match
  the site's primary CTA styling (navy gradient + unified hover).
{%- endcomment -%}

<style>
  /* Navigation buttons (Next, Back, Start, Submit) */
  .navigation-bar__button,
  /* Answer/option buttons */
  .question_button,
  .question-button--right,
  .question-button--center {
    background: linear-gradient(77.92deg, #00102C 0%, #001C4F 83.475%) !important;
    color: #FFFFFF !important;
    border: none !important;
    font-weight: 600 !important;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    transition: filter 0.25s ease, transform 0.25s ease !important;
  }

  .navigation-bar__button:hover,
  .question_button:hover,
  .question-button--right:hover,
  .question-button--center:hover {
    filter: brightness(1.1) !important;
    transform: translateY(-1px) !important;
  }

  /* Ensure any svg/icon inside inherits white */
  .navigation-bar__button svg,
  .question_button svg,
  .question-button--right svg,
  .question-button--center svg {
    color: #FFFFFF;
    fill: currentColor;
  }
</style>

{% schema %}
{
  "name": "Quiz Styles",
  "settings": [],
  "presets": [
    {
      "name": "Quiz Styles"
    }
  ]
}
{% endschema %}
