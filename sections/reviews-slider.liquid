                            <p class="font-semibold lh-12">${review.consumer.displayName} </p>
                        </div>
                        
                        <div class="trustpilot-review__stars">  <span>${icon} ${review.stars}.0</span> ${timeAgo}</div>
                        
                        <div class="trustpilot-review__text text-sm">${review.text.length > 160 ? review.text.substring(0, 160) + '...' : review.text}</div>
                        
                    </a>
                `;
                //<div class="trustpilot-review__text">${review.text}</div>
                reviewsContainer.appendChild(slide);
            });
		

           
            // Initialize on load
            initSwiper();

            
        })
	});
</script>

