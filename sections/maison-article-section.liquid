{% comment %}
  Section: Maison Article Section
  Story/article section with two-column layout (content + image).
  Desktop: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-22891&m=dev
  Mobile: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-28640&m=dev
{% endcomment %}

<section
  class="maison_commerce_maison_article_section"
  style="background-color: {{ section.settings.section_bg_color }};"
>
  <div class="maison_commerce_maison_article_section__container">
    <!-- Content Column -->
    <div
      class="maison_commerce_maison_article_section__content"
      style="background: linear-gradient(180deg, {{ section.settings.content_bg_color }} 0%, {{ section.settings.content_bg_color }}00 100%);"
    >
      <div class="maison_commerce_maison_article_section__content-inner">
        <!-- Subtitle + Heading Group -->
        <div class="maison_commerce_maison_article_section__top-group">
          {% if section.settings.subtitle != blank %}
            <div class="maison_commerce_maison_article_section__subtitle-row">
              <span
                class="maison_commerce_maison_article_section__subtitle-dot"
                style="background-color: {{ section.settings.subtitle_color }};"
              ></span>
              <span
                class="maison_commerce_maison_article_section__subtitle-text"
                style="color: {{ section.settings.subtitle_color }};"
              >
                {{ section.settings.subtitle }}
              </span>
            </div>
          {% endif %}

          <div class="maison_commerce_maison_article_section__heading">
            {% if section.settings.heading_bold != blank %}
              <span
                class="maison_commerce_maison_article_section__heading-bold"
                style="color: {{ section.settings.heading_color }};"
              >
                {{ section.settings.heading_bold }}
              </span>
            {% endif %}
            {% if section.settings.heading_italic != blank %}
              <span
                class="maison_commerce_maison_article_section__heading-italic"
                style="color: {{ section.settings.subtitle_color }};"
              >
                {{ section.settings.heading_italic }}
              </span>
            {% endif %}
          </div>
        </div>

        <!-- Body + Quote + Signature Group -->
        <div class="maison_commerce_maison_article_section__body-group">
          {% if section.settings.body_text != blank %}
            <div
              class="maison_commerce_maison_article_section__body"
              style="color: {{ section.settings.body_color }};"
            >
              {{ section.settings.body_text }}
            </div>
          {% endif %}

          {% if section.settings.quote_text != blank %}
            <p
              class="maison_commerce_maison_article_section__quote"
              style="color: {{ section.settings.heading_color }};"
            >
              {{ section.settings.quote_text }}
            </p>
          {% endif %}

          {% if section.settings.signature_text != blank %}
            <div class="maison_commerce_maison_article_section__signature-row">
              <div class="maison_commerce_maison_article_section__divider"></div>
              <span
                class="maison_commerce_maison_article_section__signature"
                style="color: {{ section.settings.heading_color }};"
              >
                {{ section.settings.signature_text }}
              </span>
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Button -->
      {% if section.settings.button_link != blank and section.settings.button_text != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="maison_commerce_maison_article_section__button"
          style="
            color: {{ section.settings.button_text_color }};
            border-color: {{ section.settings.button_border_color }};
          "
        >
          <span class="maison_commerce_maison_article_section__button-label">
            {{ section.settings.button_text }}
          </span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1.125 7.99683H14.25" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7.6875 14.5625L14.25 8L7.6875 1.4375" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </a>
      {% endif %}
    </div>

    <!-- Image Column -->
    {% if section.settings.image != blank %}
      <div class="maison_commerce_maison_article_section__image-wrapper">
        <img
          src="{{ section.settings.image | image_url: width: 1400 }}"
          alt="{{ section.settings.image.alt | default: section.settings.subtitle }}"
          loading="lazy"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      </div>
    {% endif %}
  </div>
</section>

<style>
  .maison_commerce_maison_article_section {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  /* Container: two-column layout */
  .maison_commerce_maison_article_section__container {
    max-width: 1360px;
    margin: 0 auto;
    display: flex;
    gap: 20px;
    align-items: stretch;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__container {
      flex-direction: column;
    }
  }

  /* Content Column */
  .maison_commerce_maison_article_section__content {
    flex: 1 0 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 48px 40px;
    min-width: 0;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__content {
      padding: 32px 16px;
      gap: 32px;
      justify-content: flex-start;
    }
  }

  /* Content Inner: subtitle/heading + body groups */
  .maison_commerce_maison_article_section__content-inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
    max-width: 600px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__content-inner {
      gap: 32px;
      max-width: none;
    }
  }

  /* Top Group: subtitle + heading */
  .maison_commerce_maison_article_section__top-group {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__top-group {
      gap: 12px;
    }
  }

  /* Subtitle Row */
  .maison_commerce_maison_article_section__subtitle-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .maison_commerce_maison_article_section__subtitle-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .maison_commerce_maison_article_section__subtitle-text {
    font-size: 14px;
    line-height: 1.5;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  /* Heading */
  .maison_commerce_maison_article_section__heading {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 12px;
    line-height: 1.2;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__heading {
      gap: 8px;
      line-height: 1.4;
    }
  }

  .maison_commerce_maison_article_section__heading-bold {
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    font-weight: 800;
    line-height: inherit;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__heading-bold {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
  }

  .maison_commerce_maison_article_section__heading-italic {
    font-size: {{ section.settings.heading_font_size_desktop | plus: 2 }}px;
    font-style: italic;
    font-weight: 400;
    line-height: inherit;
    background: linear-gradient(81deg, #00102C 0%, currentColor 83%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__heading-italic {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
  }

  /* Body Group: paragraphs + quote + signature */
  .maison_commerce_maison_article_section__body-group {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Body Text (richtext with <p> tags) */
  .maison_commerce_maison_article_section__body {
    display: flex;
    flex-direction: column;
    gap: 20px;
    font-size: {{ section.settings.body_font_size_desktop }}px;
    line-height: 1.5;
    opacity: 0.75;
  }

  .maison_commerce_maison_article_section__body p {
    margin: 0;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__body {
      font-size: {{ section.settings.body_font_size_mobile }}px;
    }
  }

  /* Quote */
  .maison_commerce_maison_article_section__quote {
    font-size: {{ section.settings.body_font_size_desktop }}px;
    font-weight: 800;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__quote {
      font-size: {{ section.settings.body_font_size_mobile }}px;
    }
  }

  /* Signature Row */
  .maison_commerce_maison_article_section__signature-row {
    display: flex;
    align-items: center;
    gap: 40px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__signature-row {
      gap: 20px;
    }
  }

  .maison_commerce_maison_article_section__divider {
    flex: 1 0 0;
    height: 1px;
    background-color: rgba(0, 0, 0, 0.08);
  }

  .maison_commerce_maison_article_section__signature {
    font-size: 20px;
    font-style: italic;
    font-family: 'Libre Baskerville', Georgia, 'Times New Roman', serif;
    line-height: 1.5;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__signature {
      font-size: 14px;
    }
  }

  /* Button */
  .maison_commerce_maison_article_section__button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid;
    background: transparent;
    padding: 16px 20px;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .maison_commerce_maison_article_section__button:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__button {
      width: 100%;
      padding: 12px 20px;
    }
  }

  .maison_commerce_maison_article_section__button-label {
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .maison_commerce_maison_article_section__button svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* Image Column */
  .maison_commerce_maison_article_section__image-wrapper {
    flex: 1 0 0;
    min-width: 0;
    overflow: hidden;
  }

  .maison_commerce_maison_article_section__image-wrapper img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_section__image-wrapper {
      flex: none;
      width: 100%;
      aspect-ratio: 1 / 1;
    }
  }
</style>

{% schema %}
{
  "name": "Maison Article Section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "HET VERHAAL VAN JAY"
    },
    {
      "type": "text",
      "id": "heading_bold",
      "label": "Heading (Bold Part)",
      "default": "Hoe Één Rit"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading (Italic Part)",
      "default": "Alles Veranderde?"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body Text",
      "default": "<p>Jay reed naar een date. Auto gewassen, kleren goed – maar zijn auto rook naar niets. Hij liep een Esso binnen. Plastic boompjes. Synthetische sprays. Troep.</p><p>Uiteindelijk pakte hij roomspray uit zijn badkamer. Spoot het op zijn automaat. En reed weg.</p><p>Op dat moment nam hij een beslissing: dit moet fundamenteel anders.</p><p>Samen met zijn compagnon begon hij te bouwen. Echte parfumeurs. Productie in Nederland en Italië. 20% pure parfumolie per fles – waar anderen stoppen bij 2%. Geen shortcuts. Geen dropship. Gewoon: het goed doen of niet beginnen.</p><p>Zes jaar later. Meer dan 1500 verkooppunten door heel Nederland. Duizenden ritten die net iets beter ruiken.</p>"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote Text",
      "default": "\"Jouw auto verdient meer dan een plastic boompje. Wij maken producten waar we écht trots op zijn.\""
    },
    {
      "type": "text",
      "id": "signature_text",
      "label": "Signature",
      "default": "Jay & Team"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "LEES HET HELE VERHAAL"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "content_bg_color",
      "label": "Content Background",
      "default": "#F5F4F3"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle / Accent Color",
      "default": "#001C4F"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body Text Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button Border Color",
      "default": "#D4D4D4"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading Font Size (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading Font Size (Mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_font_size_desktop",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Body Font Size (Desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "body_font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Body Font Size (Mobile)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Padding Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 140,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 140,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 80
    },
    {
      "type": "header",
      "content": "Padding Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Maison Article Section"
    }
  ]
}
{% endschema %}
