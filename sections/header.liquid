{%- liquid
  assign enable_transparent_template_list = section.settings.enable_transparent_template_list | downcase | split: ', '
  assign transparent_header_enabled = false
  if section.settings.enable_transparent_on_home and template.name == 'index'
    assign transparent_header_enabled = true
  endif

  for template_item in enable_transparent_template_list
    if template_item contains '.'
      assign template_name = template_item | split: '.' | first
      assign suffix_name = template_item | split: '.' | last

      if template_name == template.name and suffix_name == template.suffix
        assign transparent_header_enabled = true
      endif
    else
      if template_item == template.name
        assign transparent_header_enabled = true
      endif
    endif

    if transparent_header_enabled
      break
    endif
  endfor
-%}

<script>
  {% # This is done here AND in the JS so it's responsive in the theme editor before the JS is loaded %}
  {% if section.settings.enable_sticky_header %}
    document.documentElement.classList.add("sticky-header-enabled");
  {% endif %}
  {% if transparent_header_enabled %}
    document.body.classList.add("header-transparent");
  {% endif %}
</script>
{%- liquid
  assign logo = section.settings.logo
  assign logo_width = section.settings.logo_width
  assign mobile_logo_width = section.settings.mobile_logo_width

  assign logo_dark = section.settings.logo_dark
  assign color_text_transparent = section.settings.color_text_transparent
  assign color_count_transparent = section.settings.color_count_transparent
  assign logo_transparent = section.settings.logo_transparent

  assign menu = section.settings.menu
  assign secondary_menu = section.settings.secondary_menu

  assign links = linklists[menu].links
  assign secondary_links = linklists[secondary_menu].links

  assign secondary_menu_valid = false

  if secondary_menu != blank and secondary_menu != menu
    assign secondary_menu_valid = true
  endif

  assign enable_locale_selector = section.settings.enable_locale_selector
  assign enable_country_selector = section.settings.enable_country_selector
  assign show_social_media_mobile = section.settings.show_social_media_mobile

  assign locale_selector = false
  assign country_selector = false

  if enable_locale_selector and shop.published_locales.size > 1
    assign locale_selector = true
  endif

  if enable_country_selector and localization.available_countries.size > 1
    assign country_selector = true
  endif

  capture logo_tag_type
    if request.page_type == 'index'
      echo 'h1'
    else
      echo 'span'
    endif
  endcapture
-%}

{%- capture logo_sizes -%}(max-width: 960px) {{ mobile_logo_width }}px, {{ logo_width }}px{%- endcapture -%}

{%- comment -%} theme-check-disable UnusedAssign {%- endcomment -%}
{%- assign font_logo = settings.font_logo -%}
{%- assign capitalize_logo = settings.capitalize_logo -%}
{%- assign logo_text_transform = settings.logo_text_transform -%}
{%- comment -%} theme-check-enable UnusedAssign {%- endcomment -%}

{%- assign promo_banner_blocks = section.blocks | where: 'type', 'drawer_promo_banner' -%}
{%- assign category_blocks = section.blocks | where: 'type', 'drawer_category_item' -%}
{%- assign badge_blocks = section.blocks | where: 'type', 'drawer_menu_badge' -%}

{%- capture header_logo -%}
  <{{ logo_tag_type }} class="header__logo">
    <a
      class="header__logo-link"
      href="{{ routes.root_url }}"
      {% if logo != blank or logo_transparent != blank or logo_dark != blank %}
        aria-label="{{ shop.name }}"
      {% endif %}
    >
      {%- if logo != blank -%}
        {%- render 'image' with image: logo, wrapper_class: 'regular-logo', sizes: logo_sizes, prioritize_loading: true -%}
      {%- endif -%}

      {%- if logo_dark != blank -%}
        {%- render 'image' with image: logo_dark, wrapper_class: 'dark-logo', sizes: logo_sizes, prioritize_loading: true -%}
      {%- endif -%}

      {%- if logo_transparent != blank -%}
        {%- render 'image' with image: logo_transparent, wrapper_class: 'transparent-logo', sizes: logo_sizes, prioritize_loading: true -%}
      {%- endif -%}

      {%- if logo == blank and logo_dark == blank and logo_transparent == blank -%}
        <span class="header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>
  </{{ logo_tag_type }}>
{%- endcapture -%}

{%- capture search_icon -%}
  <a
    class="
      header__icon-touch
      header__icon-touch--search
      {% if settings.enable_quick_search %}no-transition{% endif %}
    "
    href="{{ routes.search_url }}"
    {% if settings.enable_quick_search %}
      data-search
    {% endif %}
    aria-label="{{ 'general.accessibility.open_search' | t }}"
    aria-controls="MainQuickSearch"
    aria-expanded="false"
  >
    {% render 'icon-button' with icon: 'header-search' %}
    {% render 'icon-button' with icon: 'header-menu-close' %}
  </a>
{%- endcapture -%}

{%- capture account_icon -%}
  <a
    class="header__icon-touch header__icon-touch--account"
    href="{{ routes.account_url }}"
    aria-label="{{ 'general.accessibility.go_account' | t }}"
  >
    {% render 'icon-button' with icon: 'header-account' %}
  </a>
{%- endcapture -%}

{%- capture cart_icon -%}
  <a
    class="header__icon-touch no-transition"
    href="{{ routes.cart_url }}"
    aria-label="{{ 'general.accessibility.open_cart' | t }}"
    data-js-cart-icon="{{ section.settings.cart_icon }}"
  >
    {% assign cart_icon_name = 'header-shopping-[[ci]]' | replace: '[[ci]]', section.settings.cart_icon %}
    {% render 'icon-button', icon: cart_icon_name %}

    <span data-js-cart-count>{{ cart.item_count }}</span>
  </a>
{%- endcapture -%}

{%- capture menu_icon -%}
  <button
    class="header__menu-icon header__icon-touch header__icon-menu"
    aria-label="{{ 'general.accessibility.open_menu' | t }}"
    aria-expanded="false"
    data-aria-label-closed="{{ 'general.accessibility.open_menu' | t }}"
    data-aria-label-opened="{{ 'general.accessibility.close_menu' | t }}"
    data-js-menu-button
  >
    {% render 'icon-button' with icon: 'header-menu' %}
    {% render 'icon-button' with icon: 'header-menu-close' %}
  </button>
{%- endcapture -%}

{%- capture localization_dropdowns -%}
  {%- if locale_selector or country_selector -%}
    <nav class="header__cross-border fs-body-50" data-secondary-navigation>
      {%
        render 'cross-border' with
        show_locale: locale_selector,
        show_country: country_selector,
        id: 'header',
        desktop_only: true
      %}
    </nav>
  {%- endif -%}
{%- endcapture -%}

{%- capture social_icons_mobile -%}
  {%- if show_social_media_mobile -%}
    {% render 'social-icons' %}
  {%- endif -%}
{%- endcapture -%}

<style>
  /* ====== Outer wrapper: floating padding ====== */
  .header--maison.header {
    position: relative;
    padding: 20px;
    background: transparent !important;
    border-bottom: none !important;
  }

  /* ====== Inner bar: frosted glass (base / blurred default) ====== */
  .header--maison .header__inner {
    position: relative;
    background: rgba(4, 3, 19, 0.08);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    height: 80px;
    padding: 16px 40px;
    display: flex;
    align-items: center;
  }

  /* ====== Unified row ====== */
  .header--maison .header__row--maison {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 100%;
  }

  /* JS reference element for sticky header height calc */
  .header--maison .header__row-desktop.lower:not(.header__row--maison) {
    display: block !important;
  }

  /* ====== Segments ====== */
  .header--maison .header__row--maison .header__row-segment {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
  }

  .header--maison .header__row--maison .header__row-segment.left {
    justify-content: flex-start;
    gap: 4px;
  }

  .header--maison .header__row--maison .header__row-segment.right {
    justify-content: flex-end;
    gap: 4px;
  }

  /* ====== Logo: centered ====== */
  .header--maison .header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header--maison .header__logo-link {
    display: flex;
    align-items: center;
  }

  /* ====== Icon buttons ====== */
  .header--maison .header__icon-touch,
  .header--maison .header__menu-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    border-radius: 8px;
    position: relative;
    cursor: pointer;
  }

  /* Ensure menu icon shows on desktop */
  .header--maison .header__menu-icon {
    display: flex !important;
  }

  /* Icon sizes */
  .header--maison .header__icon-touch .icon,
  .header--maison .header__menu-icon .icon {
    width: 24px;
    height: 24px;
  }

  /* ====== Language selector (desktop only) ====== */
  .header--maison .header__language-desktop {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* ====== Vertical divider ====== */
  .header--maison .header__vertical-divider {
    display: block;
    width: 1px;
    height: 16px;
    background-color: #FAFAFB;
    opacity: 0.2;
    flex-shrink: 0;
  }

  /* ====== Cart badge ====== */
  .header--maison [data-js-cart-count] {
    position: absolute;
    top: 2px;
    right: 2px;
    left: auto;
    min-width: 16px;
    height: 16px;
    width: fit-content;
    padding: 0 2px;
    border: 1.5px solid #272928;
    background: var(--Color-Brand-1-100, #FAFAFB);
    color: #121212;
    font-size: 12px;
    box-shadow: none;
    font-weight: 500;
    line-height: 18px;
    text-align: center;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Hide cart count when 0 */
  .header--maison [data-js-cart-count]:empty {
    display: none;
  }

  /* ====== Hide primary navigation (accessed via hamburger) ====== */
  .header--maison .header__links-primary-scroll-container,
  .header--maison .header__links-primary,
  .header--maison .header__links-secondary,
  .header--maison .header__cross-border--desktop-only {
    display: none !important;
  }

  /* ====== No-js menu: keep hidden ====== */
  .header--maison .no-js-menu {
    display: none;
  }

  /* ====== Header Style: Light (White Background) ====== */

  .header--style-light .header__inner {
    background: #FFFFFF;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .header--style-light .header__icon-touch .icon,
  .header--style-light .header__menu-icon .icon {
    color: #121212;
  }

  .header--style-light.header--transparent .header__icon-touch .icon,
  .header--style-light.header--transparent .header__menu-icon .icon {
    color: #121212;
  }

  .header--style-light .header__vertical-divider {
    background-color: rgba(0, 0, 0, 0.12);
    opacity: 1;
  }

  .header--style-light [data-js-cart-count] {
    background: #001C4F;
    color: #FFFFFF;
    border-color: #FFFFFF;
  }

  .header--style-light .dark-logo {
    display: block !important;
  }

  .header--style-light .regular-logo,
  .header--style-light .transparent-logo {
    display: none !important;
  }

  .header--style-light .header__logo-text {
    color: #121212;
  }

  .header--style-light .header__cross-border {
    color: #121212;
  }

  /* ====== Dark logo: hidden by default ====== */
  .header--maison .dark-logo {
    display: none;
  }

  /* ====== Header Style: Blurred (Frosted Glass) ====== */

  .header--style-blurred .transparent-logo {
    display: block !important;
  }

  .header--style-blurred .regular-logo,
  .header--style-blurred .dark-logo {
    display: none !important;
  }

  /* ====== Mobile Responsive ====== */
  @media (max-width: 768px) {
    .header--maison.header {
      padding: 8px;
    }

    .header--maison .header__inner {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border-radius: 8px;
      height: auto;
      padding: 12px 16px;
    }

    .header--maison .header__language-desktop {
      display: none;
    }

    .header--maison .header__icon-touch[data-js-cart-icon] .icon {
      width: 20px;
      height: 20px;
    }

    .header--maison .header__icon-touch[data-js-cart-icon] [data-js-cart-count] {
      top: 1px;
      right: -2px;
    }

    .header--style-light .header__inner {
      background: #FFFFFF;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }

  /* ====== Header space: match outer padding ====== */
  .header-transparent .header__space {
    display: none;
  }
</style>

<header
  data-section-id="{{ section.id }}"
  data-section-type="header"
  {% if section.settings.enable_sticky_header %}
    data-enable-sticky-header="true"
  {% endif %}
  {% if transparent_header_enabled %}
    data-transparent-header="true"
  {% endif %}
  class="
    header
    header--maison
    header--style-{{ section.settings.header_style }}
    {% if logo != blank -%}
      header--has-logo
    {%- endif %}
    {% if transparent_header_enabled %}
      header--transparent
    {% endif %}
    {% if logo_transparent != blank %}
      header--has-transparent-logo
    {% endif %}
    {% if shop.customer_accounts_enabled -%}
      header--has-accounts
    {%- endif %}
    {% if secondary_menu_valid -%}
      header--has-secondary-menu
    {%- endif %}
    {% if menu == blank and secondary_menu != blank -%}
      header--primary-menu-is-secondary
    {%- endif %}
    {% if settings.capitalize_navigation -%}
      header--navigation-is-all-caps
    {%- endif %}
    {% if enable_locale_selector or enable_country_selector -%}
      header--has-country-or-locale
    {%- endif %}
  "
  {% if section.settings.enable_sticky_header %}
    data-is-sticky="true"
  {% endif %}
  style="
    --logo-width: {{ logo_width }}px;
    --mobile-logo-width: {{ mobile_logo_width }}px;
    --color-cart-count-transparent: {{ color_count_transparent }};
    --color-text-transparent: {{ color_text_transparent }};
    --divider-width: {{ section.settings.divider_width }};
  "
>
  <a href="#main" class="header__skip-to-content btn btn--primary btn--small">
    {{ 'general.accessibility.skip_to_content' | t }}
  </a>

  {%- comment -%}
    JS reference element: theme.js ResizeObserver queries .header__row-desktop.lower
    to calculate sticky offsets. Positioned absolute over the full <header> so its
    offsetHeight matches the header's, giving lowerBarOffset = 0 (entire header sticks).
  {%- endcomment -%}
  <div class="header__row header__row-desktop lower" style="position:absolute;inset:0;pointer-events:none;z-index:-1;"></div>

  <div class="header__inner">
    <div class="header__row header__row--maison three-segment">
      <div class="header__row-segment left">
        {{ menu_icon }}
        {{ search_icon }}
      </div>

      {{ header_logo }}

      <div class="header__row-segment right">
        {%- if locale_selector or country_selector -%}
          <div class="header__language-desktop">
            {{ localization_dropdowns }}
            <span class="header__vertical-divider"></span>
          </div>
        {%- endif -%}
        {%- if shop.customer_accounts_enabled -%}
          {{ account_icon }}
        {%- endif -%}
        {{ cart_icon }}
      </div>
    </div>
  </div>

  <div class="no-js-menu no-js-menu--desktop">
    {% render 'no-js-navmenu' with menu: menu, secondary_menu: secondary_menu %}
  </div>
</header>

{% render 'drawer-menu',
  links: links,
  locale_selector: locale_selector,
  country_selector: country_selector,
  promo_banner_blocks: promo_banner_blocks,
  category_blocks: category_blocks,
  category_heading: section.settings.drawer_category_heading,
  badge_blocks: badge_blocks,
  social_icons_mobile: social_icons_mobile
%}

<script>
  // Set heading height at component level
  const header = document.querySelector('[data-section-type="header"]');
  document.documentElement.style.setProperty('--height-header', header.offsetHeight + 'px');
</script>

{%- if settings.enable_confirmation_popup -%}
  <div
    class="
      purchase-confirmation-popup
      {% if settings.enable_section_animations %}
        animation
        animation--purchase-confirmation
      {% endif %}
    "
    data-purchase-confirmation-popup
  >
    <div class="purchase-confirmation-popup__inner"></div>
  </div>
{%- endif -%}

{% render 'flash-alert' %}

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "header__outer-wrapper",
  "settings": [
    {
      "type": "select",
      "id": "header_style",
      "label": "Header Style",
      "default": "light",
      "options": [
        {
          "value": "light",
          "label": "Light (White Background)"
        },
        {
          "value": "blurred",
          "label": "Blurred (Frosted Glass)"
        }
      ]
    },
    {
      "id": "enable_sticky_header",
      "type": "checkbox",
      "label": "t:sections.header.settings.enable_sticky_header.label",
      "default": true
    },
    {
      "type": "radio",
      "id": "cart_icon",
      "label": "t:sections.header.settings.cart_icon.label",
      "default": "bag",
      "options": [
        {
          "value": "bag",
          "label": "t:sections.header.settings.cart_icon.option_bag"
        },
        {
          "value": "cart",
          "label": "t:sections.header.settings.cart_icon.option_cart"
        }
      ]
    },
    {
      "id": "divider_width",
      "type": "select",
      "label": "t:sections.header.settings.divider_width.label",
      "default": "2px",
      "options": [
        {
          "value": "0px",
          "label": "t:sections.header.settings.divider_width.option_0px"
        },
        {
          "value": "1px",
          "label": "t:sections.header.settings.divider_width.option_1px"
        },
        {
          "value": "2px",
          "label": "t:sections.header.settings.divider_width.option_3px"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:shared.settings.disclosure.header__language.content",
      "info": "t:shared.settings.disclosure.header__language.info"
    },
    {
      "type": "checkbox",
      "id": "enable_locale_selector",
      "label": "t:shared.settings.disclosure.enable_locale_selector.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:shared.settings.disclosure.header__country.content",
      "info": "t:shared.settings.disclosure.header__country.info"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "label": "t:shared.settings.disclosure.enable_country_selector.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social_media_mobile",
      "label": "t:sections.header.settings.show_social_media_mobile.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.header.settings.image.label"
    },
    {
      "type": "image_picker",
      "id": "logo_dark",
      "label": "Logo (Dark / Light Style)",
      "info": "Used when Header Style is set to Light. Upload a dark version of your logo."
    },
    {
      "id": "logo_width",
      "type": "range",
      "min": 50,
      "max": 350,
      "step": 10,
      "unit": "px",
      "label": "t:sections.header.settings.logo_width.label",
      "default": 200
    },
    {
      "id": "mobile_logo_width",
      "type": "range",
      "min": 50,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "t:sections.header.settings.mobile_logo_width.label",
      "default": 200
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__navigation"
    },
    {
      "id": "menu",
      "type": "link_list",
      "label": "t:sections.header.settings.menu.label",
      "default": "main-menu"
    },
    {
      "id": "secondary_menu",
      "type": "link_list",
      "label": "t:sections.header.settings.secondary_menu.label"
    },
    {
      "type": "header",
      "content": "Drawer Menu"
    },
    {
      "id": "drawer_category_heading",
      "type": "text",
      "label": "Drawer Category Heading",
      "default": "Shop per Categorie"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__transparent_header"
    },
    {
      "type": "paragraph",
      "content": "t:sections.header.settings.paragraph__transparent_header"
    },
    {
      "id": "enable_transparent_on_home",
      "type": "checkbox",
      "label": "t:sections.header.settings.enable_transparent_on_home.label",
      "default": true
    },
    {
      "id": "enable_transparent_template_list",
      "type": "textarea",
      "placeholder": "collection, product.landing, page.about",
      "label": "t:sections.header.settings.enable_transparent_template_list.label",
      "info": "t:sections.header.settings.enable_transparent_template_list.info"
    },
    {
      "id": "logo_transparent",
      "type": "image_picker",
      "label": "t:sections.header.settings.logo_transparent.label",
      "info": "t:sections.header.settings.logo_transparent.info"
    },
    {
      "id": "color_text_transparent",
      "type": "color",
      "label": "t:sections.header.settings.color_text_transparent.label",
      "default": "#ffffff"
    },
    {
      "id": "color_count_transparent",
      "type": "color",
      "label": "t:sections.header.settings.color_count_transparent.label",
      "default": "#000"
    }
  ],
  "blocks": [
    {
      "type": "drawer_promo_banner",
      "name": "Drawer Promo Banner",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text",
          "default": "Our Bestseller"
        },
        {
          "type": "text",
          "id": "title_italic",
          "label": "Title (Italic Part)",
          "default": "Cadeauset"
        },
        {
          "type": "text",
          "id": "title_bold_line1",
          "label": "Title Bold (Line 1)",
          "default": "The Car"
        },
        {
          "type": "text",
          "id": "title_bold_line2",
          "label": "Title Bold (Line 2)",
          "default": "Parfum Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "SHOP NOW"
        }
      ]
    },
    {
      "type": "drawer_category_item",
      "name": "Drawer Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
