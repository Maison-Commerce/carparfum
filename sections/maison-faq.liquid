{%- comment -%} Section: Maison FAQ {%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq {
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-right: {{ section.settings.padding_right_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --padding-left: {{ section.settings.padding_left_desktop }}px;
    --heading-font-size: {{ section.settings.heading_font_size_desktop }}px;
    --question-font-size: {{ section.settings.question_font_size_desktop }}px;
    --answer-font-size: {{ section.settings.answer_font_size_desktop }}px;
  }
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_maison_faq {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-right: {{ section.settings.padding_right_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --padding-left: {{ section.settings.padding_left_mobile }}px;
      --heading-font-size: {{ section.settings.heading_font_size_mobile }}px;
      --question-font-size: {{ section.settings.question_font_size_mobile }}px;
      --answer-font-size: {{ section.settings.answer_font_size_mobile }}px;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Section wrapper ====== */
  .maison_commerce_maison_faq {
    padding: var(--padding-top) var(--padding-right) var(--padding-bottom) var(--padding-left);
    background: {{ section.settings.section_bg_color }};
  }

  /* ====== Container ====== */
  .maison_commerce_maison_faq__container {
    max-width: 1360px;
    margin: 0 auto;
    display: flex;
    gap: 20px;
    align-items: flex-start;
    justify-content: center;
  }

  /* ====== Image ====== */
  .maison_commerce_maison_faq__image-wrap {
    flex: 1 0 0;
    min-width: 0;
    height: 670px;
    overflow: hidden;
    position: relative;
  }

  .maison_commerce_maison_faq__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ====== Content (FAQ side) ====== */
  .maison_commerce_maison_faq__content {
    flex: 1 0 0;
    min-width: 0;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    gap: 40px;
    justify-content: center;
    padding: 48px 40px;
    background: linear-gradient(to bottom, #f5f4f3 0%, rgba(245, 244, 243, 0) 100%);
  }

  /* ====== Heading ====== */
  .maison_commerce_maison_faq__heading {
    font-family: '{% comment %} font-family: 'PP Fragment', sans-serif; {% endcomment %}ment', sans-serif;
    font-weight: 800;
    font-size: var(--heading-font-size);
    line-height: 1.3;
    color: {{ section.settings.heading_color | default: '#121212' }};
    margin: 0;
  }

  /* ====== Accordion list ====== */
  .maison_commerce_maison_faq__list {
    display: flex;
    flex-direction: column;
  }

  /* ====== Accordion item ====== */
  .maison_commerce_maison_faq__item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    padding: 20px 0;
  }

  /* ====== Question button ====== */
  .maison_commerce_maison_faq__question {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
  }

  .maison_commerce_maison_faq__question:hover {
    opacity: 0.75;
  }

  .maison_commerce_maison_faq__question-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .maison_commerce_maison_faq__question-text {
    flex: 1;
    font-family: '{% comment %} font-family: 'PP Fragment', sans-serif; {% endcomment %}ment', sans-serif;
    font-weight: 800;
    font-size: var(--question-font-size);
    line-height: 1.5;
    color: {{ section.settings.question_color | default: '#121212' }};
  }

  .maison_commerce_maison_faq__toggle-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* ====== Answer ====== */
  .maison_commerce_maison_faq__answer {
    overflow: hidden;
  }

  /* Accordion animation classes */
  .maison_commerce_maison_faq [x-cloak] {
    display: none !important;
  }

  .maison-faq-transition {
    transition: max-height 0.3s ease, opacity 0.25s ease;
    overflow: hidden;
  }

  .maison-faq-hidden {
    max-height: 0 !important;
    opacity: 0;
  }

  .maison-faq-visible {
    max-height: 500px;
    opacity: 1;
  }

  /* Toggle icon transition */
  .maison_commerce_maison_faq__toggle-icon {
    transition: transform 0.2s ease;
  }

  .maison_commerce_maison_faq__answer-inner {
    padding-top: 20px;
    font-family: '{% comment %} font-family: 'PP Fragment', sans-serif; {% endcomment %}ment', sans-serif;
    font-weight: 400;
    font-size: var(--answer-font-size);
    line-height: 1.5;
    color: {{ section.settings.answer_color | default: 'rgba(18, 18, 18, 0.75)' }};
  }

  .maison_commerce_maison_faq__answer-inner p {
    margin: 0;
  }

  .maison_commerce_maison_faq__answer-inner p + p {
    margin-top: 12px;
  }

  /* ====== Mobile ====== */
  @media (max-width: 1050px) {
    .maison_commerce_maison_faq__container {
      flex-direction: column;
    }

    .maison_commerce_maison_faq__image-wrap {
      flex: none;
      width: 100%;
      height: 335px;
      order: 2;
    }

    .maison_commerce_maison_faq__content {
      flex: none;
      width: 100%;
      order: 1;
      padding: 32px 16px;
      gap: 32px;
    }

    .maison_commerce_maison_faq__heading {
      line-height: 1.4;
    }

    .maison_commerce_maison_faq__item {
      padding: 12px 0;
    }

    .maison_commerce_maison_faq__answer-inner {
      padding-top: 12px;
    }
  }
</style>

<section
  class="maison_commerce_maison_faq"
  x-data="{ openItem: 0 }"
>
  <div class="maison_commerce_maison_faq__container">

    {%- comment -%} ====== Image ====== {%- endcomment -%}
    {% if section.settings.image != blank %}
      <div class="maison_commerce_maison_faq__image-wrap">
        {{
          section.settings.image
          | image_url: width: 960
          | image_tag:
            loading: 'lazy',
            class: 'maison_commerce_maison_faq__image',
            alt: section.settings.heading
        }}
      </div>
    {% endif %}

    {%- comment -%} ====== FAQ Content ====== {%- endcomment -%}
    <div class="maison_commerce_maison_faq__content">
      {% if section.settings.heading != blank %}
        <h2 class="maison_commerce_maison_faq__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="maison_commerce_maison_faq__list">
        {% for block in section.blocks %}
          <div class="maison_commerce_maison_faq__item" {{ block.shopify_attributes }}>
            <button
              class="maison_commerce_maison_faq__question"
              @click="openItem = openItem === {{ forloop.index0 }} ? null : {{ forloop.index0 }}"
              type="button"
              :aria-expanded="openItem === {{ forloop.index0 }}"
            >
              {%- comment -%} Question mark icon {%- endcomment -%}
              <svg xmlns="http://www.w3.org/2000/svg" class="maison_commerce_maison_faq__question-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <g clip-path="url(#clip0_4199_18960{{ block.id }})">
                    <path d="M7.26562 8.4375V8.04687C7.26562 6.53672 8.48984 5.3125 10 5.3125C11.5102 5.3125 12.7344 6.53672 12.7344 8.04687V8.4375L10 10.7812V12.7344" stroke="#121212" stroke-width="1.5"/>
                    <path d="M10 13.9062V15.4687" stroke="#121212" stroke-width="1.5"/>
                    <path d="M1.40625 10C1.40625 12.2792 2.31166 14.4651 3.9233 16.0767C5.53495 17.6884 7.7208 18.5937 10 18.5937C12.2792 18.5937 14.4651 17.6884 16.0767 16.0767C17.6884 14.4651 18.5937 12.2792 18.5937 10C18.5937 7.7208 17.6884 5.53495 16.0767 3.9233C14.4651 2.31166 12.2792 1.40625 10 1.40625C7.7208 1.40625 5.53495 2.31166 3.9233 3.9233C2.31166 5.53495 1.40625 7.7208 1.40625 10Z" stroke="#121212" stroke-width="1.5"/>
                </g>
                <defs>
                    <clipPath id="clip0_4199_18960{{ block.id }}">
                    <rect width="20" height="20" fill="white"/>
                    </clipPath>
                </defs>
              </svg>

              <span class="maison_commerce_maison_faq__question-text">{{ block.settings.question }}</span>

              {%- comment -%} Plus icon (collapsed) {%- endcomment -%}
              <svg xmlns="http://www.w3.org/2000/svg" 
                class="maison_commerce_maison_faq__toggle-icon"
                x-show="openItem !== {{ forloop.index0 }}"
                width="20" height="20" viewBox="0 0 20 20" fill="none"
              >
                <path d="M10 1.40625V18.5937" stroke="#121212" stroke-width="1.25"/>
                <path d="M1.40625 10H18.5937" stroke="#121212" stroke-width="1.25"/>
              </svg>

              {%- comment -%} Close icon (expanded) {%- endcomment -%}
              <svg
                class="maison_commerce_maison_faq__toggle-icon"
                x-show="openItem === {{ forloop.index0 }}"
                x-cloak
                width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M18 6L6 18M6 6L18 18" stroke="#121212" stroke-width="1.5"/>
              </svg>
            </button>

            <div
              class="maison_commerce_maison_faq__answer"
              x-show="openItem === {{ forloop.index0 }}"
              x-transition:enter="maison-faq-transition"
              x-transition:enter-start="maison-faq-hidden"
              x-transition:enter-end="maison-faq-visible"
              x-transition:leave="maison-faq-transition"
              x-transition:leave-start="maison-faq-visible"
              x-transition:leave-end="maison-faq-hidden"
              x-cloak
            >
              <div class="maison_commerce_maison_faq__answer-inner">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

