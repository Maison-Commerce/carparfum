        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#FAFAFB"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Maison About Img Links",
      "blocks": [
        {
          "type": "link",
          "settings": {
            "button_text": "SHOP DE COLLECTIE"
          }
        },
        {
          "type": "link",
          "settings": {
            "button_text": "BEGIN MET DE CADEAUSET"
          }
        }
      ]
    }
  ]
}
{% endschema %}
