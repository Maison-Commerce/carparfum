<section class="maison_commerce_maison_collection_banner">
  {%- if section.settings.background_image != blank -%}
    <div class="maison_commerce_maison_collection_banner__bg-image">
      {{
        section.settings.background_image
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          class: 'maison_commerce_maison_collection_banner__bg-img',
          sizes: '100vw',
          widths: '375, 750, 1080, 1440, 1920'
      }}
    </div>
  {%- endif -%}

  <div class="maison_commerce_maison_collection_banner__content-wrapper">
    <div class="maison_commerce_maison_collection_banner__container">
      <div class="maison_commerce_maison_collection_banner__content">
        {%- if section.settings.badge_text != blank -%}
          <div class="maison_commerce_maison_collection_banner__badge">
            <span class="maison_commerce_maison_collection_banner__badge-dot"></span>
            <span class="maison_commerce_maison_collection_banner__badge-text">
              {{- section.settings.badge_text -}}
            </span>
          </div>
        {%- endif -%}

        <h2 class="maison_commerce_maison_collection_banner__heading">
          {%- if section.settings.heading_italic != blank -%}
            <span class="maison_commerce_maison_collection_banner__heading-italic">
              {{- section.settings.heading_italic -}}
            </span>
          {%- endif -%}
          {%- if section.settings.heading_bold != blank -%}
            <span class="maison_commerce_maison_collection_banner__heading-bold">
              {{- section.settings.heading_bold -}}
            </span>
          {%- endif -%}
        </h2>

        {%- if section.settings.body_text != blank -%}
          <div class="maison_commerce_maison_collection_banner__body">
            {{ section.settings.body_text }}
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.button_text != blank -%}
        <a
          {%- if section.settings.button_url != blank %} href="{{ section.settings.button_url }}"{% endif %}
          class="maison_commerce_maison_collection_banner__button"
        >
          <span class="maison_commerce_maison_collection_banner__button-text">
            {{- section.settings.button_text -}}
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" class="maison_commerce_maison_collection_banner__button-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M2 12H20" stroke="currentColor" stroke-width="1.5"/>
            <path d="M14 6L20 12L14 18" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.product_image != blank -%}
    <div class="maison_commerce_maison_collection_banner__product-wrapper">
      {{
        section.settings.product_image
        | image_url: width: 750
        | image_tag:
          loading: 'eager',
          class: 'maison_commerce_maison_collection_banner__product-img',
          sizes: '100vw',
          widths: '375, 750'
      }}
    </div>
  {%- endif -%}
</section>

<style>
  /* ========================================
     Section: Maison Collection Banner
     Prefix: .maison_commerce_maison_collection_banner
     ======================================== */

  .maison_commerce_maison_collection_banner {
    position: relative;
    background-color: {{ section.settings.section_bg_color }};
    overflow: hidden;
  }

  /* Background Image (Desktop) */
  .maison_commerce_maison_collection_banner__bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .maison_commerce_maison_collection_banner__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Content Wrapper */
  .maison_commerce_maison_collection_banner__content-wrapper {
    position: relative;
    z-index: 1;
    min-height: {{ section.settings.desktop_height }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_left_desktop }}px;
    padding-right: {{ section.settings.padding_right_desktop }}px;
  }

  /* Container */
  .maison_commerce_maison_collection_banner__container {
    max-width: 1360px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    min-height: inherit;
  }

  /* Content Block */
  .maison_commerce_maison_collection_banner__content {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Badge */
  .maison_commerce_maison_collection_banner__badge {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .maison_commerce_maison_collection_banner__badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ section.settings.badge_color }};
    flex-shrink: 0;
  }

  .maison_commerce_maison_collection_banner__badge-text {
    font-size: {{ section.settings.badge_font_size_desktop }}px;
    color: {{ section.settings.badge_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 400;
    line-height: 1.5;
  }

  /* Heading */
  .maison_commerce_maison_collection_banner__heading {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
  }

  .maison_commerce_maison_collection_banner__heading-italic {
    display: block;
    font-size: {{ section.settings.heading_italic_font_size_desktop }}px;
    font-style: italic;
    font-weight: 400;
    line-height: 1.2;
    color: {{ section.settings.heading_italic_color }};
  }

  .maison_commerce_maison_collection_banner__heading-bold {
    display: block;
    font-size: {{ section.settings.heading_bold_font_size_desktop }}px;
    font-weight: 800;
    line-height: 1.2;
    color: {{ section.settings.heading_bold_color }};
  }

  /* Body */
  .maison_commerce_maison_collection_banner__body {
    font-size: {{ section.settings.body_font_size_desktop }}px;
    color: {{ section.settings.body_color }};
    line-height: 1.5;
    font-weight: 400;
    max-width: 480px;
    opacity: 0.8;
  }

  .maison_commerce_maison_collection_banner__body p {
    margin: 0;
  }

  /* Button */
  .maison_commerce_maison_collection_banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    max-width: 400px;
    height: 56px;
    padding: 16px 32px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    transition: opacity 0.3s ease;
    cursor: pointer;
    border-radius: {{ section.settings.button_border_radius_desktop }}px;
  }

  .maison_commerce_maison_collection_banner__button:hover {
    opacity: 0.9;
  }

  .maison_commerce_maison_collection_banner__button-text {
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.5;
  }

  .maison_commerce_maison_collection_banner__button-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  /* Product Image (Mobile only) */
  .maison_commerce_maison_collection_banner__product-wrapper {
    display: none;
    position: relative;
    height: {{ section.settings.product_image_height_mobile }}px;
    overflow: hidden;
  }

  .maison_commerce_maison_collection_banner__product-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to bottom, {{ section.settings.section_bg_color }} 0%, transparent 50%);
    pointer-events: none;
  }

  .maison_commerce_maison_collection_banner__product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ========================================
     Mobile Responsive (max-width: 768px)
     ======================================== */
  @media (max-width: 768px) {
    .maison_commerce_maison_collection_banner__bg-image {
      display: none;
    }

    .maison_commerce_maison_collection_banner__content-wrapper {
      min-height: auto;
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_left_mobile }}px;
      padding-right: {{ section.settings.padding_right_mobile }}px;
      background: linear-gradient(180deg, #000 50.13%, #000 99.88%), #FFF;
    }

    .maison_commerce_maison_collection_banner__container {
      min-height: auto;
      gap: 48px;
    }

    .maison_commerce_maison_collection_banner__content {
      max-width: 100%;
      align-items: center;
      text-align: center;
      gap: 12px;
    }

    .maison_commerce_maison_collection_banner__badge {
      justify-content: center;
      gap: 8px;
    }

    .maison_commerce_maison_collection_banner__badge-text {
      font-size: {{ section.settings.badge_font_size_mobile }}px;
    }

    .maison_commerce_maison_collection_banner__heading-italic {
      font-size: {{ section.settings.heading_italic_font_size_mobile }}px;
      line-height: 1.4;
    }

    .maison_commerce_maison_collection_banner__heading-bold {
      font-size: {{ section.settings.heading_bold_font_size_mobile }}px;
      line-height: 1.4;
    }

    .maison_commerce_maison_collection_banner__body {
      font-size: {{ section.settings.body_font_size_mobile }}px;
      max-width: 100%;
    }

    .maison_commerce_maison_collection_banner__button {
      width: 100%;
      height: 44px;
      padding: 12px 24px;
      max-width: 100%;
      gap: 8px;
      border-radius: {{ section.settings.button_border_radius_mobile }}px;
    }

    .maison_commerce_maison_collection_banner__product-wrapper {
      display: block;
    }
  }
</style>

