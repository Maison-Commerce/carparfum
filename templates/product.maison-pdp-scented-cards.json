    "maison_faq_3epPfH": {
      "type": "maison-faq",
      "blocks": {
        "faq_item_7efD3N": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe lang gaat één Scented Card mee?",
            "answer": "<p>Gemiddeld geeft een Scented Card 2 tot 4 weken geur af, afhankelijk van temperatuur en gebruik van de auto.</p>"
          }
        },
        "faq_item_rL6pG9": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe gebruik ik de Scented Card optimaal?",
            "answer": "<p>Hang de Scented Card aan je binnenspiegel. Op deze plek verspreidt de geur zich het meest gelijkmatig door de auto.</p>"
          }
        },
        "faq_item_pF4zhL": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe sterk is de geur van de Scented Card?",
            "answer": "<p>De geur is subtiel en verfijnd aanwezig, zonder te overheersen. Precies genoeg om je auto aangenaam fris te laten ruiken.</p>"
          }
        },
        "faq_item_4TaBMC": {
          "type": "faq_item",
          "settings": {
            "question": "Is het veilig voor mijn auto interieur?",
            "answer": "<p>Ja. De Scented Card hang je eenvoudig aan de binnenspiegel en komt niet in contact met het interieur. Daardoor is het veilig in gebruik en geschikt voor elke auto.</p>"
          }
        },
        "faq_item_ykRyK9": {
          "type": "faq_item",
          "settings": {
            "question": "Wat als ik de geur niet lekker vind?",
            "answer": "<p>Wij bieden een 100% tevredenheidsgarantie. Als je niet tevreden bent met de geur, neem dan contact met ons op en we helpen je graag verder.</p>"
          }
        },
        "faq_item_bdBJyB": {
          "type": "faq_item",
          "settings": {
            "question": "Kan ik het in een winkel kopen?",
            "answer": "<p>Ja, de Scented cards zijn verkrijgbaar bij meer dan 1.500 verkooppunten.<br/>Via het menu onder verkooppunten<strong> </strong>vind je eenvoudig een locatie bij jou in de buurt.</p>"
          }
        },
        "faq_item_HBLJWT": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe snel wordt mijn bestelling verzonden?",
            "answer": "<p>Bestellingen geplaatst voor 15:00 worden dezelfde dag nog verzonden. Levering is doorgaans binnen 1-2 werkdagen.</p>"
          }
        }
      },
