{%- comment -%} Section: Maison FAQ Contant {%- endcomment -%}

{%- assign body_r = section.settings.body_color | default: '#121212' | color_extract: 'red' -%}
{%- assign body_g = section.settings.body_color | default: '#121212' | color_extract: 'green' -%}
{%- assign body_b = section.settings.body_color | default: '#121212' | color_extract: 'blue' -%}

{%- style -%}
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant {
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-right: {{ section.settings.padding_right_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --padding-left: {{ section.settings.padding_left_desktop }}px;
    --heading-font-size: {{ section.settings.heading_font_size_desktop }}px;
    --body-font-size: {{ section.settings.body_font_size_desktop }}px;
    --info-font-size: 16px;
    --column-gap: 40px;
    --info-col-gap: 40px;
    --title-gap: 16px;
    --form-gap: 16px;
    --button-height: 56px;
    --button-radius: 0px;
    --button-px: 32px;
    --button-gap: 12px;
    --badge-font-size: 14px;
  }
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-right: {{ section.settings.padding_right_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --padding-left: {{ section.settings.padding_left_mobile }}px;
      --heading-font-size: {{ section.settings.heading_font_size_mobile }}px;
      --body-font-size: {{ section.settings.body_font_size_mobile }}px;
      --info-font-size: 14px;
      --column-gap: 32px;
      --info-col-gap: 32px;
      --title-gap: 8px;
      --form-gap: 12px;
      --button-height: 44px;
      --button-radius: 8px;
      --button-px: 24px;
      --button-gap: 8px;
      --badge-font-size: 12px;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Section Wrapper ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant {
    padding: var(--padding-top) var(--padding-right) var(--padding-bottom) var(--padding-left);
    background-color: {{ section.settings.section_bg_color | default: '#FFFFFF' }};
  }

  /* ====== Container (Two Columns) ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__container {
    display: flex;
    gap: var(--column-gap);
    align-items: flex-start;
    justify-content: center;
    max-width: 1360px;
    margin: 0 auto;
  }

  /* ====== Info Column ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__info-col {
    flex: 1 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--info-col-gap);
    align-items: flex-start;
  }

  /* ====== Title Group ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__title-group {
    display: flex;
    flex-direction: column;
    gap: var(--title-gap);
    align-items: flex-start;
  }

  /* ====== Heading ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__heading {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 800;
    font-size: var(--heading-font-size);
    line-height: 1.3;
    color: {{ section.settings.heading_color | default: '#121212' }};
    margin: 0;
  }

  /* ====== Subtitle ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__subtitle {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: var(--body-font-size);
    line-height: 1.5;
    color: rgba({{ body_r }}, {{ body_g }}, {{ body_b }}, 0.75);
    margin: 0;
    max-width: 600px;
  }

  /* ====== Contact Group ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__contact-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  /* ====== Contact Rows ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__contact-rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* ====== Contact Row ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__contact-row {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  /* ====== Contact Icon ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__contact-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: {{ section.settings.info_text_color | default: '#121212' }};
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__contact-icon svg {
    width: 100%;
    height: 100%;
  }

  /* ====== Contact Text ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__contact-text {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: var(--info-font-size);
    line-height: 1.5;
    color: {{ section.settings.info_text_color | default: '#121212' }};
    margin: 0;
  }

  /* ====== Badge ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__badge {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 32px;
    padding: 2px 12px;
    background-color: {{ section.settings.badge_bg_color | default: '#F5F4F3' }};
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: var(--badge-font-size);
    line-height: 1.5;
    color: {{ section.settings.badge_text_color | default: '#121212' }};
    text-transform: uppercase;
  }

  /* ====== Form Column ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__form-col {
    flex: 1 0 0;
  }

  /* ====== Form ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__form {
    display: flex;
    flex-direction: column;
    gap: var(--form-gap);
  }

  /* ====== Input Row (Name + Email) ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__input-row {
    display: flex;
    gap: var(--form-gap);
    width: 100%;
  }

  /* ====== Text Input ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__input {
    flex: 1 0 0;
    box-sizing: border-box;
    padding: 12px 16px;
    border: 1px solid {{ section.settings.input_border_color | default: '#EAECF0' }};
    border-radius: 8px;
    background-color: #FFFFFF;
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.05);
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.5;
    color: #121212;
    outline: none;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__input::placeholder {
    color: rgba(26, 26, 26, 0.75);
  }

  /* ====== Select Wrapper ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__select-wrap {
    position: relative;
    width: 100%;
  }

  /* ====== Select ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__select {
    width: 100%;
    box-sizing: border-box;
    padding: 12px 40px 12px 16px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 0;
    background-color: #F9FAFB;
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.5;
    color: rgba(18, 18, 18, 0.75);
    appearance: none;
    -webkit-appearance: none;
    outline: none;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__select-icon {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    pointer-events: none;
    color: rgba(18, 18, 18, 0.75);
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__select-icon svg {
    width: 100%;
    height: 100%;
  }

  /* ====== Textarea ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__textarea {
    width: 100%;
    box-sizing: border-box;
    height: 96px;
    padding: 12px 16px;
    border: 1px solid {{ section.settings.input_border_color | default: '#EAECF0' }};
    border-radius: 12px;
    background-color: #FFFFFF;
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.05);
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.5;
    color: #121212;
    resize: vertical;
    outline: none;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__textarea::placeholder {
    color: rgba(26, 26, 26, 0.75);
  }

  /* ====== Checkbox ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__checkbox-label {
    display: flex;
    gap: 12px;
    align-items: center;
    cursor: pointer;
    position: relative;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__checkbox-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__checkbox-box {
    width: 20px;
    height: 20px;
    border: 1px solid #D0D5DD;
    border-radius: 6px;
    background-color: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__checkbox-icon {
    display: none;
    width: 12px;
    height: 12px;
    color: #FFFFFF;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__checkbox-input:checked + .maison_commerce_maison_faq_contant__checkbox-box {
    background-color: {{ section.settings.button_bg_color | default: '#001C4F' }};
    border-color: {{ section.settings.button_bg_color | default: '#001C4F' }};
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__checkbox-input:checked + .maison_commerce_maison_faq_contant__checkbox-box .maison_commerce_maison_faq_contant__checkbox-icon {
    display: block;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__checkbox-text {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 1.5;
    color: {{ section.settings.info_text_color | default: '#121212' }};
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__checkbox-text a {
    color: inherit;
    text-decoration: underline;
  }

  /* ====== Submit Button ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--button-gap);
    height: var(--button-height);
    padding: 0 var(--button-px);
    background-color: {{ section.settings.button_bg_color | default: '#001C4F' }};
    border: none;
    border-radius: var(--button-radius);
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 1.5;
    color: {{ section.settings.button_text_color | default: '#FAFAFB' }};
    text-transform: uppercase;
    cursor: pointer;
    width: 100%;
    box-sizing: border-box;
    transition: opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__button-arrow {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__button-arrow svg {
    width: 100%;
    height: 100%;
  }

  /* ====== Success Message ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__success {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.5;
    color: {{ section.settings.heading_color | default: '#121212' }};
    text-align: center;
    padding: 20px;
  }

  /* ====== Error Messages ====== */
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__errors {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    color: #cc0000;
    padding: 12px 16px;
    border: 1px solid #cc0000;
    border-radius: 8px;
    background-color: #fff5f5;
  }

  /* ====== Mobile Responsive ====== */
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__container {
      flex-direction: column;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__info-col {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__title-group {
      align-items: center;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__heading {
      line-height: 1.4;
    }

    #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__subtitle {
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .maison_commerce_maison_faq_contant__form-col {
      width: 100%;
    }
  }
</style>

<section class="maison_commerce_maison_faq_contant"
  x-data="maison_commerce_maison_faq_contant_init()"
  {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}>
  <div class="maison_commerce_maison_faq_contant__container">

    {%- comment -%} ====== Info Column ====== {%- endcomment -%}
    <div class="maison_commerce_maison_faq_contant__info-col">

      {%- comment -%} ====== Title Group ====== {%- endcomment -%}
      <div class="maison_commerce_maison_faq_contant__title-group">
        {%- if section.settings.heading != blank -%}
          <h2 class="maison_commerce_maison_faq_contant__heading">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.subtitle != blank -%}
          <p class="maison_commerce_maison_faq_contant__subtitle">
            {{ section.settings.subtitle }}
          </p>
        {%- endif -%}
      </div>

      {%- comment -%} ====== Contact Group ====== {%- endcomment -%}
      <div class="maison_commerce_maison_faq_contant__contact-group">
        <div class="maison_commerce_maison_faq_contant__contact-rows">
          {%- if section.settings.email_address != blank -%}
            <div class="maison_commerce_maison_faq_contant__contact-row">
              <span class="maison_commerce_maison_faq_contant__contact-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="4" width="20" height="16" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M2 4l10 8 10-8" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </span>
              <p class="maison_commerce_maison_faq_contant__contact-text">
                {{ section.settings.email_address }}
              </p>
            </div>
          {%- endif -%}

          {%- if section.settings.working_hours != blank -%}
            <div class="maison_commerce_maison_faq_contant__contact-row">
              <span class="maison_commerce_maison_faq_contant__contact-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M12 6v6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
                </svg>
              </span>
              <p class="maison_commerce_maison_faq_contant__contact-text">
                {{ section.settings.working_hours }}
              </p>
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.badge_text != blank -%}
          <div class="maison_commerce_maison_faq_contant__badge">
            {{ section.settings.badge_text }}
          </div>
        {%- endif -%}
      </div>

    </div>

    {%- comment -%} ====== Form Column ====== {%- endcomment -%}
    <div class="maison_commerce_maison_faq_contant__form-col">
      {%- form 'contact' -%}
        <div class="maison_commerce_maison_faq_contant__form">

          {%- if form.posted_successfully? -%}
            <p class="maison_commerce_maison_faq_contant__success">
              {{ section.settings.success_message | default: 'Bedankt voor je bericht! We nemen zo snel mogelijk contact met je op.' }}
            </p>
          {%- else -%}

            {%- if form.errors -%}
              <div class="maison_commerce_maison_faq_contant__errors">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="maison_commerce_maison_faq_contant__input-row">
              <input
                type="text"
                name="contact[name]"
                placeholder="{{ section.settings.name_placeholder | default: 'Name' }}"
                class="maison_commerce_maison_faq_contant__input"
                required
              >
              <input
                type="email"
                name="contact[email]"
                placeholder="{{ section.settings.email_placeholder | default: 'Email' }}"
                class="maison_commerce_maison_faq_contant__input"
                required
              >
            </div>

            {%- if section.blocks.size > 0 -%}
              <div class="maison_commerce_maison_faq_contant__select-wrap">
                <select
                  name="contact[subject]"
                  class="maison_commerce_maison_faq_contant__select"
                  required
                >
                  <option value="" disabled selected>
                    {{ section.settings.subject_placeholder | default: 'Selecteer een onderwerp' }}
                  </option>
                  {%- for block in section.blocks -%}
                    {%- case block.type -%}
                      {%- when 'subject_option' -%}
                        <option value="{{ block.settings.option_text }}" {{ block.shopify_attributes }}>
                          {{ block.settings.option_text }}
                        </option>
                    {%- endcase -%}
                  {%- endfor -%}
                </select>
                <span class="maison_commerce_maison_faq_contant__select-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none">
                    <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            {%- endif -%}

            <textarea
              name="contact[body]"
              placeholder="{{ section.settings.message_placeholder | default: 'Type your message...' }}"
              class="maison_commerce_maison_faq_contant__textarea"
              required
            ></textarea>

            <label class="maison_commerce_maison_faq_contant__checkbox-label">
              <input
                type="checkbox"
                class="maison_commerce_maison_faq_contant__checkbox-input"
                x-model="privacyAccepted"
                required
              >
              <span class="maison_commerce_maison_faq_contant__checkbox-box">
                <svg class="maison_commerce_maison_faq_contant__checkbox-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" fill="none">
                  <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="maison_commerce_maison_faq_contant__checkbox-text">
                {{ section.settings.privacy_prefix | default: 'I accept the' }}
                {%- if section.settings.privacy_url != blank -%}
                  <a href="{{ section.settings.privacy_url }}">{{ section.settings.privacy_link_text | default: 'Privacy policy' }}</a>
                {%- else -%}
                  {{ section.settings.privacy_link_text | default: 'Privacy policy' }}
                {%- endif -%}
              </span>
            </label>

            <button
              type="submit"
              class="maison_commerce_maison_faq_contant__button"
              :disabled="!privacyAccepted"
            >
              {{ section.settings.button_text | default: 'VERSTUUR BERICHT' }}
              <span class="maison_commerce_maison_faq_contant__button-arrow" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none">
                  <path d="M1.33 8h13.34M9.33 2.67L14.67 8l-5.34 5.33" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>

          {%- endif -%}

        </div>
      {%- endform -%}
    </div>

  </div>
</section>

<script>
  function maison_commerce_maison_faq_contant_init() {
    return {
      privacyAccepted: false
    };
  }
</script>

{% schema %}
{
  "name": "Maison FAQ Contant",
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Custom Section ID",
      "info": "Optional anchor ID for linking (e.g. 'contact')"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nog Vragen? Neem Contact Op"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Staat je vraag er niet tussen? We helpen je graag."
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email Address",
      "default": "info@thecarparfum.com"
    },
    {
      "type": "text",
      "id": "working_hours",
      "label": "Working Hours",
      "default": "Monday - Friday: 8:00 AM - 17:30 PM GMT"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "WE REAGEREN BINNEN 24 UUR"
    },
    {
      "type": "header",
      "content": "Form Labels"
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "Name Placeholder",
      "default": "Name"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email Placeholder",
      "default": "Email"
    },
    {
      "type": "text",
