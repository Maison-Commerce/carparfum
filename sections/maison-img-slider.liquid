{% comment %}
  Section: Maison Image Slider
  Infinite scrolling logo marquee with CSS animation.
  Desktop: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-22541&m=dev
  Mobile: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-28292&m=dev
{% endcomment %}

<section
  class="maison_commerce_maison_img_slider"
  style="
    background-color: {{ section.settings.section_bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  "
>
  {% if section.blocks.size > 0 %}
    <div class="maison_commerce_maison_img_slider__track-wrapper">
      <div
        class="maison_commerce_maison_img_slider__track"
        style="animation-duration: {{ section.settings.animation_speed }}s;"
      >
        {% comment %} Original set {% endcomment %}
        {% for block in section.blocks %}
          {% if block.type == 'logo' and block.settings.image != blank %}
            <div
              class="maison_commerce_maison_img_slider__item"
              {{ block.shopify_attributes }}
            >
              <img
                src="{{ block.settings.image | image_url: height: 300 }}"
                alt="{{ block.settings.image.alt | default: block.settings.alt_text }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
        {% comment %} Duplicate set for seamless loop {% endcomment %}
        {% for block in section.blocks %}
          {% if block.type == 'logo' and block.settings.image != blank %}
            <div
              class="maison_commerce_maison_img_slider__item"
              aria-hidden="true"
            >
              <img
                src="{{ block.settings.image | image_url: height: 300 }}"
                alt=""
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

<style>
  .maison_commerce_maison_img_slider {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_img_slider {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  .maison_commerce_maison_img_slider__track-wrapper {
    overflow: hidden;
    width: 100%;
  }

  .maison_commerce_maison_img_slider__track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: maison_img_slider_scroll linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .maison_commerce_maison_img_slider__track {
      animation-play-state: paused;
    }
  }

  .maison_commerce_maison_img_slider__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: {{ section.settings.logo_height_desktop }}px;
    width: {{ section.settings.logo_height_desktop }}px;
    margin-right: {{ section.settings.gap }}px;
  }

  .maison_commerce_maison_img_slider__item img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }};
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_img_slider__item {
      height: {{ section.settings.logo_height_mobile }}px;
      width: {{ section.settings.logo_height_mobile }}px;
    }
  }

  @keyframes maison_img_slider_scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>

{% schema %}
{
  "name": "Maison Image Slider",
  "settings": [
    {
      "type": "header",
      "content": "Logo Settings"
    },
    {
      "type": "range",
      "id": "logo_height_desktop",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Logo Height (Desktop)",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "min": 30,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Logo Height (Mobile)",
      "default": 80
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "min": 5,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Logo Opacity",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Gap Between Logos",
      "default": 24
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "min": 5,
      "max": 120,
      "step": 5,
      "unit": "s",
      "label": "Scroll Speed (seconds per cycle)",
      "default": 30
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Padding Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Maison Image Slider",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
