{%- comment -%} Section: Maison Image Right Text {%- endcomment -%}

{%- assign body_r = section.settings.body_color | default: '#121212' | color_extract: 'red' -%}
{%- assign body_g = section.settings.body_color | default: '#121212' | color_extract: 'green' -%}
{%- assign body_b = section.settings.body_color | default: '#121212' | color_extract: 'blue' -%}

{%- style -%}
  #shopify-section-{{ section.id }} .maison_commerce_maison_img_right_txt {
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-right: {{ section.settings.padding_right_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --padding-left: {{ section.settings.padding_left_desktop }}px;
    --heading-font-size: {{ section.settings.heading_font_size_desktop }}px;
    --heading-italic-font-size: {{ section.settings.heading_italic_font_size_desktop }}px;
    --body-font-size: {{ section.settings.body_font_size_desktop }}px;
    --label-font-size: 14px;
    --text-gap: 20px;
    --heading-gap: 12px;
    --column-gap: 20px;
    --content-padding-y: 48px;
    --content-padding-x: 40px;
    --content-body-gap: 0px;
    --headings-max-width: {{ section.settings.headings_max_width_desktop }}px;
  }
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_maison_img_right_txt {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-right: {{ section.settings.padding_right_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --padding-left: {{ section.settings.padding_left_mobile }}px;
      --heading-font-size: {{ section.settings.heading_font_size_mobile }}px;
      --heading-italic-font-size: {{ section.settings.heading_italic_font_size_mobile }}px;
      --body-font-size: {{ section.settings.body_font_size_mobile }}px;
      --label-font-size: 14px;
      --text-gap: 12px;
      --heading-gap: 0px;
      --column-gap: 20px;
      --content-padding-y: 32px;
      --content-padding-x: 16px;
      --content-body-gap: 32px;
      --headings-max-width: {{ section.settings.headings_max_width_mobile }}px;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Section Wrapper ====== */
  .maison_commerce_maison_img_right_txt {
    padding: var(--padding-top) var(--padding-right) var(--padding-bottom) var(--padding-left);
    background-color: {{ section.settings.section_bg_color | default: '#FFFFFF' }};
  }

  /* ====== Main Wrapper (Two Columns) ====== */
  .maison_commerce_maison_img_right_txt__wrapper {
    display: flex;
    gap: var(--column-gap);
    align-items: stretch;
    max-width: 1360px;
    margin: 0 auto;
  }

  /* ====== Content Column ====== */
  .maison_commerce_maison_img_right_txt__content-col {
    width: 50%;
    background: {{ section.settings.content_bg_color }};
    padding: var(--content-padding-y) var(--content-padding-x);
  }

  /* ====== Content Inner ====== */
  .maison_commerce_maison_img_right_txt__content {
    max-width: 600px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  /* ====== Top Group (Label + Headings) ====== */
  .maison_commerce_maison_img_right_txt__top-group {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap);
  }

  /* ====== Label ====== */
  .maison_commerce_maison_img_right_txt__label {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 400;
    font-size: var(--label-font-size);
    line-height: 1.5;
    color: {{ section.settings.label_color | default: '#001c4f' }};
    text-transform: uppercase;
  }

  .maison_commerce_maison_img_right_txt__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: {{ section.settings.label_color | default: '#001c4f' }};
    flex-shrink: 0;
  }

  /* ====== Headings ====== */
  .maison_commerce_maison_img_right_txt__headings {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--heading-gap);
    max-width: var(--headings-max-width);
    width: 100%;
  }

  .maison_commerce_maison_img_right_txt__heading-bold {
    font-size: var(--heading-font-size);
    line-height: 1.2;
    color: {{ section.settings.heading_color | default: '#121212' }};
    margin: 0;
    align-self: flex-start;
  }

  .maison_commerce_maison_img_right_txt__heading-italic {
    font-style: italic;
    font-weight: 400;
    font-size: var(--heading-italic-font-size);
    line-height: 1.2;
    margin: 0;
    color: #001c4f;
  }

  /* ====== Body ====== */
  .maison_commerce_maison_img_right_txt__body {
    display: flex;
    flex-direction: column;
    gap: 20px;
    font-weight: 400;
    font-size: var(--body-font-size);
    line-height: 1.5;
    color: rgba({{ body_r }}, {{ body_g }}, {{ body_b }}, 0.75);
  }

  .maison_commerce_maison_img_right_txt__body p {
    margin: 0;
  }

  .maison_commerce_maison_img_right_txt__body strong,
  .maison_commerce_maison_img_right_txt__body b {
    color: {{ section.settings.body_color | default: '#121212' }};
  }

  /* ====== Image Column ====== */
  .maison_commerce_maison_img_right_txt__image-col {
    width: 50%;
    position: relative;
    overflow: hidden;
  }

  .maison_commerce_maison_img_right_txt__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .maison_commerce_maison_img_right_txt__image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.08);
    pointer-events: none;
  }

  /* ====== Mobile Responsive ====== */
  @media (max-width: 1050px) {
    .maison_commerce_maison_img_right_txt__wrapper {
      flex-direction: column;
      max-width: 100%;
    }

    .maison_commerce_maison_img_right_txt__content-col {
      width: 100%;
    }

    .maison_commerce_maison_img_right_txt__content {
      max-width: 100%;
      height: auto;
      justify-content: flex-start;
      gap: var(--content-body-gap);
      align-items: center;
      text-align: center;
    }

    .maison_commerce_maison_img_right_txt__top-group {
      align-items: center;
      width: 100%;
    }

    .maison_commerce_maison_img_right_txt__label {
      justify-content: center;
    }

    .maison_commerce_maison_img_right_txt__headings {
      align-items: center;
    }

    .maison_commerce_maison_img_right_txt__heading-bold {
      align-self: center;
      text-align: center;
      line-height: 1.4;
    }

    .maison_commerce_maison_img_right_txt__heading-italic {
      align-self: flex-end;
      text-align: right;
      line-height: 1.4;
    }

    .maison_commerce_maison_img_right_txt__image-col {
      width: 100%;
      aspect-ratio: 1;
    }
  }
</style>

<section class="maison_commerce_maison_img_right_txt">
  <div class="maison_commerce_maison_img_right_txt__wrapper">

    {%- comment -%} ====== Content Column ====== {%- endcomment -%}
    <div class="maison_commerce_maison_img_right_txt__content-col">
      <div class="maison_commerce_maison_img_right_txt__content">

        <div class="maison_commerce_maison_img_right_txt__top-group">
          {%- if section.settings.label != blank -%}
            <div class="maison_commerce_maison_img_right_txt__label">
              <span class="maison_commerce_maison_img_right_txt__dot"></span>
              {{ section.settings.label }}
            </div>
          {%- endif -%}

          {%- if section.settings.heading_bold != blank or section.settings.heading_italic != blank -%}
            <div class="ff-heading maison_commerce_maison_img_right_txt__headings">
              {%- if section.settings.heading_bold != blank -%}
                <h2 class="maison_commerce_maison_img_right_txt__heading-bold">
                  {{ section.settings.heading_bold }}
                </h2>
              {%- endif -%}
              {%- if section.settings.heading_italic != blank -%}
                <p class="maison_commerce_maison_img_right_txt__heading-italic">
                  {{ section.settings.heading_italic }}
                </p>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.body != blank -%}
          <div class="maison_commerce_maison_img_right_txt__body">
            {{ section.settings.body }}
          </div>
        {%- endif -%}

      </div>
    </div>

    {%- comment -%} ====== Image Column ====== {%- endcomment -%}
    <div class="maison_commerce_maison_img_right_txt__image-col">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            class: 'maison_commerce_maison_img_right_txt__image',
            alt: section.settings.heading_bold
        }}
      {%- endif -%}
      <div class="maison_commerce_maison_img_right_txt__image-overlay"></div>
    </div>

  </div>
</section>

