{% comment %}
  Section: Maison Reviews
  Trustpilot reviews slider with section title and navigation.
  Desktop: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-22970&m=dev
  Mobile: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-28717&m=dev
{% endcomment %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section
  class="maison_commerce_maison_reviews"
  id="maison-reviews-{{ section.id }}"
  style="background-color: {{ section.settings.section_bg_color }};"
>
  <div class="maison_commerce_maison_reviews__container">
    <div class="maison_commerce_maison_reviews__layout">

      {%- comment -%} Info / Content Column {%- endcomment -%}
      <div class="maison_commerce_maison_reviews__info">
        <div class="maison_commerce_maison_reviews__info-top">
          {%- comment -%} Trustpilot Badge {%- endcomment -%}
          <div class="maison_commerce_maison_reviews__badge">
            <div class="maison_commerce_maison_reviews__badge-stars">
              <svg xmlns="http://www.w3.org/2000/svg" width="88" height="16" viewBox="0 0 88 16" fill="none">
                <rect width="16" height="16" fill="#00B67A"/>
                <path d="M8 11.15L10.61 10.45L11.7 14L8 11.15ZM14 6.57H9.41L8 2L6.59 6.57H2L5.71 9.4L4.3 13.96L8.02 11.13L10.3 9.4L14 6.57Z" fill="white"/>
                <rect width="16" height="16" transform="translate(18)" fill="#00B67A"/>
                <path d="M26 11.15L28.61 10.45L29.7 14L26 11.15ZM32 6.57H27.41L26 2L24.59 6.57H20L23.71 9.4L22.3 13.96L26.02 11.13L28.3 9.4L32 6.57Z" fill="white"/>
                <rect width="16" height="16" transform="translate(36)" fill="#00B67A"/>
                <path d="M44 11.15L46.61 10.45L47.7 14L44 11.15ZM50 6.57H45.41L44 2L42.59 6.57H38L41.71 9.4L40.3 13.96L44.02 11.13L46.3 9.4L50 6.57Z" fill="white"/>
                <rect width="16" height="16" transform="translate(54)" fill="#00B67A"/>
                <path d="M62 11.15L64.61 10.45L65.7 14L62 11.15ZM68 6.57H63.41L62 2L60.59 6.57H56L59.71 9.4L58.3 13.96L62.02 11.13L64.3 9.4L68 6.57Z" fill="white"/>
                <rect width="16" height="16" transform="translate(72)" fill="#00B67A"/>
                <rect x="80" width="8" height="16" fill="#DCDCE6"/>
                <path d="M80 11.15L82.61 10.45L83.7 14L80 11.15ZM86 6.57H81.41L80 2L78.59 6.57H74L77.71 9.4L76.3 13.96L80.02 11.13L82.3 9.4L86 6.57Z" fill="white"/>
              </svg>
            </div>
            <span class="maison_commerce_maison_reviews__badge-rating">
              {{ section.settings.trustpilot_rating }}/5 ({% if section.settings.trustpilot_url != blank %}<a href="{{ section.settings.trustpilot_url }}" target="_blank" rel="noopener" class="maison_commerce_maison_reviews__badge-link">{{ section.settings.trustpilot_review_count }} reviews</a>{% else %}{{ section.settings.trustpilot_review_count }} reviews{% endif %})
            </span>
            <div class="maison_commerce_maison_reviews__badge-tp">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M7 0L8.75 4.84L14 5.28L10.01 8.72L11.18 14L7 11.34L2.82 14L3.99 8.72L0 5.28L5.25 4.84L7 0Z" fill="#00B67A"/>
              </svg>
              <span>Trustpilot</span>
            </div>
          </div>

          {%- comment -%} Heading {%- endcomment -%}
          {% if section.settings.title != blank %}
            <div class="maison_commerce_maison_reviews__heading">
              {{ section.settings.title }}
            </div>
          {% endif %}

          {%- comment -%} Subtitle {%- endcomment -%}
          {% if section.settings.subtitle != blank %}
            <div class="maison_commerce_maison_reviews__subtitle">{{ section.settings.subtitle }}</div>
          {% endif %}
        </div>

        {%- comment -%} Navigation Buttons (desktop only) {%- endcomment -%}
        <div class="maison_commerce_maison_reviews__nav">
          <button type="button" class="maison_commerce_maison_reviews__nav-btn maison_commerce_maison_reviews__nav-prev" aria-label="Previous">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M21.75 12H2.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 21.75L2.25 12L12 2.25" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </button>
          <button type="button" class="maison_commerce_maison_reviews__nav-btn maison_commerce_maison_reviews__nav-next" aria-label="Next">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M2.25 12H21.75" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 2.25L21.75 12L12 21.75" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </button>
        </div>
      </div>

      {%- comment -%} Reviews Column {%- endcomment -%}
      <div class="maison_commerce_maison_reviews__reviews">
        <div class="swiper maison_commerce_maison_reviews__swiper" id="reviews-swiper-{{ section.id }}">
          <div class="swiper-wrapper" id="trustpilot-reviews-{{ section.id }}"></div>
        </div>
        <div class="maison_commerce_maison_reviews__pagination swiper-pagination"></div>
        <div class="maison_commerce_maison_reviews__scrollbar swiper-scrollbar"></div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ========================================
     Section wrapper
     ======================================== */
  .maison_commerce_maison_reviews {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_left_desktop }}px;
    padding-right: {{ section.settings.padding_right_desktop }}px;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_left_mobile }}px;
      padding-right: {{ section.settings.padding_right_mobile }}px;
    }
  }

  /* ========================================
     Container
     ======================================== */
  .maison_commerce_maison_reviews__container {
    max-width: 1360px;
    margin: 0 auto;
  }

  /* ========================================
     Layout
     ======================================== */
  .maison_commerce_maison_reviews__layout {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__layout {
      flex-direction: column;
      gap: 32px;
    }
  }

  /* ========================================
     Info Column
     ======================================== */
  .maison_commerce_maison_reviews__info {
    flex: 1;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-left: 40px;
    min-width: 0;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__info {
      padding-left: 0;
      align-self: auto;
      width: 100%;
    }
  }

  .maison_commerce_maison_reviews__info-top {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 600px;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__info-top {
      gap: 12px;
      align-items: center;
      text-align: center;
      max-width: none;
    }
  }

  /* ========================================
     Reviews Column
     ======================================== */
  .maison_commerce_maison_reviews__reviews {
    flex: 1;
    order: -1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__reviews {
      order: unset;
      width: 100%;
      gap: 20px;
    }
  }

  /* ========================================
     Swiper overrides
     ======================================== */
  .maison_commerce_maison_reviews__swiper {
    width: 100%;
    overflow: hidden;
  }

  .maison_commerce_maison_reviews__swiper .swiper-slide {
    height: auto!important;
  }

  /* ========================================
     Badge
     ======================================== */
  .maison_commerce_maison_reviews__badge {
    display: flex;
    gap: 8px;
    align-items: center;
    height: 20px;
    flex-wrap: wrap;
  }

  .maison_commerce_maison_reviews__badge-stars {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .maison_commerce_maison_reviews__badge-stars svg {
    display: block;
  }

  .maison_commerce_maison_reviews__badge-rating {
    font-size: 12px;
    line-height: 1.5;
    color: #121212;
    white-space: nowrap;
  }

  .maison_commerce_maison_reviews__badge-link {
    color: #121212;
    text-decoration: underline;
  }

  .maison_commerce_maison_reviews__badge-tp {
    display: flex;
    gap: 4px;
    align-items: center;
    flex-shrink: 0;
  }

  .maison_commerce_maison_reviews__badge-tp svg {
    display: block;
  }

  .maison_commerce_maison_reviews__badge-tp span {
    font-size: 12px;
    line-height: 1.5;
    color: #121212;
  }

  /* ========================================
     Heading
     ======================================== */
  .maison_commerce_maison_reviews__heading {
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    line-height: 1.2;
  }

  .maison_commerce_maison_reviews__heading p {
    margin: 0;
  }

  .maison_commerce_maison_reviews__heading em,
  .maison_commerce_maison_reviews__heading i {
    font-family: 'PP Editorial New', serif;
    font-style: italic;
    font-weight: 400;
    display: block;
    background: var(--Grad, linear-gradient(89deg, #00102C 0%, #001C4F 83.48%));
    background-clip: text;
    -webkit-background-clip: text;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
      line-height: 1.4;
      text-align: center;
    }
  }

  /* GSAP Animation Styles */
  .maison_commerce_maison_reviews__heading .word-wrapper {
    display: inline-block;
    overflow: hidden;
    vertical-align: top;
    margin-right: 0.15rem;
  }

  .maison_commerce_maison_reviews__heading .word {
    display: inline-block;
    will-change: transform, opacity;
  }

  /* ========================================
     Subtitle
     ======================================== */
  .maison_commerce_maison_reviews__subtitle {
    font-size: 16px;
    line-height: 1.5;
    color: rgba(18, 18, 18, 0.75);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__subtitle {
      font-size: 14px;
      text-align: center;
    }
  }

  /* ========================================
     Navigation Buttons
     ======================================== */
  .maison_commerce_maison_reviews__nav {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__nav {
      display: none;
    }
  }

  .maison_commerce_maison_reviews__nav-btn {
    padding: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #121212;
    border: 1px solid var(--Text-Primary, #121212);
    flex-shrink: 0;
    background: #F9F9F8;
  }

  .maison_commerce_maison_reviews__nav-btn svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  /* ========================================
     Review Card
     ======================================== */
  .maison_commerce_maison_reviews__card {
    background: #FFFFFF;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
    box-sizing: border-box;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__card {
      padding: 16px;
    }
  }

  .maison_commerce_maison_reviews__card-link {
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .maison_commerce_maison_reviews__card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .maison_commerce_maison_reviews__card-stars {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .maison_commerce_maison_reviews__card-stars svg {
    height: 20px;
    width: auto;
    display: block;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__card-stars svg {
      height: 16px;
    }
  }

  .maison_commerce_maison_reviews__card-verified {
    display: flex;
    gap: 4px;
    align-items: center;
    flex-shrink: 0;
  }

  .maison_commerce_maison_reviews__card-verified svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__card-verified svg {
      width: 20px;
      height: 20px;
    }
  }

  .maison_commerce_maison_reviews__card-verified span {
    font-size: 14px;
    line-height: 1.5;
    color: rgba(18, 18, 18, 0.75);
    white-space: nowrap;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__card-verified span {
      font-size: 12px;
    }
  }

  .maison_commerce_maison_reviews__card-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .maison_commerce_maison_reviews__card-title {
    font-size: 16px;
    font-weight: 800;
    color: #121212;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__card-title {
      font-size: 14px;
    }
  }

  .maison_commerce_maison_reviews__card-text {
    font-size: 16px;
    line-height: 1.5;
    color: rgba(18, 18, 18, 0.75);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__card-text {
      font-size: 14px;
    }
  }

  .maison_commerce_maison_reviews__card-footer {
    display: flex;
    gap: 4px;
    align-items: baseline;
    font-size: 14px;
    line-height: 1.5;
    color: #121212;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__card-footer {
      font-size: 12px;
    }
  }

  .maison_commerce_maison_reviews__card-name {
    font-weight: 800;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .maison_commerce_maison_reviews__card-date {
    opacity: 0.5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ========================================
     Pagination (desktop bars)
     ======================================== */
  .maison_commerce_maison_reviews__pagination {
    display: flex;
    gap: 20px;
    height: 2px;
    position: relative!important;
    bottom: auto!important;
    top: auto!important;
    left: auto!important;
  }

  .maison_commerce_maison_reviews__pagination .swiper-pagination-bullet {
    flex: 1;
    height: 2px;
    border-radius: 100px;
    background: #E3E2E1;
    opacity: 1;
    margin: 0 !important;
    width: auto;
  }

  .maison_commerce_maison_reviews__pagination .swiper-pagination-bullet-active {
    background: {{ section.settings.nav_button_color }};
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__pagination {
      display: none;
    }
  }

  /* ========================================
     Scrollbar (mobile)
     ======================================== */
  .maison_commerce_maison_reviews__scrollbar {
    display: none;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_reviews__scrollbar {
      display: block;
      position: relative!important;
      height: 2px!important;
      border-radius: 999px;
      background: rgba(21, 17, 15, 0.1);
    }

    .maison_commerce_maison_reviews__scrollbar .swiper-scrollbar-drag {
      background: #15110F;
      border-radius: 999px;
    }
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  /* ========================================
     GSAP Animations
     ======================================== */
  (function() {
    if (typeof gsap === 'undefined') {
      var gsapScript = document.createElement('script');
      gsapScript.src = 'https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js';
      gsapScript.async = true;
      document.head.appendChild(gsapScript);

      var stScript = document.createElement('script');
      stScript.src = 'https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js';
      stScript.async = true;
      document.head.appendChild(stScript);

      stScript.onload = function() {
        gsap.registerPlugin(ScrollTrigger);
        initGsapAnimations();
      };
    } else {
      if (typeof ScrollTrigger !== 'undefined') {
        gsap.registerPlugin(ScrollTrigger);
      }
      initGsapAnimations();
    }

    function initGsapAnimations() {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupAnimations);
      } else {
        setupAnimations();
      }
    }

    function setupAnimations() {
      var sections = document.querySelectorAll('.maison_commerce_maison_reviews__layout');
      sections.forEach(function(section) {
        var title = section.querySelector('.maison_commerce_maison_reviews__heading');
        var subtitle = section.querySelector('.maison_commerce_maison_reviews__subtitle');
        if (title) animateTitle(title, section);
        if (subtitle) animateSubtitle(subtitle, section);
      });
    }

    function animateTitle(titleEl, container) {
      var tempDiv = document.createElement('div');
      tempDiv.innerHTML = titleEl.innerHTML;

      function processNode(node) {
        if (node.nodeType === Node.TEXT_NODE) {
          var text = node.textContent.trim();
          if (text.length > 0) {
            return text.split(/\s+/).map(function(word) {
              return '<span class="word-wrapper"><span class="word">' + word + '</span></span>';
            }).join(' ');
          }
          return '';
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          var tag = node.tagName.toLowerCase();
          var attrs = Array.from(node.attributes).map(function(a) {
            return a.name + '="' + a.value + '"';
          }).join(' ');
          var content = '';
          node.childNodes.forEach(function(child) { content += processNode(child); });
          return attrs ? '<' + tag + ' ' + attrs + '>' + content + '</' + tag + '>' : '<' + tag + '>' + content + '</' + tag + '>';
        }
        return '';
      }

      var processed = '';
      tempDiv.childNodes.forEach(function(child) { processed += processNode(child); });
      titleEl.innerHTML = processed;

      var words = titleEl.querySelectorAll('.word');
      gsap.set(words, { y: '100%', opacity: 0 });
      gsap.to(words, {
        y: '0%',
        opacity: 1,
        duration: 0.8,
        ease: 'power3.out',
        stagger: 0.08,
        scrollTrigger: {
          trigger: container,
          start: 'top 80%',
          end: 'top 50%',
          toggleActions: 'play none none none'
        }
      });
    }

    function animateSubtitle(el, container) {
      gsap.set(el, { opacity: 0, y: 20 });
      gsap.to(el, {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: container,
          start: 'top 75%',
          end: 'top 45%',
          toggleActions: 'play none none none'
        }
      });
    }
  })();
</script>

