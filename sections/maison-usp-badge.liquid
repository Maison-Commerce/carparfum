{% comment %}
  Section: Maison USP Badge
  Horizontal USP badge bar with icons and text.
  Desktop: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-22495&m=dev
  Mobile: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-28214&m=dev
{% endcomment %}

<section
  class="maison_commerce_maison_usp_badge"
  style="background-color: {{ section.settings.section_bg_color }};"
>
  <div class="maison_commerce_maison_usp_badge__container">
    {% if section.blocks.size > 0 %}
      <div class="maison_commerce_maison_usp_badge__items">
        {% for block in section.blocks %}
          {% if block.type == 'usp_item' %}
            <div
              class="maison_commerce_maison_usp_badge__item {% if forloop.index == 1 %}maison_commerce_maison_usp_badge__item-order-2{% endif %}"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.icon != blank %}
                <img
                  class="maison_commerce_maison_usp_badge__icon"
                  src="{{ block.settings.icon | image_url: width: 96 }}"
                  alt="{{ block.settings.icon.alt | default: block.settings.text }}"
                  loading="lazy"
                  width="{{ block.settings.icon.width }}"
                  height="{{ block.settings.icon.height }}"
                >
              {% endif %}
              {% if block.settings.text != blank %}
                <span
                  class="maison_commerce_maison_usp_badge__text"
                  style="color: {{ section.settings.text_color }};"
                >
                  {{ block.settings.text }}
                </span>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .maison_commerce_maison_usp_badge {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_left_desktop }}px;
    padding-right: {{ section.settings.padding_right_desktop }}px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_usp_badge {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_left_mobile }}px;
      padding-right: {{ section.settings.padding_right_mobile }}px;
    }
  }

  .maison_commerce_maison_usp_badge__container {
    max-width: 1360px;
    margin: 0 auto;
  }

  /* Desktop: horizontal row */
  .maison_commerce_maison_usp_badge__items {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  /* Mobile: 2x2 grid, column-first flow (1,3 / 2,4) */
  @media (max-width: 768px) {
    .maison_commerce_maison_usp_badge__items {
      gap: 12px;
    }
  }

  /* USP Item */
  .maison_commerce_maison_usp_badge__item {
    flex: 1;
    min-width: fit-content;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_usp_badge__item {
      justify-content: flex-start;
    }
  }

  /* Icon */
  .maison_commerce_maison_usp_badge__icon {
    display: block;
    height: auto;
    width: auto;
    max-height: 24px;
    flex-shrink: 0;
  }

  /* Text */
  .maison_commerce_maison_usp_badge__text {
    font-size: {{ section.settings.font_size_desktop }}px;
    font-weight: 400;
    line-height: 1.5;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_usp_badge__text {
      font-size: {{ section.settings.font_size_mobile }}px;
    }
  }
</style>

