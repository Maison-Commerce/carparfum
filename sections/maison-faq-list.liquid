{%- comment -%} Section: Maison FAQ List {%- endcomment -%}

{%- assign answer_r = section.settings.answer_color | default: '#121212' | color_extract: 'red' -%}
{%- assign answer_g = section.settings.answer_color | default: '#121212' | color_extract: 'green' -%}
{%- assign answer_b = section.settings.answer_color | default: '#121212' | color_extract: 'blue' -%}

{%- style -%}
  #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list {
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-right: {{ section.settings.padding_right_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --padding-left: {{ section.settings.padding_left_desktop }}px;
    --heading-font-size: {{ section.settings.heading_font_size_desktop }}px;
    --question-font-size: {{ section.settings.question_font_size_desktop }}px;
    --answer-font-size: {{ section.settings.answer_font_size_desktop }}px;
    --container-py: 80px;
    --container-px: 40px;
    --column-gap: 40px;
    --item-py: 20px;
    --answer-gap: 20px;
    --icon-size: 24px;
  }
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-right: {{ section.settings.padding_right_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --padding-left: {{ section.settings.padding_left_mobile }}px;
      --heading-font-size: {{ section.settings.heading_font_size_mobile }}px;
      --question-font-size: {{ section.settings.question_font_size_mobile }}px;
      --answer-font-size: {{ section.settings.answer_font_size_mobile }}px;
      --container-py: 48px;
      --container-px: 20px;
      --column-gap: 32px;
      --item-py: 16px;
      --answer-gap: 16px;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Section Wrapper ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list {
    padding: var(--padding-top) var(--padding-right) var(--padding-bottom) var(--padding-left);
    background-color: {{ section.settings.section_bg_color | default: '#FFFFFF' }};
  }

  /* ====== Container (gray box) ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__container {
    background-color: {{ section.settings.container_bg_color | default: '#F9F9F8' }};
    border: 1px solid {{ section.settings.container_border_color | default: '#F5F4F3' }};
    padding: var(--container-py) var(--container-px);
    display: flex;
    gap: var(--column-gap);
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
    max-width: 1360px;
    margin: 0 auto;
  }

  /* ====== Heading Column ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__heading-col {
    flex: 1 0 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  /* ====== Heading ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__heading {
    font-family: 'font-family: 'PP Fragment', sans-serif;ment', sans-serif;
    font-weight: 800;
    font-size: var(--heading-font-size);
    line-height: 1.3;
    color: {{ section.settings.heading_color | default: '#121212' }};
    margin: 0;
  }

  /* ====== Accordion Column ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__accordion-col {
    flex: 1 0 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* ====== Accordion Item ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__item {
    width: 100%;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    padding: var(--item-py) 0;
  }

  /* ====== Item Header (button) ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__header {
    width: 100%;
    display: flex;
    gap: 8px;
    align-items: center;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
  }

  /* ====== Question Text ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__question {
    flex: 1 0 0;
    font-family: 'font-family: 'PP Fragment', sans-serif;ment', sans-serif;
    font-weight: 800;
    font-size: var(--question-font-size);
    line-height: 1.5;
    color: {{ section.settings.question_color | default: '#121212' }};
    margin: 0;
  }

  /* ====== Toggle Icon ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__toggle {
    width: var(--icon-size);
    height: var(--icon-size);
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: {{ section.settings.question_color | default: '#121212' }};
  }

   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__toggle svg {
    width: 100%;
    height: 100%;
  }

   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__item--open .maison_commerce_maison_faq_list__toggle {
    transform: rotate(45deg);
  }

  /* ====== Answer Wrapper (grid for smooth animation) ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__answer-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__item--open .maison_commerce_maison_faq_list__answer-wrap {
    grid-template-rows: 1fr;
  }

   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__answer-inner {
    overflow: hidden;
  }

  /* ====== Answer Text ====== */
   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__answer {
    font-family: 'font-family: 'PP Fragment', sans-serif;ment', sans-serif;
    font-weight: 400;
    font-size: var(--answer-font-size);
    line-height: 1.5;
    color: rgba({{ answer_r }}, {{ answer_g }}, {{ answer_b }}, 0.75);
    margin: 0;
    padding-top: var(--answer-gap);
  }

   #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__answer p {
    margin: 0;
  }

  /* ====== Mobile Responsive ====== */
  @media (max-width: 1050px) {
     #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__container {
      flex-direction: column;
      align-items: center;
      border-left: none;
      border-right: none;
      max-width: 100%;
    }

     #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__heading-col {
      align-items: center;
    }

     #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__heading {
      text-align: center;
      line-height: 1.4;
    }

     #shopify-section-{{ section.id }} .maison_commerce_maison_faq_list__accordion-col {
      width: 100%;
    }
  }
</style>

<section class="maison_commerce_maison_faq_list"
  x-data="maison_commerce_maison_faq_list_init()"
  {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}>
  <div class="maison_commerce_maison_faq_list__container">

    {%- comment -%} ====== Heading Column ====== {%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      <div class="maison_commerce_maison_faq_list__heading-col">
        <h2 class="maison_commerce_maison_faq_list__heading">
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endif -%}

    {%- comment -%} ====== Accordion Column ====== {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="maison_commerce_maison_faq_list__accordion-col">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'faq_item' -%}
              <div class="maison_commerce_maison_faq_list__item"
                :class="{ 'maison_commerce_maison_faq_list__item--open': openItem === {{ forloop.index0 }} }"
                {{ block.shopify_attributes }}>

                <button class="maison_commerce_maison_faq_list__header"
                  @click="openItem = openItem === {{ forloop.index0 }} ? null : {{ forloop.index0 }}"
                  :aria-expanded="openItem === {{ forloop.index0 }}">
                  <span class="maison_commerce_maison_faq_list__question">
                    {{ block.settings.question }}
                  </span>
                  <span class="maison_commerce_maison_faq_list__toggle" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
                      <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="1.5"/>
                      <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                  </span>
                </button>

                <div class="maison_commerce_maison_faq_list__answer-wrap">
                  <div class="maison_commerce_maison_faq_list__answer-inner">
                    {%- if block.settings.answer != blank -%}
                      <div class="maison_commerce_maison_faq_list__answer">
                        {{ block.settings.answer }}
                      </div>
                    {%- endif -%}
                  </div>
                </div>

              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  function maison_commerce_maison_faq_list_init() {
    return {
      openItem: null
    };
  }
</script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

