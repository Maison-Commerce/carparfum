    "maison_faq_list_LziKba": {
      "type": "maison-faq-list",
      "blocks": {
        "faq_item_BEAftw": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe gebruik ik The Car Parfum spray?",
            "answer": "<p>Houd de flacon op 10cm afstand van je automat en spray 4x. Laat even drogen en geniet. Dat is alles.</p>"
          }
        },
        "faq_item_R6GKck": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe lang blijft de geur hangen?",
            "answer": "<p>Gemiddeld 24–48 uur, afhankelijk van temperatuur en ventilatie. Jij bepaalt wanneer je opnieuw sprayt.</p>"
          }
        },
        "faq_item_jnR3aH": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe lang gaat één flesje mee?",
            "answer": "<p>Een 15ml flacon gaat gemiddeld 4–6 weken mee bij normaal gebruik. De 100ml fles gaat uiteraard veel langer mee.</p>"
          }
        },
        "faq_item_JaEXUY": {
          "type": "faq_item",
          "settings": {
            "question": "Is het veilig voor mijn auto-interieur?",
            "answer": "<p>Ja. Spray op je automat — niet op leer, plastic of het dashboard. Laat even drogen. Miljoenen tevreden klanten gingen je voor.</p>"
          }
        },
        "faq_item_PnrG7f": {
          "type": "faq_item",
          "settings": {
            "question": "Kan ik de spray ook buiten de auto gebruiken?",
            "answer": "<p>Technisch gezien wel. Maar onze producten zijn specifiek ontwikkeld voor auto-interieurs en daar presteren ze het best.</p>"
          }
        },
        "faq_item_9QNaMK": {
          "type": "faq_item",
          "settings": {
            "question": "Wat is het verschil tussen de 15ml en 100ml fles?",
            "answer": "<p>Alleen het formaat. De 15ml is perfect om een geur te ontdekken. De 100ml is voordeliger per ml — ideaal als je je favoriet hebt gevonden.</p>"
          }
        },
        "faq_item_NcFanb": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe werken de hangers?",
            "answer": "<p>Hang de hanger aan je achteruitkijkspiegel. De geur verspreidt zich geleidelijk en gaat tot 2 maanden mee. Gewoon ophangen en genieten.</p>"
          }
        },
        "faq_item_z6HiQ3": {
          "type": "faq_item",
          "settings": {
            "question": "Wat zit er in The Car Parfum? Is het veilig?",
            "answer": "<p>Onze parfums bevatten 20% pure parfumolie — veel hoger dan standaard luchtverfrisers. Ontwikkeld en geproduceerd in Nederland en Italië. Niet getest op dieren.</p>"
          }
        }
      },
