{%- comment -%} Section: Maison About Us Banner {%- endcomment -%}

{%- assign overlay_r = section.settings.section_bg_color | default: '#000000' | color_extract: 'red' -%}
{%- assign overlay_g = section.settings.section_bg_color | default: '#000000' | color_extract: 'green' -%}
{%- assign overlay_b = section.settings.section_bg_color | default: '#000000' | color_extract: 'blue' -%}

{%- style -%}
  #shopify-section-{{ section.id }} .maison_commerce_maison_about_us_banner {
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-right: {{ section.settings.padding_right_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --padding-left: {{ section.settings.padding_left_desktop }}px;
    --heading-font-size: {{ section.settings.heading_font_size_desktop }}px;
    --description-font-size: {{ section.settings.description_font_size_desktop }}px;
    --label-font-size: 14px;
    --text-gap: 20px;
    --content-button-gap: 96px;
    --button-height: 56px;
    --button-padding-y: 16px;
    --button-padding-x: 32px;
    --content-max-width: 708px;
  }
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_maison_about_us_banner {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-right: {{ section.settings.padding_right_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --padding-left: {{ section.settings.padding_left_mobile }}px;
      --heading-font-size: {{ section.settings.heading_font_size_mobile }}px;
      --description-font-size: {{ section.settings.description_font_size_mobile }}px;
      --label-font-size: 12px;
      --text-gap: 12px;
      --content-button-gap: 48px;
      --button-height: 44px;
      --button-padding-y: 12px;
      --button-padding-x: 24px;
      --content-max-width: 100%;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Section Wrapper ====== */
  .maison_commerce_maison_about_us_banner {
    position: relative;
    overflow: hidden;
  }

  /* ====== Background Image ====== */
  .maison_commerce_maison_about_us_banner__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .maison_commerce_maison_about_us_banner__bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  {%- if section.settings.background_image_mobile != blank -%}
    .maison_commerce_maison_about_us_banner__bg-image--mobile {
      display: none;
    }
  {%- endif -%}

  .maison_commerce_maison_about_us_banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(87deg, rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, 1) 0%, rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, 0) 83.475%);
  }

  /* ====== Container ====== */
  .maison_commerce_maison_about_us_banner__container {
    position: relative;
    min-height: {{ section.settings.desktop_height }};
    z-index: 1;
    max-width: 1360px;
    margin: 0 auto;
    padding: var(--padding-top) var(--padding-right) var(--padding-bottom) var(--padding-left);
  }

  /* ====== Content ====== */
  .maison_commerce_maison_about_us_banner__content {
    display: flex;
    flex-direction: column;
    gap: var(--content-button-gap);
    max-width: var(--content-max-width);
  }

  /* ====== Text Group ====== */
  .maison_commerce_maison_about_us_banner__text-group {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap);
  }

  /* ====== Label ====== */
  .maison_commerce_maison_about_us_banner__label {
    display: flex;
    align-items: center;
    gap: 12px;
    {% comment %} font-family: 'font-family: 'PP Fragment', sans-serif;ment', sans-serif; {% endcomment %}
    font-weight: 400;
    font-size: var(--label-font-size);
    line-height: 1.5;
    color: {{ section.settings.label_color | default: '#BBC2D0' }};
    text-transform: uppercase;
  }

  .maison_commerce_maison_about_us_banner__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: {{ section.settings.label_color | default: '#BBC2D0' }};
    flex-shrink: 0;
  }

  /* ====== Heading ====== */
  .maison_commerce_maison_about_us_banner__heading {
    {% comment %} font-family: 'font-family: 'PP Fragment', sans-serif;ment', sans-serif; {% endcomment %}
    font-weight: 800;
    font-size: var(--heading-font-size);
    line-height: 1.2;
    color: {{ section.settings.heading_color | default: '#FAFAFB' }};
    margin: 0;
  }

  /* ====== Description ====== */
  .maison_commerce_maison_about_us_banner__description {
    {% comment %} font-family: 'font-family: 'PP Fragment', sans-serif;ment', sans-serif; {% endcomment %}
    font-weight: 400;
    font-size: var(--description-font-size);
    line-height: 1.5;
    color: {{ section.settings.description_color | default: '#BBC2D0' }};
    max-width: 600px;
  }

  .maison_commerce_maison_about_us_banner__description p {
    margin: 0;
  }

  /* ====== Button ====== */
  .maison_commerce_maison_about_us_banner__button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--button-height);
    padding: var(--button-padding-y) var(--button-padding-x);
    background: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color | default: '#001c4f' }};
    {% comment %} font-family: 'font-family: 'PP Fragment', sans-serif;ment', sans-serif; {% endcomment %}
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    max-width: 400px;
    transition: opacity 0.2s ease;
  }

  .maison_commerce_maison_about_us_banner__button:hover {
    opacity: 0.85;
  }

  .maison_commerce_maison_about_us_banner__button svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* ====== Mobile Responsive ====== */
  @media (max-width: 1050px) {
    .maison_commerce_maison_about_us_banner {
      display: flex;
      flex-direction: column;
    }

    .maison_commerce_maison_about_us_banner__container {
      min-height: auto;
      order: 1;
      background: {{ section.settings.section_bg_color | default: '#000000' }};
    }

    .maison_commerce_maison_about_us_banner__bg {
      position: relative;
      height: 320px;
      order: 2;
    }

    .maison_commerce_maison_about_us_banner__overlay {
      background: linear-gradient(180deg, rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, 1) 0%, rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, 0) 50%);
    }

    {%- if section.settings.background_image_mobile != blank -%}
      .maison_commerce_maison_about_us_banner__bg-image--mobile {
        display: block;
      }

      .maison_commerce_maison_about_us_banner__bg-image--desktop {
        display: none;
      }
    {%- endif -%}

    .maison_commerce_maison_about_us_banner__content {
      max-width: 100%;
      align-items: center;
      text-align: center;
    }

    .maison_commerce_maison_about_us_banner__label {
      justify-content: center;
      gap: 8px;
    }

    .maison_commerce_maison_about_us_banner__heading {
      text-align: center;
      line-height: 1.4;
    }

    .maison_commerce_maison_about_us_banner__description {
      text-align: center;
      max-width: 100%;
    }

    .maison_commerce_maison_about_us_banner__button {
      max-width: 100%;
      width: 100%;
    }
  }
</style>

<section class="maison_commerce_maison_about_us_banner">

  {%- comment -%} ====== Background Image ====== {%- endcomment -%}
  <div class="maison_commerce_maison_about_us_banner__bg">
    {%- if section.settings.background_image != blank -%}
      {{
        section.settings.background_image
        | image_url: width: 1920
        | image_tag:
          loading: 'lazy',
          class: 'maison_commerce_maison_about_us_banner__bg-image maison_commerce_maison_about_us_banner__bg-image--desktop',
          alt: section.settings.heading
      }}
    {%- endif -%}
    {%- if section.settings.background_image_mobile != blank -%}
      {{
        section.settings.background_image_mobile
        | image_url: width: 800
        | image_tag:
          loading: 'lazy',
          class: 'maison_commerce_maison_about_us_banner__bg-image maison_commerce_maison_about_us_banner__bg-image--mobile',
          alt: section.settings.heading
      }}
    {%- endif -%}
    <div class="maison_commerce_maison_about_us_banner__overlay"></div>
  </div>

  {%- comment -%} ====== Content ====== {%- endcomment -%}
  <div class="maison_commerce_maison_about_us_banner__container">
    <div class="maison_commerce_maison_about_us_banner__content">

      <div class="maison_commerce_maison_about_us_banner__text-group">
        {%- if section.settings.label != blank -%}
          <div class="maison_commerce_maison_about_us_banner__label">
            <span class="maison_commerce_maison_about_us_banner__dot"></span>
            {{ section.settings.label }}
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="maison_commerce_maison_about_us_banner__heading">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="maison_commerce_maison_about_us_banner__description">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
        <a href="{{ section.settings.button_link }}" class="maison_commerce_maison_about_us_banner__button">
          {{ section.settings.button_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M1.125 7.99695H14.25" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7.6875 14.5625L14.25 8L7.6875 1.4375" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </a>
      {%- endif -%}

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Maison About Us Banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "OVER ONS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gebouwd Door Autoliefhebbers. Voor Autoliefhebbers."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Je geeft om je auto. De velgen. Het interieur. De details. Waarom zou je geur dan anders zijn? The Car Parfum is gemaakt voor mensen die nergens concessies doen.</p>"
    },
    {
      "type": "text",
