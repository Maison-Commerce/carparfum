{%- comment -%} Section: Announcement Bar (Reworked) {%- endcomment -%}

<script>
  {% # This is done here AND in the JS so it's responsive in the theme editor before the JS is loaded %}
  document.documentElement.setAttribute("data-enable-sticky-announcement-bar", "{{ section.settings.enable_sticky_announcement_bar }}");
</script>

{%- if section.blocks.size > 0 -%}

{%- style -%}
  #shopify-section-{{ section.id }} .maison_commerce_announcement_bar {
    --bar-height: 40px;
    --font-size: {{ section.settings.font_size_desktop }}px;
  }
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_announcement_bar {
      --bar-height: 32px;
      --font-size: {{ section.settings.font_size_mobile }}px;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Bar Wrapper ====== */
  .maison_commerce_announcement_bar {
    background: {{ section.settings.color_background }};
    height: var(--bar-height);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  /* ====== Items Wrapper ====== */
  .maison_commerce_announcement_bar__wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ====== Announcement Item ====== */
  .maison_commerce_announcement_bar__item {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 20px;
    width: 100%;
    height: 100%;
  }

  .maison_commerce_announcement_bar__item--absolute {
    position: absolute;
    top: 0;
    left: 0;
  }

  /* ====== Text ====== */
  .maison_commerce_announcement_bar__text {
    font-family: 'PP Fragment', sans-serif;
    font-weight: 400;
    font-size: var(--font-size);
    line-height: 1.5;
    color: {{ section.settings.color_text | default: '#FAFAFB' }};
    margin: 0;
  }

  .maison_commerce_announcement_bar__text p {
    margin: 0;
  }

  /* ====== Link ====== */
  .maison_commerce_announcement_bar__link {
    color: inherit;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .maison_commerce_announcement_bar__link:hover {
    text-decoration: underline;
  }

  /* ====== Mobile Text Variant ====== */
  .maison_commerce_announcement_bar__text--mobile {
    display: none;
  }

  @media (max-width: 1050px) {
    .maison_commerce_announcement_bar__text--desktop {
      display: none;
    }
    .maison_commerce_announcement_bar__text--mobile {
      display: block;
    }
  }
</style>

<div
  class="maison_commerce_announcement_bar"
  data-section-id="{{ section.id }}"
  data-section-type="announcement-bar"
  data-enable-sticky-announcement-bar="{{ section.settings.enable_sticky_announcement_bar }}"
  data-item-count="{{ section.blocks.size }}"
  {%- if section.blocks.size > 1 %}
    x-data="maison_commerce_announcement_bar_init()"
  {%- endif %}
>
  <div class="maison_commerce_announcement_bar__wrapper">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'announcement' -%}
          <div
            class="maison_commerce_announcement_bar__item{% if section.blocks.size > 1 %} maison_commerce_announcement_bar__item--absolute{% endif %}"
            {{ block.shopify_attributes }}
            {%- if section.blocks.size > 1 %}
              x-show="current === {{ forloop.index0 }}"
              x-transition.opacity.duration.300ms
            {%- endif %}
          >
            {%- assign has_mobile_text = false -%}
            {%- if block.settings.title_mobile != blank and block.settings.title_mobile != block.settings.title -%}
              {%- assign has_mobile_text = true -%}
            {%- endif -%}

            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="maison_commerce_announcement_bar__link">
            {%- endif -%}

            {%- if has_mobile_text -%}
              <div class="maison_commerce_announcement_bar__text maison_commerce_announcement_bar__text--desktop">
                {{ block.settings.title | replace: '<a ', '<span class="fake-link" ' | replace: '</a>', '</span>' }}
              </div>
              <div class="maison_commerce_announcement_bar__text maison_commerce_announcement_bar__text--mobile">
                {{ block.settings.title_mobile | replace: '<a ', '<span class="fake-link" ' | replace: '</a>', '</span>' }}
              </div>
            {%- else -%}
              <div class="maison_commerce_announcement_bar__text">
                {{ block.settings.title | replace: '<a ', '<span class="fake-link" ' | replace: '</a>', '</span>' }}
              </div>
            {%- endif -%}

            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{%- if section.blocks.size > 1 -%}
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<script>
  function maison_commerce_announcement_bar_init() {
    return {
      current: 0,
      total: {{ section.blocks.size }},
      autoplay: {{ section.settings.autoplay_enabled }},
      delay: {{ section.settings.autoplay_delay | times: 1000 }},
      interval: null,
      init() {
        if (this.autoplay && this.total > 1) {
          this.startAutoplay();
        }
      },
      startAutoplay() {
        this.interval = setInterval(() => {
          this.current = (this.current + 1) % this.total;
        }, this.delay);
      },
      destroy() {
        if (this.interval) clearInterval(this.interval);
      }
    };
  }
</script>
{%- endif -%}

{%- endif -%}

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "class": "announcement-bar__outer-wrapper",
  "max_blocks": 3,
  "settings": [
    {
      "id": "enable_sticky_announcement_bar",
      "type": "select",
      "label": "t:sections.announcement_bar.settings.enable_sticky_announcement_bar.label",
      "info": "t:sections.announcement_bar.settings.enable_sticky_announcement_bar.info",
      "options": [
        {
          "value": "never",
          "label": "t:sections.announcement_bar.settings.enable_sticky_announcement_bar.options.never"
        },
        {
          "value": "desktop",
          "label": "t:sections.announcement_bar.settings.enable_sticky_announcement_bar.options.desktop"
        },
        {
          "value": "mobile",
          "label": "t:sections.announcement_bar.settings.enable_sticky_announcement_bar.options.mobile"
        },
        {
          "value": "desktop-and-mobile",
          "label": "t:sections.announcement_bar.settings.enable_sticky_announcement_bar.options.both"
        }
      ],
      "default": "never"
    },
    {
      "id": "autoplay_enabled",
      "type": "checkbox",
      "label": "t:sections.announcement_bar.settings.autoplay_enabled.label",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "label": "t:sections.announcement_bar.settings.timing.label",
      "min": 3,
      "max": 15,
      "step": 1,
      "default": 4,
      "unit": "s"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "id": "color_background",
      "type": "color_background",
      "label": "t:sections.announcement_bar.settings.color_background.label",
      "default": "linear-gradient(48deg, rgb(0, 16, 44) 0%, rgb(0, 28, 79) 83.475%)"
    },
    {
      "id": "color_text",
      "type": "color",
      "label": "t:sections.announcement_bar.settings.color_text.label",
      "default": "#FAFAFB"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Desktop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Mobile)",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement_bar.blocks.announcement.name",
      "settings": [
        {
          "type": "richtext",
          "id": "title",
          "default": "<p>Free standard shipping and returns on all orders</p>",
          "label": "t:sections.announcement_bar.blocks.announcement.settings.title.label"
        },
        {
          "type": "richtext",
          "id": "title_mobile",
          "label": "t:sections.announcement_bar.blocks.announcement.settings.title_mobile.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement_bar.blocks.announcement.settings.link.label",
          "info": "t:sections.announcement_bar.blocks.announcement.settings.link.info"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      }
    ]
  }
}
{% endschema %}
