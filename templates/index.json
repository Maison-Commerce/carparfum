    "dbd17859-9f6c-48b3-84e1-4294e6f2fff5": {
      "type": "quote",
      "blocks": {
        "template--18081342914824__dbd17859-9f6c-48b3-84e1-4294e6f2fff5-quote-1": {
          "type": "quote",
          "settings": {
            "logo": "shopify://shop_images/output-onlinepngtools.png",
            "quote": "<p>''The Car Parfum heeft mijn favoriete autogeur. Superblij met de snelle levering en het ruime assortiment.''</p>",
            "title": "Eline Vries (Geverifieerd)",
            "quote_tag": "h4",
            "font_size": "medium"
          }
        },
        "template--18081342914824__dbd17859-9f6c-48b3-84e1-4294e6f2fff5-quote-2": {
          "type": "quote",
          "settings": {
            "logo": "shopify://shop_images/output-onlinepngtools.png",
            "quote": "<p>\"Geweldige geuren! Mijn auto ruikt nu altijd fris en aangenaam tijdens mijn ritten.\"</p>",
            "title": "Sander Hermeling (Geverifieerd)",
            "quote_tag": "h4",
            "font_size": "medium"
          }
        },
        "f4980102-a08e-43e1-b18e-a0443980458e": {
          "type": "quote",
          "settings": {
            "logo": "shopify://shop_images/output-onlinepngtools.png",
            "quote": "<p>\"Million geur is een game changer! Mijn auto ruikt nu ongelooflijk en maakt elke autorit aangenaam.\"</p>",
            "title": "Rick van de Wijdeven (Geverifieerd)",
            "quote_tag": "h4",
            "font_size": "medium"
          }
        },
        "dd9783c7-2ed3-487d-851e-d94717f8cd53": {
          "type": "quote",
          "settings": {
            "logo": "shopify://shop_images/output-onlinepngtools.png",
            "quote": "<p>\"De freshbox top 3 exclusief is top! Ik kan nu afwisselen tussen drie heerlijke geuren in mijn auto, perfect voor elke stemming.\"</p>",
            "title": "Ruben Scholte (Geverifieerd)",
            "quote_tag": "h4",
            "font_size": "medium"
          }
        }
      },
