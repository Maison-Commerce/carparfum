{%- comment -%}
  Section: Maison Collection Banner
  Full-width banner with background image, gradient overlay, and overlaid content.
  Desktop: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-23216&m=dev
  Mobile: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-27824&m=dev
{%- endcomment -%}

<section
  class="maison_commerce_maison_collection_banner"
  style="background-color: {{ section.settings.section_bg_color }};"
>
  <div class="maison_commerce_maison_collection_banner__container">

    {%- comment -%} Background image {%- endcomment -%}
    {% if section.settings.bg_image != blank %}
      <div class="maison_commerce_maison_collection_banner__bg">
        <img
          class="maison_commerce_maison_collection_banner__bg-img maison_commerce_maison_collection_banner__bg-img--desktop"
          src="{{ section.settings.bg_image | image_url: width: 1600 }}"
          alt="{{ section.settings.bg_image.alt | default: '' }}"
          loading="lazy"
          width="{{ section.settings.bg_image.width }}"
          height="{{ section.settings.bg_image.height }}"
        >
        {% if section.settings.bg_image_mobile != blank %}
          <img
            class="maison_commerce_maison_collection_banner__bg-img maison_commerce_maison_collection_banner__bg-img--mobile"
            src="{{ section.settings.bg_image_mobile | image_url: width: 800 }}"
            alt="{{ section.settings.bg_image_mobile.alt | default: '' }}"
            loading="lazy"
            width="{{ section.settings.bg_image_mobile.width }}"
            height="{{ section.settings.bg_image_mobile.height }}"
          >
        {% endif %}
        <div class="maison_commerce_maison_collection_banner__bg-gradient"></div>
      </div>
    {% endif %}

    {%- comment -%} Content {%- endcomment -%}
    <div class="maison_commerce_maison_collection_banner__content">
      <div class="maison_commerce_maison_collection_banner__text-group">

        {%- comment -%} Subtitle with dot {%- endcomment -%}
        {% if section.settings.subtitle != blank %}
          <div class="maison_commerce_maison_collection_banner__subtitle-row">
            <span class="maison_commerce_maison_collection_banner__dot"></span>
            <span class="maison_commerce_maison_collection_banner__subtitle">
              {{ section.settings.subtitle }}
            </span>
          </div>
        {% endif %}

        {%- comment -%} Heading {%- endcomment -%}
        {% if section.settings.heading_italic != blank or section.settings.heading_bold != blank %}
          <h2 class="maison_commerce_maison_collection_banner__heading">
            {% if section.settings.heading_italic != blank %}
              <span class="maison_commerce_maison_collection_banner__heading-italic">{{ section.settings.heading_italic }}</span>
            {% endif %}
            {% if section.settings.heading_bold != blank %}
              <span class="maison_commerce_maison_collection_banner__heading-bold">{{ section.settings.heading_bold }}</span>
            {% endif %}
          </h2>
        {% endif %}

        {%- comment -%} Body text {%- endcomment -%}
        {% if section.settings.body_text != blank %}
          <p class="maison_commerce_maison_collection_banner__body">
            {{ section.settings.body_text }}
          </p>
        {% endif %}

      </div>

      {%- comment -%} CTA Button {%- endcomment -%}
      {% if section.settings.button_text != blank and section.settings.button_link != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="maison_commerce_maison_collection_banner__button"
          style="background: {{ section.settings.button_bg }}; color: {{ section.settings.button_text_color }};"
        >
          <span>{{ section.settings.button_text }}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M1.125 7.99683H14.25" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7.6875 14.5625L14.25 8L7.6875 1.4375" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </a>
      {% endif %}
    </div>

  </div>
</section>

<style>
  /* ========================================
     Section wrapper
     ======================================== */
  .maison_commerce_maison_collection_banner {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_left_desktop }}px;
    padding-right: {{ section.settings.padding_right_desktop }}px;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_left_mobile }}px;
      padding-right: {{ section.settings.padding_right_mobile }}px;
    }
  }

  /* ========================================
     Container
     ======================================== */
  .maison_commerce_maison_collection_banner__container {
    position: relative;
    overflow: hidden;
    max-width: 1360px;
    margin: 0 auto;
    height: {{ section.settings.container_height_desktop }}px;
    display: flex;
    align-items: stretch;
    background: {{ section.settings.container_bg }};
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner__container {
      height: auto;
      flex-direction: column;
      background: none;
    }
  }

  /* ========================================
     Background image layer
     ======================================== */
  .maison_commerce_maison_collection_banner__bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .maison_commerce_maison_collection_banner__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .maison_commerce_maison_collection_banner__bg-img--desktop {
    display: block;
  }

  .maison_commerce_maison_collection_banner__bg-img--mobile {
    display: none;
  }

  /* Gradient overlay (left-to-right fade on desktop) */
  .maison_commerce_maison_collection_banner__bg-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, {{ section.settings.overlay_color }} 29%, transparent 65%);
    z-index: 2;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner__bg {
      position: relative;
      height: {{ section.settings.mobile_image_height }}px;
      order: 2;
    }

    .maison_commerce_maison_collection_banner__bg-img--desktop {
      display: none;
    }

    .maison_commerce_maison_collection_banner__bg-img--mobile {
      display: block;
    }

    /* Fallback: show desktop image if no mobile image */
    .maison_commerce_maison_collection_banner__bg:not(:has(.maison_commerce_maison_collection_banner__bg-img--mobile)) .maison_commerce_maison_collection_banner__bg-img--desktop {
      display: block;
    }

    /* Top-to-bottom fade on mobile */
    .maison_commerce_maison_collection_banner__bg-gradient {
      background: linear-gradient(180deg, {{ section.settings.overlay_color }} 0%, transparent 50%);
    }
  }

  /* ========================================
     Content
     ======================================== */
  .maison_commerce_maison_collection_banner__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 40px;
    height: 100%;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner__content {
      order: 1;
      padding: 48px 20px 0;
      background: {{ section.settings.mobile_content_bg }};
      height: auto;
      gap: 48px;
    }
  }

  /* ========================================
     Text group (subtitle, heading, body)
     ======================================== */
  .maison_commerce_maison_collection_banner__text-group {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 600px;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner__text-group {
      max-width: 100%;
      gap: 12px;
      align-items: center;
      text-align: center;
    }
  }

  /* ========================================
     Subtitle with dot
     ======================================== */
  .maison_commerce_maison_collection_banner__subtitle-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner__subtitle-row {
      gap: 8px;
    }
  }

  .maison_commerce_maison_collection_banner__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    background-color: {{ section.settings.dot_color }};
  }

  .maison_commerce_maison_collection_banner__subtitle {
    font-size: {{ section.settings.subtitle_font_size_desktop }}px;
    line-height: 1.5;
    text-transform: uppercase;
    color: {{ section.settings.subtitle_color }};
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner__subtitle {
      font-size: {{ section.settings.subtitle_font_size_mobile }}px;
    }
  }

  /* ========================================
     Heading
     ======================================== */
  .maison_commerce_maison_collection_banner__heading {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 12px;
    line-height: 1.2;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner__heading {
      flex-direction: column;
      align-items: center;
      line-height: 1.4;
    }
  }

  .maison_commerce_maison_collection_banner__heading-italic {
    font-family: 'PP Editorial New', serif;
    font-style: italic;
    font-weight: 400;
    font-size: {{ section.settings.heading_italic_font_size_desktop }}px;
    color: {{ section.settings.heading_italic_color }};
  }

  .maison_commerce_maison_collection_banner__heading-bold {
    font-weight: 800;
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    color: {{ section.settings.text_color }};
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner__heading-italic {
      font-size: {{ section.settings.heading_italic_font_size_mobile }}px;
    }

    .maison_commerce_maison_collection_banner__heading-bold {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
  }

  /* ========================================
     Body text
     ======================================== */
  .maison_commerce_maison_collection_banner__body {
    font-size: {{ section.settings.body_font_size_desktop }}px;
    line-height: 1.5;
    color: {{ section.settings.body_color }};
    max-width: 600px;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner__body {
      font-size: {{ section.settings.body_font_size_mobile }}px;
      max-width: 100%;
    }
  }

  /* ========================================
     CTA Button
     ======================================== */
  .maison_commerce_maison_collection_banner__button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 400px;
    height: 56px;
    padding: 16px 32px;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 12px;
    line-height: 1.5;
    cursor: pointer;
    border: none;
    border-radius: 12px;
  }

  .maison_commerce_maison_collection_banner__button svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_collection_banner__button {
      max-width: 100%;
      height: 44px;
      padding: 12px 24px;
      border-radius: 8px;
    }
  }
</style>

