{% comment %}
  Section: Maison USP Slider
  Full-width banner slider with background image + overlay text per slide.
  Autoplay with configurable delay, dots navigation.
{% endcomment %}

{%- assign section_id = 'maison-usp-slider-' | append: section.id -%}

<section
  id="{{ section_id }}"
  class="maison-usp-slider"
  data-autoplay-delay="{{ section.settings.autoplay_delay | times: 1000 }}"
  data-show-dots="{{ section.settings.show_dots }}"
>
  {%- if section.blocks.size > 0 -%}
    <div class="swiper maison-usp-slider__swiper">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- if block.type == 'usp_slide' -%}
            {%- assign slide_tag = 'div' -%}
            {%- if block.settings.link != blank -%}{%- assign slide_tag = 'a' -%}{%- endif -%}

            <div class="swiper-slide maison-usp-slider__slide" {{ block.shopify_attributes }}>
              <{{ slide_tag }}
                class="maison-usp-slider__slide-inner"
                {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
              >
                <div class="maison-usp-slider__media">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 2000
                      | image_tag:
                        loading: 'lazy',
                        widths: '480, 768, 1200, 1600, 2000',
                        sizes: '100vw',
                        class: 'maison-usp-slider__img',
                        alt: block.settings.image.alt | default: block.settings.heading
                    }}
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'maison-usp-slider__img maison-usp-slider__img--placeholder' }}
                  {%- endif -%}
                </div>

                {%- if block.settings.overlay_opacity > 0 -%}
                  <span
                    class="maison-usp-slider__overlay"
                    style="background: {{ block.settings.overlay_color }}; opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
                  ></span>
                {%- endif -%}

                {%- if block.settings.icon != blank or block.settings.heading != blank or block.settings.subheading != blank -%}
                  <div
                    class="maison-usp-slider__content maison-usp-slider__content--{{ block.settings.text_position }} maison-usp-slider__content--align-{{ block.settings.text_align }}"
                    style="color: {{ block.settings.text_color }};"
                  >
                    {%- if block.settings.icon != blank -%}
                      <img
                        class="maison-usp-slider__icon"
                        src="{{ block.settings.icon | image_url: width: 256 }}"
                        alt="{{ block.settings.icon.alt | default: block.settings.heading }}"
                        loading="lazy"
                        style="--icon-width-desktop: {{ block.settings.icon_width_desktop }}px; --icon-width-mobile: {{ block.settings.icon_width_mobile }}px;"
                      >
                    {%- endif -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 class="maison-usp-slider__heading">{{ block.settings.heading }}</h2>
                    {%- endif -%}
                    {%- if block.settings.subheading != blank -%}
                      <p class="maison-usp-slider__subheading">{{ block.settings.subheading }}</p>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </{{ slide_tag }}>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_dots -%}
        <div class="maison-usp-slider__dots swiper-pagination"></div>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<style>
  #{{ section_id }}.maison-usp-slider {
    position: relative;
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    background: {{ section.settings.section_bg_color }};
  }

  #{{ section_id }} .maison-usp-slider__swiper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  #{{ section_id }} .maison-usp-slider__slide {
    position: relative;
    height: {{ section.settings.banner_height_desktop }}px;
    overflow: hidden;
  }

  #{{ section_id }} .maison-usp-slider__slide-inner {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  #{{ section_id }} .maison-usp-slider__media {
    position: absolute;
    inset: 0;
  }

  #{{ section_id }} .maison-usp-slider__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #{{ section_id }} .maison-usp-slider__img--placeholder {
    background: #e6e6e6;
  }

  #{{ section_id }} .maison-usp-slider__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  #{{ section_id }} .maison-usp-slider__content {
    position: absolute;
    left: 0;
    right: 0;
    padding: 40px 60px;
    z-index: 2;
    pointer-events: none;
  }

  #{{ section_id }} .maison-usp-slider__content--top    { top: 0; }
  #{{ section_id }} .maison-usp-slider__content--center { top: 50%; transform: translateY(-50%); }
  #{{ section_id }} .maison-usp-slider__content--bottom { bottom: 0; }

  #{{ section_id }} .maison-usp-slider__content--align-left   { text-align: left; }
  #{{ section_id }} .maison-usp-slider__content--align-center { text-align: center; }
  #{{ section_id }} .maison-usp-slider__content--align-right  { text-align: right; }

  #{{ section_id }} .maison-usp-slider__icon {
    display: block;
    height: auto;
    width: var(--icon-width-desktop, 48px);
    margin-bottom: 16px;
  }

  #{{ section_id }} .maison-usp-slider__content--align-center .maison-usp-slider__icon { margin-left: auto; margin-right: auto; }
  #{{ section_id }} .maison-usp-slider__content--align-right  .maison-usp-slider__icon { margin-left: auto; }

  #{{ section_id }} .maison-usp-slider__heading {
    font-size: {{ section.settings.heading_size_desktop }}px;
    font-weight: 600;
    line-height: 1.15;
    margin: 0;
    letter-spacing: 0.01em;
  }

  #{{ section_id }} .maison-usp-slider__subheading {
    font-size: {{ section.settings.subheading_size_desktop }}px;
    font-weight: 400;
    line-height: 1.4;
    margin: 12px 0 0;
  }

  /* Dots */
  #{{ section_id }} .maison-usp-slider__dots {
    position: absolute;
    bottom: 20px;
    left: 0;
    right: 0;
    z-index: 3;
    display: flex;
    justify-content: center;
    gap: 8px;
    pointer-events: auto;
  }

  #{{ section_id }} .maison-usp-slider__dots .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: {{ section.settings.dots_color }};
    opacity: 0.5;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    display: inline-block;
  }

  #{{ section_id }} .maison-usp-slider__dots .swiper-pagination-bullet-active {
    opacity: 1;
    transform: scale(1.25);
  }

  @media (max-width: 768px) {
    #{{ section_id }}.maison-usp-slider {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #{{ section_id }} .maison-usp-slider__slide {
      height: {{ section.settings.banner_height_mobile }}px;
    }

    #{{ section_id }} .maison-usp-slider__content {
      padding: 24px 20px;
    }

    #{{ section_id }} .maison-usp-slider__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }

    #{{ section_id }} .maison-usp-slider__subheading {
      font-size: {{ section.settings.subheading_size_mobile }}px;
      margin-top: 8px;
    }

    #{{ section_id }} .maison-usp-slider__icon {
      width: var(--icon-width-mobile, 36px);
      margin-bottom: 12px;
    }
  }
</style>

{%- if section.blocks.size > 1 -%}
  <script type="module">
    (function () {
      var sectionEl = document.getElementById('{{ section_id }}');
      if (!sectionEl) return;
      var swiperEl = sectionEl.querySelector('.maison-usp-slider__swiper');
      if (!swiperEl) return;

      var delay = parseInt(sectionEl.getAttribute('data-autoplay-delay'), 10) || 5000;
      var showDots = sectionEl.getAttribute('data-show-dots') === 'true';

      import('{{ 'swiper-chunk.js' | asset_url }}').then(function (mod) {
        var modules = [mod.Autoplay];
        if (showDots) modules.push(mod.Pagination);

        new mod.Swiper(swiperEl, {
          modules: modules,
          loop: true,
          slidesPerView: 1,
          speed: 700,
          autoplay: {
            delay: delay,
            disableOnInteraction: false,
            pauseOnMouseEnter: true,
          },
          pagination: showDots
            ? {
                el: sectionEl.querySelector('.maison-usp-slider__dots'),
                clickable: true,
                bulletClass: 'swiper-pagination-bullet',
                bulletActiveClass: 'swiper-pagination-bullet-active',
              }
            : false,
        });
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Maison USP Slider",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Slider Behavior"
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 2,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Autoplay delay",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "color",
      "id": "dots_color",
      "label": "Dots color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "banner_height_desktop",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Banner height (Desktop)",
      "default": 500
    },
    {
      "type": "range",
      "id": "banner_height_mobile",
      "min": 160,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Banner height (Mobile)",
      "default": 360
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading size (Desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Heading size (Mobile)",
      "default": 28
    },
    {
      "type": "range",
      "id": "subheading_size_desktop",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Subheading size (Desktop)",
      "default": 18
    },
    {
      "type": "range",
      "id": "subheading_size_mobile",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Subheading size (Mobile)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom (Mobile)",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "usp_slide",
      "name": "USP Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading text"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Slide link (optional)"
        },
        {
          "type": "header",
          "content": "Text styling"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "select",
          "id": "text_position",
          "label": "Text vertical position",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "bottom", "label": "Bottom" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Text alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "header",
          "content": "Overlay"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Overlay opacity",
          "default": 30
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Maison USP Slider",
      "blocks": [
        {
          "type": "usp_slide",
          "settings": {
            "heading": "4.6/5 op Trustpilot",
            "subheading": "10.000+ tevreden klanten"
          }
        },
        {
          "type": "usp_slide",
          "settings": {
            "heading": "High-end parfums",
            "subheading": "Premium geuren voor jouw auto"
          }
        },
        {
          "type": "usp_slide",
          "settings": {
            "heading": "Niet goed? Geld terug",
            "subheading": "30 dagen retourgarantie"
          }
        }
      ]
    }
  ]
}
{% endschema %}
