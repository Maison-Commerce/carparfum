{% comment %}
  Section: Maison Article List
  Blog article listing with featured article + smaller card list.
  Desktop: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-23150&m=dev
  Mobile: https://www.figma.com/design/wY5AIHOmFO9j24qx5DMQrU/Client-File-%7C-The-Car-Parfum?node-id=4199-28940&m=dev
{% endcomment %}

<section
  class="maison_commerce_maison_article_list"
  style="background-color: {{ section.settings.section_bg_color }};"
>
  <div class="maison_commerce_maison_article_list__container">
    {% if section.settings.section_heading != blank %}
      <h2 class="maison_commerce_maison_article_list__heading">
        {{ section.settings.section_heading }}
      </h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="maison_commerce_maison_article_list__content">
        {%- comment -%} Featured article (first block) {%- endcomment -%}
        {%- assign featured = section.blocks.first -%}
        {% if featured.type == 'article_item' %}
          <a
            {% if featured.settings.link != blank %}href="{{ featured.settings.link }}"{% endif %}
            class="maison_commerce_maison_article_list__featured"
            {{ featured.shopify_attributes }}
          >
            {% if featured.settings.image != blank %}
              <img
                class="maison_commerce_maison_article_list__featured-img"
                src="{{ featured.settings.image | image_url: width: 800 }}"
                alt="{{ featured.settings.image.alt | default: featured.settings.title }}"
                loading="lazy"
                width="{{ featured.settings.image.width }}"
                height="{{ featured.settings.image.height }}"
              >
            {% endif %}
            <div class="maison_commerce_maison_article_list__featured-gradient"></div>
            <div class="maison_commerce_maison_article_list__featured-info">
              {% if featured.settings.title != blank %}
                <h3 class="maison_commerce_maison_article_list__featured-title">
                  {{ featured.settings.title }}
                </h3>
              {% endif %}
              <div class="maison_commerce_maison_article_list__featured-meta">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="9.75" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M12 7.5V12H15.75" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                {% if featured.settings.read_time != blank %}
                  <span>{{ featured.settings.read_time }}</span>
                {% endif %}
                {% if featured.settings.date != blank %}
                  <span class="maison-blog-item-date">{{ featured.settings.date }}</span>
                {% endif %}
              </div>
            </div>
          </a>
        {% endif %}

        {%- comment -%} Article list (remaining blocks) {%- endcomment -%}
        {% if section.blocks.size > 1 %}
          <div class="maison_commerce_maison_article_list__list">
            {% for block in section.blocks offset:1 %}
              {% if block.type == 'article_item' %}
                <a
                  {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
                  class="maison_commerce_maison_article_list__item"
                  {{ block.shopify_attributes }}
                >
                  {% if block.settings.image != blank %}
                    <div class="maison_commerce_maison_article_list__item-thumb">
                      <img
                        class="maison_commerce_maison_article_list__item-img"
                        src="{{ block.settings.image | image_url: width: 300 }}"
                        alt="{{ block.settings.image.alt | default: block.settings.title }}"
                        loading="lazy"
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                      >
                    </div>
                  {% endif %}
                  <div class="maison_commerce_maison_article_list__item-body">
                    {% if block.settings.title != blank %}
                      <h3 class="maison_commerce_maison_article_list__item-title">
                        {{ block.settings.title }}
                      </h3>
                    {% endif %}
                    <div class="maison_commerce_maison_article_list__item-meta">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M12 20.25C16.5563 20.25 20.25 16.5563 20.25 12C20.25 7.44365 16.5563 3.75 12 3.75C7.44365 3.75 3.75 7.44365 3.75 12C3.75 16.5563 7.44365 20.25 12 20.25Z" stroke="currentColor" stroke-opacity="0.75" stroke-width="1.5" stroke-miterlimit="10"/>
                        <path d="M12 12.0001L15.7125 8.2876" stroke="currentColor" stroke-opacity="0.75" stroke-width="1.5"/>
                        <path d="M9.75 0.75L14.25 0.75" stroke="currentColor" stroke-opacity="0.75" stroke-width="1.5"/>
                      </svg>
                      {% if block.settings.read_time != blank %}
                        <span>{{ block.settings.read_time }}</span>
                      {% endif %}
                      {% if block.settings.date != blank %}
                        <span class="maison-blog-item-date">{{ block.settings.date }}</span>
                      {% endif %}
                    </div>
                  </div>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  /* ========================================
     Section wrapper
     ======================================== */
  .maison_commerce_maison_article_list {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_left_desktop }}px;
    padding-right: {{ section.settings.padding_right_desktop }}px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_left_mobile }}px;
      padding-right: {{ section.settings.padding_right_mobile }}px;
    }
  }

  /* ========================================
     Container
     ======================================== */
  .maison_commerce_maison_article_list__container {
    max-width: 1360px;
    margin: 0 auto;
  }

  /* ========================================
     Heading
     ======================================== */
  .maison_commerce_maison_article_list__heading {
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    color: {{ section.settings.heading_color }};
    text-align: center;
    line-height: 1.2;
    margin: 0 0 40px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
      line-height: 1.4;
      margin-bottom: 24px;
    }
  }

  /* ========================================
     Content (two-column layout)
     ======================================== */
  .maison_commerce_maison_article_list__content {
    display: flex;
    gap: 40px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__content {
      flex-direction: column;
      gap: 24px;
    }
  }

  /* ========================================
     Featured article (first block)
     ======================================== */
  .maison_commerce_maison_article_list__featured {
    flex: 1;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    text-decoration: none;
    color: inherit;
    min-height: 400px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__featured {
      flex: none;
      height: {{ section.settings.featured_height_mobile }}px;
      min-height: auto;
    }
  }

  .maison_commerce_maison_article_list__featured-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .maison_commerce_maison_article_list__featured-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, {{ section.settings.featured_gradient_color }});
    z-index: 1;
  }

  .maison_commerce_maison_article_list__featured-info {
    position: relative;
    z-index: 2;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .maison-blog-item-date{
    margin-left: auto;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__featured-info {
      padding: 24px;
      gap: 8px;
    }
  }

  .maison_commerce_maison_article_list__featured-title {
    font-size: {{ section.settings.featured_title_font_size_desktop }}px;
    color: {{ section.settings.featured_title_color }};
    line-height: 1.4;
    margin: 0;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__featured-title {
      font-size: {{ section.settings.featured_title_font_size_mobile }}px;
    }
  }

  .maison_commerce_maison_article_list__featured-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: {{ section.settings.featured_meta_color }};
    opacity: 0.5;
  }

  .maison_commerce_maison_article_list__featured-meta svg {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__featured-meta svg {
      width: 20px;
      height: 20px;
    }
  }

  /* ========================================
     Article list (remaining blocks)
     ======================================== */
  .maison_commerce_maison_article_list__list {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__list {
      gap: 16px;
    }
  }

  /* ========================================
     List item
     ======================================== */
  .maison_commerce_maison_article_list__item {
    display: flex;
    gap: 24px;
    text-decoration: none;
    color: inherit;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__item {
      gap: 16px;
    }
  }

  .maison_commerce_maison_article_list__item-thumb {
    width: 140px;
    height: 140px;
    flex-shrink: 0;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__item-thumb {
      width: 92px;
      height: 100px;
    }
  }

  .maison_commerce_maison_article_list__item-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .maison_commerce_maison_article_list__item-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-bottom: 1px solid rgba(2, 49, 48, 0.12);
    padding-bottom: 16px;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__item-body {
      padding-bottom: 8px;
    }
  }

  .maison_commerce_maison_article_list__item-title {
    font-size: {{ section.settings.list_title_font_size_desktop }}px;
    color: {{ section.settings.list_title_color }};
    line-height: 1.4;
    margin: 0;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__item-title {
      font-size: {{ section.settings.list_title_font_size_mobile }}px;
      line-height: 1.5;
    }
  }

  .maison_commerce_maison_article_list__item-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: {{ section.settings.list_meta_color }};
    opacity: 0.75;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__item-meta {
      font-size: 12px;
    }
  }

  .maison_commerce_maison_article_list__item-meta svg {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .maison_commerce_maison_article_list__item-meta svg {
      width: 16px;
      height: 16px;
    }
  }
</style>

{% schema %}
