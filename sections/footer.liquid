{%- comment -%} Logo {%- endcomment -%}
{%- comment -%} Content {%- endcomment -%}
{%- comment -%} Bottom bar (copyright + payment icons) {%- endcomment -%}

<footer
  class="maison_commerce_maison_footer"
  id="maison-footer-{{ section.id }}"
  style="{% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}"
>
  <div class="maison_commerce_maison_footer__container">

    {%- comment -%} Logo {%- endcomment -%}
    {% if section.settings.logo_image != blank %}
      <div class="maison_commerce_maison_footer__logo">
        {{ section.settings.logo_image | image_url: width: 440 | image_tag: class: 'maison_commerce_maison_footer__logo-img', loading: 'lazy' }}
      </div>
    {% endif %}

    {%- comment -%} Divider {%- endcomment -%}
    <div class="maison_commerce_maison_footer__divider"></div>

    {%- comment -%} Main content {%- endcomment -%}
    <div class="maison_commerce_maison_footer__content">

      {%- comment -%} Info column {%- endcomment -%}
      <div class="maison_commerce_maison_footer__info">
        {% if section.settings.description != blank %}
          <div class="maison_commerce_maison_footer__info-text">{{ section.settings.description }}</div>
        {% endif %}
        {% if section.settings.email != blank %}
          <a href="mailto:{{ section.settings.email }}" class="maison_commerce_maison_footer__info-email">{{ section.settings.email }}</a>
        {% endif %}
        {% if section.settings.company_info != blank %}
          <div class="maison_commerce_maison_footer__info-company">{{ section.settings.company_info }}</div>
        {% endif %}
      </div>

      {%- comment -%} Navigation columns {%- endcomment -%}
      <div class="maison_commerce_maison_footer__columns">

        {%- comment -%} Menu 1 {%- endcomment -%}
        {% assign menu_1 = linklists[section.settings.menu_1] %}
        {% if menu_1.links.size > 0 %}
          <div class="maison_commerce_maison_footer__column" data-accordion>
            <button type="button" class="maison_commerce_maison_footer__column-heading" aria-expanded="false">
              <span>{{ section.settings.menu_1_title }}</span>
              <svg class="maison_commerce_maison_footer__toggle-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M12 3.5V20.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M3.5 12H20.5" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </button>
            <div class="maison_commerce_maison_footer__column-links">
              {% for link in menu_1.links %}
                <a href="{{ link.url }}" class="maison_commerce_maison_footer__link">{{ link.title }}</a>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {%- comment -%} Menu 2 {%- endcomment -%}
        {% assign menu_2 = linklists[section.settings.menu_2] %}
        {% if menu_2.links.size > 0 %}
          <div class="maison_commerce_maison_footer__column" data-accordion>
            <button type="button" class="maison_commerce_maison_footer__column-heading" aria-expanded="false">
              <span>{{ section.settings.menu_2_title }}</span>
              <svg class="maison_commerce_maison_footer__toggle-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M12 3.5V20.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M3.5 12H20.5" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </button>
            <div class="maison_commerce_maison_footer__column-links">
              {% for link in menu_2.links %}
                <a href="{{ link.url }}" class="maison_commerce_maison_footer__link">{{ link.title }}</a>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {%- comment -%} Menu 3 {%- endcomment -%}
        {% assign menu_3 = linklists[section.settings.menu_3] %}
        {% if menu_3.links.size > 0 %}
          <div class="maison_commerce_maison_footer__column" data-accordion>
            <button type="button" class="maison_commerce_maison_footer__column-heading" aria-expanded="false">
              <span>{{ section.settings.menu_3_title }}</span>
              <svg class="maison_commerce_maison_footer__toggle-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M12 3.5V20.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M3.5 12H20.5" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </button>
            <div class="maison_commerce_maison_footer__column-links">
              {% for link in menu_3.links %}
                <a href="{{ link.url }}" class="maison_commerce_maison_footer__link">{{ link.title }}</a>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {%- comment -%} Social column {%- endcomment -%}
        <div class="maison_commerce_maison_footer__social">
          {% if section.settings.social_title != blank %}
            <div class="maison_commerce_maison_footer__social-heading">{{ section.settings.social_title }}</div>
          {% endif %}
          <div class="maison_commerce_maison_footer__social-links">
            {% if section.settings.instagram_url != blank %}
              <a href="{{ section.settings.instagram_url }}" class="maison_commerce_maison_footer__social-icon" target="_blank" rel="noopener" aria-label="Instagram" style="background-color: {{ section.settings.social_bg_color }};">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M2.625 2.625H21.375V21.375H2.625V2.625Z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M7.78125 12C7.78125 13.1189 8.22572 14.1919 9.01689 14.9831C9.80806 15.7743 10.8811 16.2188 12 16.2188C13.1189 16.2188 14.1919 15.7743 14.9831 14.9831C15.7743 14.1919 16.2188 13.1189 16.2188 12C16.2188 10.8811 15.7743 9.80806 14.9831 9.01689C14.1919 8.22572 13.1189 7.78125 12 7.78125C10.8811 7.78125 9.80806 8.22572 9.01689 9.01689C8.22572 9.80806 7.78125 10.8811 7.78125 12Z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M17.1562 5.90625H17.625V6.375H17.1562V5.90625Z" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </a>
            {% endif %}
            {% if section.settings.facebook_url != blank %}
              <a href="{{ section.settings.facebook_url }}" class="maison_commerce_maison_footer__social-icon" target="_blank" rel="noopener" aria-label="Facebook" style="background-color: {{ section.settings.social_bg_color }};">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M2.625 2.625H21.375V21.375H2.625V2.625Z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M17.625 8.25H14.8125C13.7769 8.25 12.9375 9.08947 12.9375 10.125V21.375" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M9.65625 13.875H16.2188" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </a>
            {% endif %}
            {% if section.settings.linkedin_url != blank %}
              <a href="{{ section.settings.linkedin_url }}" class="maison_commerce_maison_footer__social-icon" target="_blank" rel="noopener" aria-label="LinkedIn" style="background-color: {{ section.settings.social_bg_color }};">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M2.625 10.125H6.375V21.375H2.625V10.125Z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M21.375 21.375V15.75C21.375 12.6434 18.8566 10.125 15.75 10.125H10.125V21.375H13.875V13.875H14.8125C16.3658 13.875 17.625 15.1342 17.625 16.6875V21.375H21.375Z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M2.625 3.09375H6.375V6.84375H2.625V3.09375Z" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>

      </div>
    </div>

    {%- comment -%} Divider {%- endcomment -%}
    <div class="maison_commerce_maison_footer__divider"></div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="maison_commerce_maison_footer__bottom">
      {% if section.settings.copyright_text != blank %}
        <p class="maison_commerce_maison_footer__copyright">{{ section.settings.copyright_text }}</p>
      {% endif %}
      {% if section.blocks.size > 0 %}
        <div class="maison_commerce_maison_footer__payments">
          {% for block in section.blocks %}
            {% if block.type == 'payment_icon' and block.settings.image != blank %}
              <div class="maison_commerce_maison_footer__payment" {{ block.shopify_attributes }}>
                {{ block.settings.image | image_url: width: 70 | image_tag: loading: 'lazy' }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

  </div>

  {%- comment -%} Overlay {%- endcomment -%}
  {% if section.settings.overlay_image != blank %}
    <div class="maison_commerce_maison_footer__overlay">
      {{ section.settings.overlay_image | image_url: width: 2880 | image_tag: loading: 'lazy' }}
    </div>
  {% endif %}

</footer>

<style>
  /* ========================================
     Section
     ======================================== */
  .maison_commerce_maison_footer {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius_desktop }}px {{ section.settings.border_radius_desktop }}px 0 0;
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_left_desktop }}px;
    padding-right: {{ section.settings.padding_right_desktop }}px;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer {
      border-radius: {{ section.settings.border_radius_mobile }}px {{ section.settings.border_radius_mobile }}px 0 0;
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_left_mobile }}px;
      padding-right: {{ section.settings.padding_right_mobile }}px;
    }
  }

  /* ========================================
     Container
     ======================================== */
  .maison_commerce_maison_footer__container {
    max-width: 1360px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__container {
      gap: 20px;
    }
  }

  /* ========================================
     Logo
     ======================================== */
  .maison_commerce_maison_footer__logo {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .maison_commerce_maison_footer__logo-img {
    width: 219px;
    height: auto;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__logo-img {
      width: 132px;
    }
  }

  /* ========================================
     Divider
     ======================================== */
  .maison_commerce_maison_footer__divider {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
  }

  /* ========================================
     Content row
     ======================================== */
  .maison_commerce_maison_footer__content {
    display: flex;
    gap: 40px;
    align-items: flex-start;
    justify-content: space-between;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__content {
      flex-direction: column;
      gap: 20px;
    }
  }

  /* ========================================
     Info column
     ======================================== */
  .maison_commerce_maison_footer__info {
    flex: 0 0 auto;
    max-width: 340px;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__info {
      max-width: 100%;
      text-align: center;
      align-items: center;
      width: 100%;
    }
  }

  .maison_commerce_maison_footer__info-text,
  .maison_commerce_maison_footer__info-text p {
    font-size: {{ section.settings.body_font_size_desktop }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.5;
    padding: 8px 0;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__info-text,
    .maison_commerce_maison_footer__info-text p {
      font-size: {{ section.settings.body_font_size_mobile }}px;
      padding: 4px 0;
    }
  }

  .maison_commerce_maison_footer__info-email {
    font-size: {{ section.settings.body_font_size_desktop }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.5;
    text-decoration: underline;
    padding: 8px 0;
    display: inline-block;
    transition: opacity 0.3s ease;
  }

  .maison_commerce_maison_footer__info-email:hover {
    opacity: 0.7;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__info-email {
      font-size: {{ section.settings.body_font_size_mobile }}px;
      padding: 4px 0;
    }
  }

  .maison_commerce_maison_footer__info-company,
  .maison_commerce_maison_footer__info-company p {
    font-size: {{ section.settings.body_font_size_desktop }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.5;
    padding: 8px 0;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__info-company,
    .maison_commerce_maison_footer__info-company p {
      font-size: {{ section.settings.body_font_size_mobile }}px;
      padding: 4px 0;
    }
  }

  /* ========================================
     Navigation columns
     ======================================== */
  .maison_commerce_maison_footer__columns {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 32px;
    justify-content: flex-end;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__columns {
      flex-direction: column;
      gap: 12px;
      width: 100%;
    }
  }

  /* ========================================
     Single column
     ======================================== */
  .maison_commerce_maison_footer__column {
    flex: 0 0 auto;
    width: 200px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__column {
      width: 100%;
      gap: 0;
    }
  }

  /* ========================================
     Column heading
     ======================================== */
  .maison_commerce_maison_footer__column-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    font-size: {{ section.settings.body_font_size_desktop }}px;
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    line-height: 1.5;
    text-transform: uppercase;
    letter-spacing: 0;
    border: none;
    background: transparent;
    padding: 0 0 20px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    cursor: default;
    text-align: left;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__column-heading {
      font-size: {{ section.settings.body_font_size_mobile }}px;
      padding: 8px 0;
      border-bottom: none;
      cursor: pointer;
    }
  }

  /* ========================================
     Toggle icon (mobile only)
     ======================================== */
  .maison_commerce_maison_footer__toggle-icon {
    display: none;
    flex-shrink: 0;
    color: {{ section.settings.heading_color }};
    transition: transform 0.3s ease;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__toggle-icon {
      display: block;
    }
  }

  .maison_commerce_maison_footer__column-heading[aria-expanded="true"] .maison_commerce_maison_footer__toggle-icon {
    transform: rotate(45deg);
  }

  /* ========================================
     Column links
     ======================================== */
  .maison_commerce_maison_footer__column-links {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__column-links {
      display: none;
      padding-top: 4px;
    }

    .maison_commerce_maison_footer__column-links.is-open {
      display: flex;
    }
  }

  .maison_commerce_maison_footer__link {
    font-size: {{ section.settings.body_font_size_desktop }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.5;
    text-decoration: none;
    padding: 8px 0;
    transition: opacity 0.3s ease;
  }

  .maison_commerce_maison_footer__link:hover {
    opacity: 0.7;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__link {
      font-size: {{ section.settings.body_font_size_mobile }}px;
    }
  }

  /* ========================================
     Social column
     ======================================== */
  .maison_commerce_maison_footer__social {
    flex: 0 0 auto;
    width: 200px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__social {
      width: 100%;
      gap: 12px;
      padding: 8px 0;
    }
  }

  .maison_commerce_maison_footer__social-heading {
    font-size: {{ section.settings.body_font_size_desktop }}px;
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    line-height: 1.5;
    text-transform: uppercase;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__social-heading {
      font-size: {{ section.settings.body_font_size_mobile }}px;
      padding-bottom: 0;
      border-bottom: none;
    }
  }

  .maison_commerce_maison_footer__social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .maison_commerce_maison_footer__social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    color: {{ section.settings.heading_color }};
    transition: opacity 0.3s ease;
  }

  .maison_commerce_maison_footer__social-icon:hover {
    opacity: 0.7;
  }

  .maison_commerce_maison_footer__social-icon svg {
    width: 24px;
    height: 24px;
  }

  /* ========================================
     Bottom bar
     ======================================== */
  .maison_commerce_maison_footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__bottom {
      flex-direction: column;
      gap: 16px;
      align-items: center;
    }
  }

  .maison_commerce_maison_footer__copyright {
    font-size: {{ section.settings.body_font_size_desktop }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__copyright {
      font-size: {{ section.settings.copyright_font_size_mobile }}px;
      text-align: center;
    }
  }

  /* ========================================
     Payment icons
     ======================================== */
  .maison_commerce_maison_footer__payments {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__payments {
      justify-content: center;
    }
  }

  .maison_commerce_maison_footer__payment {
    width: 35px;
    height: 24px;
    flex-shrink: 0;
  }

  .maison_commerce_maison_footer__payment img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .maison_commerce_maison_footer__payment {
      width: 23px;
      height: 16px;
    }
  }

  /* ========================================
     Overlay
     ======================================== */
  .maison_commerce_maison_footer__overlay {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1440px;
    height: 100%;
    mix-blend-mode: plus-lighter;
    pointer-events: none;
    z-index: 0;
  }

  .maison_commerce_maison_footer__overlay img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  (function() {
    var SECTION_ID = '{{ section.id }}';

    function initFooter() {
      var section = document.getElementById('maison-footer-' + SECTION_ID);
      if (!section) return;

      var accordions = section.querySelectorAll('[data-accordion]');

      accordions.forEach(function(accordion) {
        var heading = accordion.querySelector('.maison_commerce_maison_footer__column-heading');
        var links = accordion.querySelector('.maison_commerce_maison_footer__column-links');
        if (!heading || !links) return;

        heading.addEventListener('click', function() {
          var isOpen = heading.getAttribute('aria-expanded') === 'true';
          heading.setAttribute('aria-expanded', !isOpen);
          links.classList.toggle('is-open', !isOpen);
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFooter);
    } else {
      initFooter();
    }

    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail && e.detail.sectionId === SECTION_ID) {
        initFooter();
      }
    });
  })();
</script>

