        },
        "faq_item_dzgTdD": {
          "type": "faq_item",
          "settings": {
            "question": "Zijn er minimale afnamehoeveelheden?",
            "answer": "<p>Ja. De exacte aantallen bespreken we graag persoonlijk. Neem contact op voor een offerte.</p>"
          }
        },
        "faq_item_Kmdj7C": {
          "type": "faq_item",
          "settings": {
            "question": "Bieden jullie gepersonaliseerde producten voor bedrijven?",
            "answer": "<p>We staan open voor samenwerkingen en gepersonaliseerde opties. Stuur ons een e-mail met je idee en we kijken naar de mogelijkheden.</p>"
          }
        },
        "faq_item_rG83aj": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe kan ik contact opnemen voor zakelijke vragen?",
            "answer": "<p>Stuur een e-mail met je bedrijfsnaam, locatie en wat je zoekt. We reageren binnen 24–48 uur.</p>"
          }
        }
      },
