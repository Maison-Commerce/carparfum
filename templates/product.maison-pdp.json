      "blocks": {
        "faq_item_7efD3N": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe lang gaat één flesje mee?",
            "answer": "<p>Een 15ml flacon gaat gemiddeld 4-6 weken mee bij normaal gebruik (4 sprays per keer, een paar keer per week). De 100ml fles gaat uiteraard veel langer mee.</p>"
          }
        },
        "faq_item_4TaBMC": {
          "type": "faq_item",
          "settings": {
            "question": "Is het veilig voor mijn auto-interieur?",
            "answer": "<p>Ja, onze formule is speciaal ontwikkeld om veilig te zijn voor alle auto-interieurs, inclusief leer, stof en kunststof.</p>"
          }
        },
        "faq_item_ykRyK9": {
          "type": "faq_item",
          "settings": {
            "question": "Wat als ik de geur niet lekker vind?",
            "answer": "<p>Wij bieden een 100% tevredenheidsgarantie. Als je niet tevreden bent met de geur, neem dan contact met ons op en we helpen je graag verder.</p>"
          }
        },
        "faq_item_rL6pG9": {
          "type": "faq_item",
          "settings": {
            "question": "Hoe werkt Subscribe & Save?",
            "answer": "<p>Met Subscribe & Save ontvang je automatisch een nieuw flesje op het door jou gekozen interval, met korting op elke levering.</p>"
          }
        },
        "faq_item_pF4zhL": {
          "type": "faq_item",
          "settings": {
            "question": "Waar wordt het gemaakt?",
            "answer": "<p>Al onze parfums worden met zorg gemaakt in Nederland, met hoogwaardige ingrediënten.</p>"
          }
        },
