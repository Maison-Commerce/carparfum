{%- comment -%} Section: Maison Compare Table {%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .maison_commerce_maison_compare_table {
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-right: {{ section.settings.padding_right_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --padding-left: {{ section.settings.padding_left_desktop }}px;
    --heading-font-size: {{ section.settings.heading_font_size_desktop }}px;
    --heading-italic-font-size: {{ section.settings.heading_italic_font_size_desktop }}px;
    --body-font-size: {{ section.settings.body_font_size_desktop }}px;
  }
  @media (max-width: 1050px) {
    #shopify-section-{{ section.id }} .maison_commerce_maison_compare_table {
      --padding-top: {{ section.settings.padding_top_mobile }}px;
      --padding-right: {{ section.settings.padding_right_mobile }}px;
      --padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --padding-left: {{ section.settings.padding_left_mobile }}px;
      --heading-font-size: {{ section.settings.heading_font_size_mobile }}px;
      --heading-italic-font-size: {{ section.settings.heading_italic_font_size_mobile }}px;
      --body-font-size: {{ section.settings.body_font_size_mobile }}px;
    }
  }
{%- endstyle -%}

<style>
  /* ====== Section wrapper ====== */
  .maison_commerce_maison_compare_table {
    padding: var(--padding-top) var(--padding-right) var(--padding-bottom) var(--padding-left);
    background: {{ section.settings.section_bg_color }};
  }

  /* ====== Container grid ====== */
  .maison_commerce_maison_compare_table__container {
    display: grid;
    grid-template-columns: 5fr 6fr;
    grid-template-rows: 1fr auto;
    gap: 40px;
    max-width: 1360px;
    margin: 0 auto;
  }

  /* ====== Header group (subtitle + heading) ====== */
  .maison_commerce_maison_compare_table__header-group {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .maison_commerce_maison_compare_table__subtitle-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .maison_commerce_maison_compare_table__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ section.settings.heading_color | default: '#001c4f' }};
    flex-shrink: 0;
  }

  .maison_commerce_maison_compare_table__subtitle {
    font-family: '{% comment %} font-family: 'PP Fragment', sans-serif; {% endcomment %}ment', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    text-transform: uppercase;
    color: #001C4F;
    margin: 0;
  }

  .maison_commerce_maison_compare_table__heading {
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  .maison_commerce_maison_compare_table__heading-bold {
    font-family: '{% comment %} font-family: 'PP Fragment', sans-serif; {% endcomment %}ment', sans-serif;
    font-weight: 800;
    font-size: var(--heading-font-size);
    line-height: 1.2;
    color: {{ section.settings.heading_color | default: '#121212' }};
  }

  .maison_commerce_maison_compare_table__heading-italic {
    font-family: 'PP Editorial New', serif;
    font-weight: 400;
    font-style: italic;
    font-size: var(--heading-italic-font-size);
    line-height: 1.2;
    background: linear-gradient(88.57deg, #00102C 0%, #001C4F 83.48%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  /* ====== Description ====== */
  .maison_commerce_maison_compare_table__description {
    grid-column: 1;
    grid-row: 2;
    align-self: end;
    font-weight: 400;
    font-size: var(--body-font-size);
    line-height: 1.5;
    color: {{ section.settings.body_color | hex_to_rgba: 0.75 }};
    margin: 0;
    max-width: 600px;
  }

  /* ====== Table ====== */
  .maison_commerce_maison_compare_table__table {
    grid-column: 2;
    grid-row: 1 / -1;
    align-self: start;
    width: 100%;
    min-width: 575px;
  }

  /* ====== Table rows ====== */
  .maison_commerce_maison_compare_table__row {
    display: flex;
    align-items: stretch;
  }

  /* ====== Table cells ====== */
  .maison_commerce_maison_compare_table__cell {
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .maison_commerce_maison_compare_table__cell--label {
    flex: 1 0 0;
    min-width: 0;
    height: 80px;
    padding: 20px 24px;
    justify-content: flex-start;
    font-family: '{% comment %} font-family: 'PP Fragment', sans-serif; {% endcomment %}ment', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 1.5;
    text-transform: uppercase;
    color: #121212;
  }

  .maison_commerce_maison_compare_table__row:not(.maison_commerce_maison_compare_table__row--header) .maison_commerce_maison_compare_table__cell--label {
    background-color: #f5f4f3;
  }

  .maison_commerce_maison_compare_table__cell--col1 {
    width: 200px;
    flex-shrink: 0;
    height: 80px;
    padding: 16px 8px;
    background-color: #001c4f;
    color: #f5f4f3;
  }

  .maison_commerce_maison_compare_table__row--header .maison_commerce_maison_compare_table__cell--col1 {
    border-radius: 24px 24px 0 0;
    padding: 20px 16px;
  }

  .maison_commerce_maison_compare_table__cell--col2 {
    width: 200px;
    flex-shrink: 0;
    height: 80px;
    padding: 16px 8px;
  }

  .maison_commerce_maison_compare_table__row:not(.maison_commerce_maison_compare_table__row--header) .maison_commerce_maison_compare_table__cell--col2 {
    background-color: #f5f4f3;
  }

  /* ====== Column header text ====== */
  .maison_commerce_maison_compare_table__col-heading {
    font-family: '{% comment %} font-family: 'PP Fragment', sans-serif; {% endcomment %}ment', sans-serif;
    font-weight: 800;
    font-size: 18px;
    line-height: 1.4;
    text-align: center;
    margin: 0;
  }

  /* ====== Value text ====== */
  .maison_commerce_maison_compare_table__value {
    font-family: '{% comment %} font-family: 'PP Fragment', sans-serif; {% endcomment %}ment', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.5;
    text-align: center;
  }

  .maison_commerce_maison_compare_table__value--bold {
    font-weight: 800;
  }

  /* ====== Check/uncheck circles ====== */
  .maison_commerce_maison_compare_table__circle {
    display: inline-block;
    width: 16px;
    height: 16px;
    border-radius: 50%;
  }

  .maison_commerce_maison_compare_table__cell--col1 .maison_commerce_maison_compare_table__circle--filled {
    background-color: #ffffff;
  }

  .maison_commerce_maison_compare_table__cell--col1 .maison_commerce_maison_compare_table__circle--empty {
    border: 1.5px solid rgba(255, 255, 255, 0.5);
  }

  .maison_commerce_maison_compare_table__cell--col2 .maison_commerce_maison_compare_table__circle--filled {
    background-color: #121212;
  }

  .maison_commerce_maison_compare_table__cell--col2 .maison_commerce_maison_compare_table__circle--empty {
    border: 1.5px solid #121212;
  }

  /* ====== Mobile ====== */
  @media (max-width: 1050px) {
    .maison_commerce_maison_compare_table__container {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      gap: 32px;
    }

    .maison_commerce_maison_compare_table__header-group {
      grid-column: 1;
      grid-row: 1;
      align-items: center;
      text-align: center;
    }

    .maison_commerce_maison_compare_table__subtitle-row {
      justify-content: center;
    }

    .maison_commerce_maison_compare_table__heading {
      align-items: center;
    }

    .maison_commerce_maison_compare_table__heading-bold,
    .maison_commerce_maison_compare_table__heading-italic {
      line-height: 1.4;
    }

    .maison_commerce_maison_compare_table__table {
      grid-column: 1;
      grid-row: 2;
      min-width: auto;
    }

    .maison_commerce_maison_compare_table__description {
      grid-column: 1;
      grid-row: 3;
      text-align: center;
      max-width: none;
      font-size: 14px;
    }

    .maison_commerce_maison_compare_table__row {
      flex-wrap: wrap;
    }

    .maison_commerce_maison_compare_table__row--header {
      flex-wrap: nowrap;
    }

    .maison_commerce_maison_compare_table__row--header .maison_commerce_maison_compare_table__cell--label {
      display: none;
    }

    .maison_commerce_maison_compare_table__cell--label {
      flex: 0 0 100%;
      height: 56px;
      justify-content: center;
      text-align: center;
      padding: 8px 16px;
    }

    .maison_commerce_maison_compare_table__cell--col1,
    .maison_commerce_maison_compare_table__cell--col2 {
      flex: 1 0 0;
      width: auto;
      height: 64px;
    }

    .maison_commerce_maison_compare_table__row--header .maison_commerce_maison_compare_table__cell--col1 {
      border-radius: 20px 20px 0 0;
    }

    .maison_commerce_maison_compare_table__value {
      font-size: 14px;
    }

    .maison_commerce_maison_compare_table__value--bold {
      font-weight: 800;
    }
  }
</style>

<section class="maison_commerce_maison_compare_table">
  <div class="maison_commerce_maison_compare_table__container">

    {%- comment -%} ====== Header Group (subtitle + heading) ====== {%- endcomment -%}
    <div class="maison_commerce_maison_compare_table__header-group">
      {% if section.settings.subtitle != blank %}
        <div class="maison_commerce_maison_compare_table__subtitle-row">
          <span class="maison_commerce_maison_compare_table__dot"></span>
          <span class="maison_commerce_maison_compare_table__subtitle">{{ section.settings.subtitle }}</span>
        </div>
      {% endif %}

      {% if section.settings.heading_bold != blank or section.settings.heading_italic != blank %}
        <h2 class="maison_commerce_maison_compare_table__heading">
          {%- if section.settings.heading_bold != blank -%}
            <span class="maison_commerce_maison_compare_table__heading-bold">{{ section.settings.heading_bold }}</span>
          {%- endif -%}
          {%- if section.settings.heading_italic != blank -%}
            <span class="maison_commerce_maison_compare_table__heading-italic">{{ section.settings.heading_italic }}</span>
          {%- endif -%}
        </h2>
      {% endif %}
    </div>

    {%- comment -%} ====== Comparison Table ====== {%- endcomment -%}
    <div class="maison_commerce_maison_compare_table__table">

      {%- comment -%} Column Headers {%- endcomment -%}
      <div class="maison_commerce_maison_compare_table__row maison_commerce_maison_compare_table__row--header">
        <div class="maison_commerce_maison_compare_table__cell maison_commerce_maison_compare_table__cell--label"></div>
        <div class="maison_commerce_maison_compare_table__cell maison_commerce_maison_compare_table__cell--col1">
          <span class="maison_commerce_maison_compare_table__col-heading">{{ section.settings.column_1_heading }}</span>
        </div>
        <div class="maison_commerce_maison_compare_table__cell maison_commerce_maison_compare_table__cell--col2">
          <span class="maison_commerce_maison_compare_table__col-heading">{{ section.settings.column_2_heading }}</span>
        </div>
      </div>

      {%- comment -%} Data Rows (blocks) {%- endcomment -%}
      {% for block in section.blocks %}
        <div class="maison_commerce_maison_compare_table__row" {{ block.shopify_attributes }}>
          <div class="maison_commerce_maison_compare_table__cell maison_commerce_maison_compare_table__cell--label">
            {{ block.settings.label }}
          </div>
          <div class="maison_commerce_maison_compare_table__cell maison_commerce_maison_compare_table__cell--col1">
            {% if block.settings.row_type == 'text' %}
              <span class="maison_commerce_maison_compare_table__value maison_commerce_maison_compare_table__value--bold">{{ block.settings.column_1_value }}</span>
            {% else %}
              {% if block.settings.column_1_checked %}
                <span class="maison_commerce_maison_compare_table__circle maison_commerce_maison_compare_table__circle--filled"></span>
              {% else %}
                <span class="maison_commerce_maison_compare_table__circle maison_commerce_maison_compare_table__circle--empty"></span>
              {% endif %}
            {% endif %}
          </div>
          <div class="maison_commerce_maison_compare_table__cell maison_commerce_maison_compare_table__cell--col2">
            {% if block.settings.row_type == 'text' %}
              <span class="maison_commerce_maison_compare_table__value">{{ block.settings.column_2_value }}</span>
            {% else %}
              {% if block.settings.column_2_checked %}
                <span class="maison_commerce_maison_compare_table__circle maison_commerce_maison_compare_table__circle--filled"></span>
              {% else %}
                <span class="maison_commerce_maison_compare_table__circle maison_commerce_maison_compare_table__circle--empty"></span>
              {% endif %}
            {% endif %}
          </div>
        </div>
      {% endfor %}

    </div>

    {%- comment -%} ====== Description ====== {%- endcomment -%}
    {% if section.settings.description != blank %}
      <p class="maison_commerce_maison_compare_table__description">{{ section.settings.description }}</p>
    {% endif %}

  </div>
</section>

{% schema %}
